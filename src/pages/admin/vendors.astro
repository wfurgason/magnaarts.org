    .req { color: var(--red); }

    .edit-fee-preview {
      display: flex;
      align-items: baseline;
      gap: 10px;
      background: #f0fdf4;
      border: 1.5px solid #bbf7d0;
      border-radius: 8px;
      padding: 14px 18px;
      margin: 4px 0 8px;
    }

    .edit-fee-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #166534;
      white-space: nowrap;
