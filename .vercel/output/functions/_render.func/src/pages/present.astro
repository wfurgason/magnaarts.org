---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const options = [
  {
    icon: '💡',
    num: '01',
    title: 'Propose a Program',
    body: 'Have an idea for an event, class, performance, or community program that doesn\'t fit the categories below? Submit a general proposal and the board will review it at the next monthly meeting.',
    link: '/propose',
    label: 'Submit a proposal →',
    color: 'red',
  },
  {
    icon: '🎸',
    num: '02',
    title: 'Apply as a Band',
    body: 'Perform live at Music & Movies in the Park — our summer Friday night concert series at Pleasant Green Park. Open to all genres. Reviewed by the board each season.',
    link: '/call-for-bands',
    label: 'Apply to perform →',
    color: 'blue',
  },
  {
    icon: '🎨',
    num: '03',
    title: 'Teach an Art Class',
    body: 'Lead a Group Art Night session at the Magna Library. Share your skill — painting, drawing, pottery, crafts, or any hands-on art form — with your neighbors.',
    link: '/teach-an-art-class',
    label: 'Submit your interest →',
    color: 'green',
  },
  {
    icon: '🛒',
    num: '04',
    title: 'Vendor at the Arts Festival',
    body: 'Sell your art, crafts, or food at the Magna Main Street Arts Festival. Applications open each spring for our annual flagship event drawing thousands of attendees.',
    link: '/vendor-application',
    label: 'Apply as a vendor →',
    color: 'amber',
  },
];
---

<BaseLayout
  title="Present or Perform — Magna Arts Council"
  description="Ways to present, perform, or participate in Magna Arts Council programs — propose an event, apply as a band, teach an art class, or become a festival vendor."
>
  <Header />

  <main>

    <!-- ── PAGE HERO ── -->
    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">Present &amp; Perform</div>
        <h1>Bring Your Talent to Magna</h1>
        <p class="hero-sub">
          There are several ways to share your art with the community.
          Choose the path that fits what you do.
        </p>
      </div>
    </section>

    <!-- ── OPTIONS GRID ── -->
    <section class="section options-section">
      <div class="container">
        <div class="options-grid">
          {options.map(o => (
            <div class={`option-card option-${o.color}`}>
              <div class="option-num">{o.num}</div>
              <span class="option-icon">{o.icon}</span>
              <h3>{o.title}</h3>
              <p>{o.body}</p>
              <a href={o.link} class="option-link">{o.label}</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PROCESS ── -->
    <section class="process-section">
      <div class="container process-inner">
        <div class="process-text">
          <div class="hero-badge">How It Works</div>
          <h2>What Happens After You Apply</h2>
          <p>
            Every submission is reviewed by the full Arts Council board. We meet monthly
            and respond to all applicants. Accepted presenters and performers are paired with
            a board sponsor who helps you plan, promote, and run your event.
          </p>
          <p>
            All events are free and open to the Magna community — your audience is built in.
          </p>
          <a href="/contact" class="btn btn-gold" style="margin-top: 8px;">Have a question? Contact us →</a>
        </div>
        <div class="process-steps">
          <div class="step">
            <div class="step-num">1</div>
            <div>
              <strong>Apply or Propose</strong>
              <p>Submit your application or proposal using the form that matches your interest.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div>
              <strong>Board Review</strong>
              <p>The board reviews your submission at the next monthly meeting and votes to accept.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div>
              <strong>Plan Together</strong>
              <p>A board sponsor is assigned to help you with logistics, promotion, and setup.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">4</div>
            <div>
              <strong>Take the Stage</strong>
              <p>Your event goes live — free and open to the whole Magna community.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-banner">
      <div class="container cta-inner">
        <div>
          <h2>Not Sure Which Fits?</h2>
          <p>Reach out and we'll point you in the right direction.</p>
        </div>
        <a href="/contact" class="btn btn-gold">Contact Us →</a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0 64px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.18);
    border: 1px solid rgba(232, 160, 32, 0.45);
    color: var(--gold-lt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 18px;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── OPTIONS ── */
  .options-section { background: var(--white); }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .option-card {
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 36px 32px 30px;
    box-shadow: var(--shadow-card);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.22s, transform 0.22s;
  }

  .option-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }

  .option-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    border-radius: var(--radius) var(--radius) 0 0;
  }

  .option-red::before    { background: var(--red); }
  .option-blue::before   { background: var(--blue); }
  .option-green::before  { background: var(--green); }
  .option-amber::before  { background: var(--amber); }

  .option-num {
    position: absolute;
    top: 18px;
    right: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--border);
  }

  .option-icon { font-size: 32px; }

  .option-card h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    color: var(--navy);
  }

  .option-card p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .option-link {
    font-size: 14px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
    transition: gap 0.2s;
    text-decoration: none;
  }

  .option-red .option-link    { color: var(--red); }
  .option-blue .option-link   { color: var(--blue); }
  .option-green .option-link  { color: var(--green); }
  .option-amber .option-link  { color: var(--amber); }
  .option-link:hover { gap: 8px; }

  /* ── PROCESS ── */
  .process-section {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0;
  }

  .process-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .process-text .hero-badge {
    background: rgba(232, 160, 32, 0.18);
    border: 1px solid rgba(232, 160, 32, 0.45);
    color: var(--gold-lt);
    margin-bottom: 16px;
  }

  .process-text h2 {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .process-text p {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--navy-dk);
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step strong {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }

  .step p {
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTA ── */
  .cta-banner {
    background: var(--navy-dk);
    color: var(--white);
    padding: 56px 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .cta-inner h2 {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .cta-inner p {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .options-grid  { grid-template-columns: 1fr; }
    .process-inner { grid-template-columns: 1fr; gap: 40px; }
    .cta-inner     { flex-direction: column; align-items: flex-start; }
  }
</style>
