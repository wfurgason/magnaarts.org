---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';

const user = Astro.locals.user;
const filterParam = Astro.url.searchParams.get('filter') || 'all';

const snap = await adminDb.collection('vendor_applications')
  .orderBy('submitted_at', 'asc')
  .get();

type Vendor = {
  id: string;
  contact_name: string;
  company_name: string;
  address: string;
  city_zip: string;
  phone: string;
  email: string;
  website?: string;
  vendor_type: string;
  selling: string;
  description?: string;
  needs_electricity: string;
  needs_water: string;
  additional_comments?: string;
  location_request?: string;
  waiver_agreed: boolean;
  signature: string;
  status: string;
  space_number?: string;
  payment_method?: string;
  submitted_at: string;
  reviewedBy?: string;
  paidAt?: any;
  profile_image_url?: string;
  admin_notes?: string;
};

let vendors = snap.docs.map(d => ({ id: d.id, ...d.data() })) as Vendor[];

// Data map for edit modal — all vendors keyed by doc ID, built before filter is applied
const vendorDataMap: Record<string, Record<string, any>> = Object.fromEntries(
  snap.docs.map(d => [d.id, d.data()])
);

// Build conflict map from ALL vendors before filter is applied
const assignedSpaces: Record<string, string> = {};
for (const v of vendors) {
  if ((v.status || 'pending') === 'paid' && v.space_number) {
    assignedSpaces[String(v.space_number).trim()] = v.company_name || v.contact_name || 'Unknown';
  }
}

const filters = ['all', 'pending', 'approved', 'paid', 'rejected'];
const filterLabels: Record<string, string> = {
  all: 'All',
  pending: 'Pending',
  approved: 'Approved',
  paid: 'Paid',
  rejected: 'Rejected',
};

const counts: Record<string, number> = { all: vendors.length };
for (const f of ['pending', 'approved', 'paid', 'rejected']) {
  counts[f] = vendors.filter(v => (v.status || 'pending') === f).length;
}

if (filterParam !== 'all') {
  vendors = vendors.filter(v => (v.status || 'pending') === filterParam);
}

const feeMap: Record<string, number> = {
  'Individual Artist': 25,
  'Food Vendor': 100,
  'Retail / Franchise / non-profit': 50,
  'Political': 75,
};

function calcTotal(v: Vendor): number {
  return (feeMap[v.vendor_type] ?? 0)
    + (v.needs_electricity === 'yes' ? 10 : 0)
    + (v.needs_water === 'yes' ? 10 : 0);
}
---

<AdminLayout title="Vendor Applications" user={user}>

  <div class="page-header">
    <div>
      <h1>Vendor Applications</h1>
      <p class="page-sub">Magna Main Street Arts Festival · August 15, 2026</p>
    </div>
  </div>

  <div class="filter-tabs">
    {filters.map(f => (
      <a
        href={`/admin/vendors${f === 'all' ? '' : `?filter=${f}`}`}
        class:list={['filter-tab', { active: filterParam === f }]}
      >
        {filterLabels[f]}
        {counts[f] > 0 && <span class="tab-badge">{counts[f]}</span>}
      </a>
    ))}
  </div>

  {vendors.length === 0 ? (
    <div class="empty-state">
      <p>No vendor applications matching this filter.</p>
      <p style="margin-top:8px;font-size:13px;">Applications come in through <a href="/vendor-application">/vendor-application</a>.</p>
    </div>
  ) : (
    <div class="submission-list">
      {vendors.map(v => {
        const total = calcTotal(v);
        const feeBreakdown = [
          `${v.vendor_type}: $${feeMap[v.vendor_type] ?? 0}`,
          v.needs_electricity === 'yes' ? '+$10 electric' : '',
          v.needs_water === 'yes' ? '+$10 water' : '',
        ].filter(Boolean).join(' · ');

        return (
          <div class="submission-card" id={`card-${v.id}`}>
            <div class="submission-header">
              <div class="submission-title-group">
                <div>
                  <h2 class="submission-name">{v.company_name}</h2>
                  <span class="submission-meta">{v.contact_name} · {v.email}</span>
                </div>
              </div>
              <div class="header-right">
                {v.status === 'paid' && v.space_number && (
                  <>
                    <div
                      class="space-badge space-badge-editable"
                      data-id={v.id}
                      data-space={v.space_number}
                      title="Click to edit space number"
                    >Space {v.space_number}</div>
                    <button
                      type="button"
                      class="resend-link"
                      data-action="resend-confirmation"
                      data-id={v.id}
                      data-company={v.company_name}
                      title="Resend the space confirmation email to this vendor"
                    >✉️ Resend</button>
                  </>
                )}
                <span class={`badge badge-${v.status || 'pending'}`}>{v.status || 'pending'}</span>
              </div>
            </div>

            <div class="submission-body">
              <div class="detail-grid">
                <div>
                  <div class="detail-label">Contact</div>
                  <div>{v.contact_name}</div>
                  <div><a href={`mailto:${v.email}`}>{v.email}</a></div>
                  <div>{v.phone}</div>
                </div>
                <div>
                  <div class="detail-label">Address</div>
                  <div>{v.address}</div>
                  <div>{v.city_zip}</div>
                </div>
                <div>
                  <div class="detail-label">Fee</div>
                  <div class="fee-total">${total}</div>
                  <div style="font-size:12px;color:var(--muted);margin-top:2px;">{feeBreakdown}</div>
                </div>
                <div>
                  <div class="detail-label">Utilities + Links</div>
                  <div>⚡ {v.needs_electricity === 'yes' ? 'Electric: Yes' : 'No electric'}</div>
                  <div>💧 {v.needs_water === 'yes' ? 'Water: Yes' : 'No water'}</div>
                  {v.website && <div style="margin-top:4px;"><a href={/^https?:\/\//i.test(v.website) ? v.website : `https://${v.website}`} target="_blank" rel="noopener">Website ↗</a></div>}
                </div>
              </div>

              {v.location_request && (
                <div class="detail-bio location-request">
                  <div class="detail-label">📍 Requested Space Location</div>
                  <p>{v.location_request}</p>
                </div>
              )}

              <div class="detail-bio">
                <div class="detail-label">What They're Selling</div>
                <p>{v.selling}</p>
              </div>

              {v.description && (
                <div class="detail-bio">
                  <div class="detail-label">Public Website Description</div>
                  <p>{v.description}</p>
                </div>
              )}

              {v.profile_image_url && (
                <div class="detail-bio">
                  <div class="detail-label">Profile Image</div>
                  <img src={v.profile_image_url} alt={`${v.company_name} profile`} class="vendor-profile-img" />
                </div>
              )}

              {v.additional_comments && (
                <div class="detail-bio">
                  <div class="detail-label">Additional Comments</div>
                  <p>{v.additional_comments}</p>
                </div>
              )}

              <div class="waiver-notice">
                <span>✓</span>
                <span>Waiver agreed &amp; signed by <strong>{v.signature}</strong></span>
              </div>

              {v.status === 'paid' && (
                <div class="paid-notice">
                  <span>✅</span>
                  <span>
                    Payment confirmed · Space
                    <strong
                      id={`space-display-${v.id}`}
                      class="space-inline-editable"
                      data-id={v.id}
                      data-space={v.space_number || ''}
                      title="Click to edit space number"
                    >{v.space_number || 'Assign…'}</strong>
                    {v.payment_method && <> · {v.payment_method}</>}
                  </span>
                </div>
              )}

              <div class="admin-notes-box">
                <label class="detail-label" for={`notes-${v.id}`}>🔒 Admin Notes</label>
                <textarea
                  id={`notes-${v.id}`}
                  class="admin-notes-textarea"
                  data-id={v.id}
                  placeholder="Internal notes — not visible to vendors…"
                  rows="2"
                >{v.admin_notes || ''}</textarea>
                <div class="admin-notes-status" id={`notes-status-${v.id}`}></div>
              </div>

            </div>

            <div class="submission-actions">
              {v.status === 'pending' && (
                <>
                  <button class="btn btn-success" data-action="approve" data-id={v.id} data-company={v.company_name}>
                    ✓ Approve &amp; Notify
                  </button>
                  <button class="btn btn-danger" data-action="reject" data-id={v.id} data-company={v.company_name}>
                    Reject
                  </button>
                </>
              )}

              {v.status === 'approved' && (
                <>
                  <button class="btn btn-paid" data-action="open-paid-modal" data-id={v.id} data-company={v.company_name} data-total={total}>
                    💳 Mark as Paid &amp; Assign Space
                  </button>
                  <button class="btn btn-muted" data-action="unapprove" data-id={v.id} data-company={v.company_name}>
                    Undo Approval
                  </button>
                </>
              )}

              {v.status === 'paid' && (
                <button class="btn btn-muted" data-action="reject" data-id={v.id} data-company={v.company_name}>
                  Revoke (move to rejected)
                </button>
              )}

              {v.status === 'rejected' && (
                <button class="btn btn-success" data-action="approve" data-id={v.id} data-company={v.company_name}>
                  Re-approve
                </button>
              )}

              <button class="btn btn-edit" data-action="open-edit-modal" data-id={v.id}>
                ✏️ Edit
              </button>
              <button class="btn btn-delete" data-action="delete" data-id={v.id} data-company={v.company_name}>
                🗑 Delete
              </button>

              <div class="submitted-at">
                Submitted {v.submitted_at ? new Date(v.submitted_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—'}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <!-- ── Mark as Paid Modal ── -->
  <div id="paid-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true">
    <div class="modal-box">
      <div class="modal-header">
        <h2>Mark as Paid &amp; Assign Space</h2>
        <button id="modal-close" class="modal-close" aria-label="Close">✕</button>
      </div>
      <p class="modal-sub" id="modal-company-name"></p>

      <div class="modal-field">
        <label for="modal-space">Assigned Space Number <span class="req">*</span></label>
        <input type="text" id="modal-space" placeholder="e.g. 14 or A7" />
      </div>

      <div class="modal-field">
        <label for="modal-method">Payment Method</label>
        <select id="modal-method">
          <option value="">Select…</option>
          <option value="PayPal">PayPal</option>
          <option value="Venmo">Venmo</option>
          <option value="Cash">Cash</option>
          <option value="Check">Check</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="modal-field">
        <label for="modal-note">Payment Note (optional)</label>
        <input type="text" id="modal-note" placeholder="Reference # or other notes" />
      </div>

      <div class="modal-actions">
        <button id="modal-cancel" class="btn btn-muted">Cancel</button>
        <button id="modal-confirm" class="btn btn-paid">Confirm &amp; Send Email</button>
      </div>
    </div>
  </div>

  <!-- ── Edit Modal ── -->
  <div id="edit-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true">
    <div class="modal-box modal-box--large">
      <div class="modal-header">
        <h2>&#x270F;&#xFE0F; Edit Vendor Application</h2>
        <button id="edit-modal-close" class="modal-close" aria-label="Close">&#x2715;</button>
      </div>
      <p class="modal-sub" id="edit-modal-company"></p>

      <div class="edit-section-label">Contact &amp; Business Info</div>

      <div class="modal-two-col">
        <div class="modal-field">
          <label for="edit-contact-name">Contact Name</label>
          <input type="text" id="edit-contact-name" placeholder="Jane Smith" />
        </div>
        <div class="modal-field">
          <label for="edit-company-name">Business / Company Name</label>
          <input type="text" id="edit-company-name" placeholder="Acme Arts" />
        </div>
      </div>

      <div class="modal-field">
        <label for="edit-address">Address</label>
        <input type="text" id="edit-address" placeholder="123 Main St" />
      </div>

      <div class="modal-two-col">
        <div class="modal-field">
          <label for="edit-city-zip">City &amp; ZIP</label>
          <input type="text" id="edit-city-zip" placeholder="Magna, UT 84044" />
        </div>
        <div class="modal-field">
          <label for="edit-phone">Phone</label>
          <input type="tel" id="edit-phone" placeholder="(801) 555-0100" />
        </div>
      </div>

      <div class="modal-two-col">
        <div class="modal-field">
          <label for="edit-email">Email Address</label>
          <input type="email" id="edit-email" placeholder="vendor@example.com" />
        </div>
        <div class="modal-field">
          <label for="edit-website">Website (optional)</label>
          <input type="url" id="edit-website" placeholder="https://example.com" />
        </div>
      </div>

      <div class="edit-section-label">Booth &amp; Products</div>

      <div class="modal-field">
        <label for="edit-vendor-type">Vendor Type <span class="req">*</span></label>
        <select id="edit-vendor-type">
          <option value="Individual Artist">Individual Artist &#x2014; $25</option>
          <option value="Retail / Franchise / non-profit">Retail / Franchise / Non-Profit &#x2014; $50</option>
          <option value="Political">Political &#x2014; $75</option>
          <option value="Food Vendor">Food Vendor &#x2014; $100</option>
        </select>
      </div>

      <div class="modal-two-col">
        <div class="modal-field">
          <label for="edit-electricity">Needs Electricity?</label>
          <select id="edit-electricity">
            <option value="no">No</option>
            <option value="yes">Yes (+$10)</option>
          </select>
        </div>
        <div class="modal-field">
          <label for="edit-water">Needs Water?</label>
          <select id="edit-water">
            <option value="no">No</option>
            <option value="yes">Yes (+$10)</option>
          </select>
        </div>
      </div>

      <div class="edit-fee-preview">
        <span class="edit-fee-label">Updated Fee Total</span>
        <span class="edit-fee-amount" id="edit-fee-amount">$0</span>
        <span class="edit-fee-breakdown" id="edit-fee-breakdown"></span>
      </div>

      <div class="modal-field">
        <label for="edit-selling">What They're Selling</label>
        <textarea id="edit-selling" rows="2" placeholder="Handmade jewelry, prints&#x2026;"></textarea>
      </div>

      <div class="modal-field">
        <label for="edit-description">Public Website Description (optional)</label>
        <textarea id="edit-description" rows="2" placeholder="Description shown on the festival page&#x2026;"></textarea>
      </div>

      <div class="modal-field">
        <label for="edit-location-request">Space Location Request (optional)</label>
        <textarea id="edit-location-request" rows="2" placeholder="Near the stage, corner spot&#x2026;"></textarea>
      </div>

      <div class="modal-field">
        <label for="edit-comments">Additional Comments (optional)</label>
        <textarea id="edit-comments" rows="2" placeholder="Any other notes&#x2026;"></textarea>
      </div>

      <div class="edit-section-label">Vendor Photo</div>

      <div class="modal-field">
        <div id="edit-photo-preview-wrap" style="display:none;margin-bottom:10px;">
          <img id="edit-photo-preview" alt="Vendor photo preview" style="max-width:200px;max-height:150px;object-fit:cover;border-radius:8px;border:1.5px solid #e2e0d8;display:block;" />
        </div>
        <label for="edit-photo-file" class="photo-upload-btn">Choose Photo</label>
        <input type="file" id="edit-photo-file" accept="image/*" style="display:none;" />
        <div id="edit-photo-status" class="edit-photo-status"></div>
        <div style="font-size:11px;color:#6b7280;margin-top:6px;">Uploading a new photo replaces the existing one &#x2014; the old file is deleted automatically.</div>
      </div>

      <div class="modal-actions">
        <button id="edit-modal-cancel" class="btn btn-muted">Cancel</button>
        <button id="edit-modal-confirm" class="btn btn-edit-confirm">Save Changes</button>
      </div>
    </div>
  </div>

  <!-- ── Delete Confirmation Modal ── -->
  <div id="delete-modal" class="modal-backdrop" style="display:none" role="dialog" aria-modal="true">
    <div class="modal-box">
      <div class="modal-header">
        <h2 style="color:#991b1b">🗑 Delete Vendor Record</h2>
        <button id="delete-modal-close" class="modal-close" aria-label="Close">✕</button>
      </div>
      <p class="modal-sub" id="delete-modal-sub"></p>
      <div style="background:#fee2e2;border:1.5px solid #fca5a5;border-radius:8px;padding:14px 18px;margin-bottom:20px;font-size:13px;color:#991b1b;line-height:1.6;">
        This will permanently delete the application from Firestore. This action cannot be undone.
      </div>
      <div class="modal-actions">
        <button id="delete-modal-cancel" class="btn btn-muted">Cancel</button>
        <button id="delete-modal-confirm" class="btn btn-danger">Yes, Delete</button>
      </div>
    </div>
  </div>

  <script type="application/json" id="assigned-spaces-data" set:html={JSON.stringify(assignedSpaces)}></script>
  <script type="application/json" id="vendor-data-map" set:html={JSON.stringify(vendorDataMap)}></script>

  <script>
    // ── Assigned spaces conflict map ──────────────────────────────────────
    const ASSIGNED_SPACES: Record<string, string> = JSON.parse(
      document.getElementById('assigned-spaces-data')?.textContent || '{}'
    );

    const VENDOR_DATA_MAP: Record<string, any> = JSON.parse(
      document.getElementById('vendor-data-map')?.textContent || '{}'
    );

    // ── Space inline editing (header badge + paid-notice) ─────────────────
    function attachSpaceEditor(el: Element) {
      const badge = el as HTMLElement;

      badge.addEventListener('click', () => {
        if (badge.querySelector('input')) return; // already editing

        const id           = badge.dataset.id!;
        const currentSpace = badge.dataset.space || '';
        const originalText = badge.textContent || '';
        const isBadge      = badge.classList.contains('space-badge-editable');

        badge.textContent = '';
        const input = document.createElement('input');
        input.type  = 'text';
        input.value = currentSpace;
        input.style.cssText = isBadge
          ? [
              'width:80px',
              'font-family:inherit',
              'font-size:13px',
              'font-weight:700',
              'color:#e8a020',
              'background:#1a2456',
              'border:1.5px solid #e8a020',
              'border-radius:6px',
              'padding:2px 7px',
              'outline:none',
              'text-align:center',
            ].join(';')
          : [
              'width:70px',
              'font-family:inherit',
              'font-size:13px',
              'font-weight:700',
              'color:#1e40af',
              'background:#fff',
              'border:1.5px solid #1e40af',
              'border-radius:4px',
              'padding:1px 6px',
              'outline:none',
              'text-align:center',
            ].join(';');
        badge.appendChild(input);
        input.focus();
        input.select();

        let saved = false;

        async function saveSpace() {
          if (saved) return;
          const newSpace = input.value.trim();

          // No change — just cancel
          if (!newSpace || newSpace === currentSpace) {
            badge.textContent  = originalText;
            badge.dataset.space = currentSpace;
            return;
          }

          // Conflict check
          const conflictVendor = ASSIGNED_SPACES[newSpace];
          if (conflictVendor && newSpace !== currentSpace) {
            const ok = confirm(`Space ${newSpace} is already assigned to "${conflictVendor}". Assign anyway?`);
            if (!ok) {
              badge.textContent = originalText;
              return;
            }
          }

          saved = true;
          badge.textContent = 'Saving…';

          try {
            const res = await fetch('/api/admin/vendor-action', {
              method:  'POST',
              headers: { 'Content-Type': 'application/json' },
              body:    JSON.stringify({ action: 'update-space', id, spaceNumber: newSpace }),
            });

            if (res.ok) {
              const json = await res.json().catch(() => ({}));

              // Update this element
              badge.dataset.space = newSpace;
              badge.textContent   = isBadge ? `Space ${newSpace}` : newSpace;

              // Sync the other element (badge <-> paid-notice)
              if (isBadge) {
                const displayEl = document.getElementById(`space-display-${id}`) as HTMLElement | null;
                if (displayEl) { displayEl.dataset.space = newSpace; displayEl.textContent = newSpace; }
              } else {
                const headerBadge = document.querySelector(`.space-badge-editable[data-id="${id}"]`) as HTMLElement | null;
                if (headerBadge) { headerBadge.dataset.space = newSpace; headerBadge.textContent = `Space ${newSpace}`; }
              }

              // Keep conflict map current
              if (currentSpace) delete ASSIGNED_SPACES[currentSpace];
              ASSIGNED_SPACES[newSpace] = badge.closest('.submission-card')
                ?.querySelector('.submission-name')?.textContent || 'Unknown';

              if (json.emailError) {
                alert(`⚠️ Space updated, but confirmation email failed to send:\n\n${json.emailError}`);
              }
            } else {
              const json = await res.json().catch(() => ({}));
              alert(`Error: ${json.error || 'Update failed. Please try again.'}`);
              badge.textContent = originalText;
            }
          } catch {
            alert('Network error. Please check your connection and try again.');
            badge.textContent = originalText;
          }
        }

        function cancelEdit() {
          if (!saved) badge.textContent = originalText;
        }

        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter')  { e.preventDefault(); saveSpace(); }
          if (e.key === 'Escape') { saved = true; cancelEdit(); }
        });

        // Blur cancels (not saves) so accidental clicks away don't trigger an email
        input.addEventListener('blur', () => {
          setTimeout(() => { if (badge.querySelector('input')) cancelEdit(); }, 150);
        });
      });
    }

    document.querySelectorAll('.space-badge-editable, .space-inline-editable').forEach(attachSpaceEditor);

    // ── Admin notes auto-save (debounced on input + blur) ─────────────────
    document.querySelectorAll('.admin-notes-textarea').forEach(el => {
      const textarea = el as HTMLTextAreaElement;
      let original = textarea.value.trim();
      let debounceTimer: ReturnType<typeof setTimeout> | null = null;

      async function saveNote() {
        const current = textarea.value.trim();
        if (current === original) return;
        const id = textarea.dataset.id!;
        const statusEl = document.getElementById(`notes-status-${id}`);
        if (statusEl) { statusEl.textContent = 'Saving…'; statusEl.className = 'admin-notes-status saving'; }
        try {
          const res = await fetch('/api/admin/vendor-action', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'note', id, notes: current }),
          });
          if (res.ok) {
            original = current;
            if (statusEl) { statusEl.textContent = 'Saved ✓'; statusEl.className = 'admin-notes-status saved'; }
            setTimeout(() => { if (statusEl) statusEl.textContent = ''; }, 2500);
          } else {
            const json = await res.json().catch(() => ({}));
            if (statusEl) { statusEl.textContent = `Error: ${json.error || res.status}`; statusEl.className = 'admin-notes-status error'; }
          }
        } catch (err) {
          if (statusEl) { statusEl.textContent = 'Network error — note not saved'; statusEl.className = 'admin-notes-status error'; }
        }
      }

      textarea.addEventListener('input', () => {
        if (debounceTimer) clearTimeout(debounceTimer);
        debounceTimer = setTimeout(saveNote, 1200);
      });

      textarea.addEventListener('blur', () => {
        if (debounceTimer) clearTimeout(debounceTimer);
        saveNote();
      });
    });

    let pendingPaidId: string | null = null;
    let pendingTotal: number = 0;
    let pendingDeleteId: string | null = null;
    let pendingEditId: string | null = null;
    let pendingPhotoUrl: string | null = null;
    let isUploadingPhoto = false;

    // ── Fee map (must match server) ────────────────────────────────────────
    const FEE_MAP: Record<string, number> = {
      'Individual Artist': 25,
      'Food Vendor': 100,
      'Retail / Franchise / non-profit': 50,
      'Political': 75,
    };

    function calcEditFee(type: string, elec: string, water: string): number {
      return (FEE_MAP[type] ?? 0)
        + (elec === 'yes' ? 10 : 0)
        + (water === 'yes' ? 10 : 0);
    }

    function updateEditFeeDisplay() {
      const type  = (document.getElementById('edit-vendor-type') as HTMLSelectElement).value;
      const elec  = (document.getElementById('edit-electricity') as HTMLSelectElement).value;
      const water = (document.getElementById('edit-water') as HTMLSelectElement).value;
      const total = calcEditFee(type, elec, water);
      const parts = [
        `${type}: ${FEE_MAP[type] ?? 0}`,
        elec  === 'yes' ? '+$10 electric' : '',
        water === 'yes' ? '+$10 water'    : '',
      ].filter(Boolean).join(' · ');
      (document.getElementById('edit-fee-amount') as HTMLElement).textContent = `${total}`;
      (document.getElementById('edit-fee-breakdown') as HTMLElement).textContent = parts;
    }

    // ── Edit modal ──────────────────────────────────────────────────────
    function openEditModal(id: string) {
      pendingEditId = id;
      const v = VENDOR_DATA_MAP[id] || {};
      (document.getElementById('edit-modal-company') as HTMLElement).textContent = v.company_name || id;
      (document.getElementById('edit-contact-name')   as HTMLInputElement).value  = v.contact_name || '';
      (document.getElementById('edit-company-name')   as HTMLInputElement).value  = v.company_name || '';
      (document.getElementById('edit-address')         as HTMLInputElement).value  = v.address || '';
      (document.getElementById('edit-city-zip')        as HTMLInputElement).value  = v.city_zip || '';
      (document.getElementById('edit-phone')           as HTMLInputElement).value  = v.phone || '';
      (document.getElementById('edit-email')           as HTMLInputElement).value  = v.email || '';
      (document.getElementById('edit-website')         as HTMLInputElement).value  = v.website || '';
      (document.getElementById('edit-vendor-type')     as HTMLSelectElement).value = v.vendor_type || '';
      (document.getElementById('edit-selling')         as HTMLTextAreaElement).value = v.selling || '';
      (document.getElementById('edit-description')     as HTMLTextAreaElement).value = v.description || '';
      (document.getElementById('edit-location-request') as HTMLTextAreaElement).value = v.location_request || '';
      (document.getElementById('edit-comments')        as HTMLTextAreaElement).value = v.additional_comments || '';
      (document.getElementById('edit-electricity')     as HTMLSelectElement).value = v.needs_electricity || 'no';
      (document.getElementById('edit-water')           as HTMLSelectElement).value = v.needs_water || 'no';
      // Photo preview
      pendingPhotoUrl = v.profile_image_url || null;
      const preview     = document.getElementById('edit-photo-preview') as HTMLImageElement;
      const previewWrap = document.getElementById('edit-photo-preview-wrap') as HTMLElement;
      const fileInput   = document.getElementById('edit-photo-file') as HTMLInputElement;
      const statusEl    = document.getElementById('edit-photo-status') as HTMLElement;
      fileInput.value = '';
      if (statusEl) statusEl.textContent = '';
      if (pendingPhotoUrl) {
        preview.src = pendingPhotoUrl;
        previewWrap.style.display = 'block';
      } else {
        previewWrap.style.display = 'none';
      }
      updateEditFeeDisplay();
      (document.getElementById('edit-modal') as HTMLElement).style.display = 'flex';
    }

    function closeEditModal() {
      (document.getElementById('edit-modal') as HTMLElement).style.display = 'none';
      pendingEditId    = null;
      pendingPhotoUrl  = null;
      isUploadingPhoto = false;
      const btn = document.getElementById('edit-modal-confirm') as HTMLButtonElement;
      btn.disabled    = false;
      btn.textContent = 'Save Changes';
      const statusEl = document.getElementById('edit-photo-status') as HTMLElement;
      if (statusEl) statusEl.textContent = '';
    }

    document.getElementById('edit-vendor-type')?.addEventListener('change', updateEditFeeDisplay);
    document.getElementById('edit-electricity')?.addEventListener('change', updateEditFeeDisplay);
    document.getElementById('edit-water')?.addEventListener('change', updateEditFeeDisplay);
    document.getElementById('edit-modal-close')?.addEventListener('click', closeEditModal);
    document.getElementById('edit-modal-cancel')?.addEventListener('click', closeEditModal);
    document.getElementById('edit-modal')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'edit-modal') closeEditModal();
    });

    document.getElementById('edit-modal-confirm')?.addEventListener('click', async () => {
      if (!pendingEditId || isUploadingPhoto) return;
      const btn = document.getElementById('edit-modal-confirm') as HTMLButtonElement;
      btn.disabled    = true;
      btn.textContent = 'Saving…';
      await doVendorAction({
        action:             'edit',
        id:                 pendingEditId,
        contactName:        (document.getElementById('edit-contact-name')      as HTMLInputElement).value.trim(),
        companyName:        (document.getElementById('edit-company-name')      as HTMLInputElement).value.trim(),
        address:            (document.getElementById('edit-address')            as HTMLInputElement).value.trim(),
        cityZip:            (document.getElementById('edit-city-zip')           as HTMLInputElement).value.trim(),
        phone:              (document.getElementById('edit-phone')              as HTMLInputElement).value.trim(),
        email:              (document.getElementById('edit-email')              as HTMLInputElement).value.trim(),
        website:            (document.getElementById('edit-website')            as HTMLInputElement).value.trim(),
        vendorType:         (document.getElementById('edit-vendor-type')        as HTMLSelectElement).value,
        selling:            (document.getElementById('edit-selling')            as HTMLTextAreaElement).value.trim(),
        description:        (document.getElementById('edit-description')        as HTMLTextAreaElement).value.trim(),
        locationRequest:    (document.getElementById('edit-location-request')   as HTMLTextAreaElement).value.trim(),
        additionalComments: (document.getElementById('edit-comments')           as HTMLTextAreaElement).value.trim(),
        needsElectricity:   (document.getElementById('edit-electricity')        as HTMLSelectElement).value,
        needsWater:         (document.getElementById('edit-water')              as HTMLSelectElement).value,
        profileImageUrl:    pendingPhotoUrl,
      });
    });

    // ── Photo upload ────────────────────────────────────────────────────
    document.getElementById('edit-photo-file')?.addEventListener('change', async (e) => {
      const input = e.target as HTMLInputElement;
      const file  = input.files?.[0];
      if (!file || !pendingEditId) return;

      const statusEl    = document.getElementById('edit-photo-status') as HTMLElement;
      const preview     = document.getElementById('edit-photo-preview') as HTMLImageElement;
      const previewWrap = document.getElementById('edit-photo-preview-wrap') as HTMLElement;
      const confirmBtn  = document.getElementById('edit-modal-confirm') as HTMLButtonElement;

      // Show local blob preview immediately so user gets live feedback
      const localUrl = URL.createObjectURL(file);
      preview.src = localUrl;
      previewWrap.style.display = 'block';

      statusEl.textContent = 'Uploading…';
      statusEl.className   = 'edit-photo-status uploading';
      isUploadingPhoto     = true;
      confirmBtn.disabled  = true;

      const formData = new FormData();
      formData.append('vendorId', pendingEditId);
      formData.append('file', file);
      if (pendingPhotoUrl) formData.append('oldUrl', pendingPhotoUrl);

      try {
        const res = await fetch('/api/admin/upload-vendor-photo', { method: 'POST', body: formData });
        if (res.ok) {
          const json = await res.json();
          pendingPhotoUrl = json.url;
          preview.src = pendingPhotoUrl!;
          URL.revokeObjectURL(localUrl);
          statusEl.textContent = '✓ Photo uploaded';
          statusEl.className   = 'edit-photo-status success';
          setTimeout(() => { if (statusEl.className.includes('success')) statusEl.textContent = ''; }, 3000);
        } else {
          const json = await res.json().catch(() => ({}));
          statusEl.textContent = `Upload failed: ${json.error || res.status}`;
          statusEl.className   = 'edit-photo-status error';
          if (pendingPhotoUrl) { preview.src = pendingPhotoUrl; }
          else { previewWrap.style.display = 'none'; }
        }
      } catch {
        statusEl.textContent = 'Network error — upload failed';
        statusEl.className   = 'edit-photo-status error';
        if (pendingPhotoUrl) { preview.src = pendingPhotoUrl; }
        else { previewWrap.style.display = 'none'; }
      } finally {
        isUploadingPhoto    = false;
        confirmBtn.disabled = false;
        input.value = '';
      }
    });

    // ── Delete modal ────────────────────────────────────────────────────
    function openDeleteModal(id: string, company: string) {
      pendingDeleteId = id;
      const sub = document.getElementById('delete-modal-sub');
      if (sub) sub.textContent = `Delete "${company}"? This record will be permanently removed.`;
      (document.getElementById('delete-modal') as HTMLElement).style.display = 'flex';
    }
    function closeDeleteModal() {
      (document.getElementById('delete-modal') as HTMLElement).style.display = 'none';
      pendingDeleteId = null;
      const confirmBtn = document.getElementById('delete-modal-confirm') as HTMLButtonElement;
      confirmBtn.disabled    = false;
      confirmBtn.textContent = 'Yes, Delete';
    }
    document.getElementById('delete-modal-close')?.addEventListener('click', closeDeleteModal);
    document.getElementById('delete-modal-cancel')?.addEventListener('click', closeDeleteModal);
    document.getElementById('delete-modal')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'delete-modal') closeDeleteModal();
    });
    document.getElementById('delete-modal-confirm')?.addEventListener('click', async () => {
      if (!pendingDeleteId) return;
      const confirmBtn = document.getElementById('delete-modal-confirm') as HTMLButtonElement;
      confirmBtn.disabled    = true;
      confirmBtn.textContent = 'Deleting…';
      await doVendorAction({ action: 'delete', id: pendingDeleteId });
    });

    // ── Action buttons ────────────────────────────────────────────────────
    document.querySelectorAll('[data-action]').forEach(btn => {
      btn.addEventListener('click', () => {
        const el      = btn as HTMLButtonElement;
        const action  = el.dataset.action!;
        const id      = el.dataset.id!;
        const company = el.dataset.company || 'this vendor';
        const total   = Number(el.dataset.total || 0);

        if (action === 'delete') { openDeleteModal(id, company); return; }

        if (action === 'open-edit-modal') {
          openEditModal(id);
          return;
        }

        if (action === 'open-paid-modal') {
          pendingPaidId = id;
          pendingTotal  = total;
          const nameEl = document.getElementById('modal-company-name');
          if (nameEl) nameEl.textContent = `${company} · $${total} due`;
          (document.getElementById('modal-space') as HTMLInputElement).value  = '';
          (document.getElementById('modal-method') as HTMLSelectElement).value = '';
          (document.getElementById('modal-note') as HTMLInputElement).value   = '';
          (document.getElementById('paid-modal') as HTMLElement).style.display = 'flex';
          return;
        }

        if (action === 'resend-confirmation') {
          if (!confirm(`Resend the space confirmation email to "${company}"?`)) return;
          const originalLabel = el.textContent;
          el.disabled    = true;
          el.textContent = 'Sending…';
          fetch('/api/admin/vendor-action', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ action, id }),
          })
            .then(async res => {
              const json = await res.json().catch(() => ({}));
              if (res.ok && !json.error) {
                el.textContent = '✓ Sent';
                setTimeout(() => { el.textContent = originalLabel; el.disabled = false; }, 2500);
              } else {
                alert(`⚠️ Email failed to send:\n\n${json.error || 'Unknown error'}`);
                el.textContent = originalLabel;
                el.disabled    = false;
              }
            })
            .catch(() => {
              alert('Network error. Please check your connection and try again.');
              el.textContent = originalLabel;
              el.disabled    = false;
            });
          return;
        }

        const label = action === 'approve' ? 'approved' : action === 'unapprove' ? 'moved back to pending' : 'rejected';
        if (!confirm(`Set "${company}" to "${label}"?`)) return;

        el.disabled    = true;
        el.textContent = 'Updating…';
        doVendorAction({ action, id });
      });
    });

    // ── Modal controls ────────────────────────────────────────────────────
    function closeModal() {
      (document.getElementById('paid-modal') as HTMLElement).style.display = 'none';
      pendingPaidId = null;
    }

    document.getElementById('modal-close')?.addEventListener('click', closeModal);
    document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
    document.getElementById('paid-modal')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'paid-modal') closeModal();
    });

    document.getElementById('modal-confirm')?.addEventListener('click', async () => {
      if (!pendingPaidId) return;
      const spaceInput  = document.getElementById('modal-space') as HTMLInputElement;
      const methodInput = document.getElementById('modal-method') as HTMLSelectElement;
      const noteInput   = document.getElementById('modal-note') as HTMLInputElement;

      const spaceNumber   = spaceInput.value.trim();
      const paymentMethod = methodInput.value;
      const paymentNote   = noteInput.value.trim();

      if (!spaceNumber) {
        spaceInput.style.borderColor = 'var(--red)';
        spaceInput.focus();
        return;
      }
      spaceInput.style.borderColor = '';

      const confirmBtn = document.getElementById('modal-confirm') as HTMLButtonElement;
      confirmBtn.disabled    = true;
      confirmBtn.textContent = 'Saving…';

      await doVendorAction({
        action:       'mark-paid',
        id:           pendingPaidId,
        spaceNumber,
        paymentMethod,
        paymentNote,
      });
    });

    // ── Shared fetch ──────────────────────────────────────────────────────
    async function doVendorAction(payload: Record<string, any>) {
      try {
        const res = await fetch('/api/admin/vendor-action', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
        });

        if (res.ok) {
          const json = await res.json().catch(() => ({}));
          if (json.emailError) {
            alert(`⚠️ Status updated, but email failed to send:\n\n${json.emailError}\n\nCheck the server logs for more detail.`);
          }
          window.location.reload();
        } else {
          const json = await res.json().catch(() => ({}));
          alert(`Error: ${json.error || 'Update failed. Please try again.'}`);
        }
      } catch {
        alert('Network error. Please check your connection and try again.');
      }
    }
  </script>

