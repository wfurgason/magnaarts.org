---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const firebaseConfig = {
  apiKey:        import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain:    import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:     import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
  storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
};
---

<BaseLayout
  title="Teach an Art Class — Magna Arts Council"
  description="Share your artistic expertise with the Magna community. Apply to lead a Group Art Night session at the Magna Library."
>
  <Fragment slot="head">
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
  </Fragment>
  <Header />

  <main>

    <!-- ── HERO ──────────────────────────────────────────────────────── -->
    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">Call for Arts Presenters</div>
        <h1>Teach an Art Class</h1>
        <p class="hero-sub">
          Do you have expertise in an area of the arts? We're looking for local artists
          and educators to lead interactive sessions for the Magna community at the Magna Library.
          Material costs are covered and compensation for your time may be negotiated.
        </p>
      </div>
    </section>

    <!-- ── FORM ──────────────────────────────────────────────────────── -->
    <section class="section">
      <div class="container form-container">

        <!-- Left: context -->
        <aside class="form-sidebar reveal">
          <div class="info-card">
            <h3>About Group Art Night</h3>
            <p>Group Art Night is a monthly community session held at the Magna Library where a local artist guides participants through a hands-on project in a relaxed social setting.</p>
            <p>Sessions run 1–2 hours and typically draw around 20 participants of all skill levels. We're always looking for enthusiastic presenters across all arts disciplines.</p>
            <dl class="quick-facts">
              <dt>Location</dt>
              <dd>Magna Library, 2675 S 8950 W</dd>
              <dt>Duration</dt>
              <dd>1–2 hours per session</dd>
              <dt>Age Group</dt>
              <dd>16 and older</dd>
              <dt>Materials</dt>
              <dd>Covered by the Arts Council</dd>
              <dt>Compensation</dt>
              <dd>Negotiable</dd>
            </dl>
          </div>
        </aside>

        <!-- Right: form -->
        <div class="form-main reveal">

          <!-- Success state (hidden by default) -->
          <div id="success-state" class="success-state" hidden>
            <div class="success-icon">✓</div>
            <h2>Application Received!</h2>
            <p>Thank you for your interest in teaching a Group Art Night session. The Arts Council board will review your application and reach out to you soon.</p>
            <a href="/programs#art-night" class="btn btn-gold">Back to Group Art Night →</a>
          </div>

          <!-- Error banner -->
          <div id="error-banner" class="error-banner" hidden>
            <strong>Something went wrong.</strong>
            <span id="error-message">Please try again or contact us directly.</span>
          </div>

          <!-- The form -->
          <form id="teach-form" class="teach-form" novalidate>

            <h2 class="form-heading">Tell Us About Yourself</h2>

            <div class="form-row">
              <div class="form-field">
                <label for="fullName">Full Name <span class="req">*</span></label>
                <input type="text" id="fullName" name="fullName" required autocomplete="name" placeholder="Your full name" />
                <span class="field-error" id="err-fullName"></span>
              </div>
            </div>

            <div class="form-row two-col">
              <div class="form-field">
                <label for="email">Email Address <span class="req">*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@example.com" />
                <span class="field-error" id="err-email"></span>
              </div>
              <div class="form-field">
                <label for="phone">Phone Number <span class="req">*</span></label>
                <input type="tel" id="phone" name="phone" required autocomplete="tel" placeholder="(801) 555-0100" />
                <span class="field-error" id="err-phone"></span>
              </div>
            </div>

            <h2 class="form-heading">About Your Session</h2>

            <div class="form-field">
              <label>
                Arts Area &amp; Experience <span class="req">*</span>
                <span class="field-hint">Briefly describe your background and credentials.</span>
              </label>
              <div id="artsArea-editor" class="quill-wrap"></div>
              <span class="field-error" id="err-artsArea"></span>
            </div>

            <div class="form-field">
              <label>
                Project Description <span class="req">*</span>
                <span class="field-hint">Describe the specific project or activity you'd like to lead. What will participants make or learn?</span>
              </label>
              <div id="projectDescription-editor" class="quill-wrap"></div>
              <span class="field-error" id="err-projectDescription"></span>
            </div>

            <div class="form-field">
              <label>Presenter Photo
                <span class="field-hint">A photo of yourself — used on the event page to introduce you to attendees (JPG or PNG, max 10 MB)</span>
              </label>
              <div class="upload-zone" id="presenter-photo-zone">
                <input type="file" id="presenterPhoto" name="presenterPhoto"
                  accept="image/jpeg,image/png,image/webp" class="upload-input" />
                <label for="presenterPhoto" class="upload-label">
                  <span class="upload-icon">🧑‍🎨</span>
                  <span class="upload-text"><strong>Choose a photo</strong> or drag and drop</span>
                  <span class="upload-hint">JPG, PNG or WebP · max 10 MB</span>
                </label>
                <div class="upload-preview" id="presenter-photo-preview" hidden></div>
              </div>
            </div>

            <div class="form-field">
              <label>Project Image
                <span class="field-hint">A photo of the finished project — used to promote your session (JPG or PNG, max 10 MB)</span>
              </label>
              <div class="upload-zone" id="project-image-zone">
                <input type="file" id="projectImage" name="projectImage"
                  accept="image/jpeg,image/png,image/webp" class="upload-input" />
                <label for="projectImage" class="upload-label">
                  <span class="upload-icon">🖼️</span>
                  <span class="upload-text"><strong>Choose a photo</strong> or drag and drop</span>
                  <span class="upload-hint">JPG, PNG or WebP · max 10 MB</span>
                </label>
                <div class="upload-preview" id="project-image-preview" hidden></div>
              </div>
            </div>

            <div class="form-field">
              <label>
                Materials &amp; Resources Required
                <span class="field-hint">Please provide an itemized list of materials needed with quantities and where to purchase. If available online include url to each item.</span>
              </label>
              <div id="materials-editor" class="quill-wrap"></div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-gold" id="submit-btn">
                <span id="btn-text">Submit Application →</span>
                <span id="btn-loading" hidden>Submitting…</span>
              </button>
            </div>

          </form>
        </div>

      </div>
    </section>

  </main>

  <Footer />

  <script type="module" define:vars={{ firebaseConfig }}>
    // Load Quill before anything else
    await new Promise((resolve, reject) => {
      if (window.Quill) return resolve();
      const s = document.createElement('script');
      s.src = 'https://cdn.quilljs.com/1.3.7/quill.min.js';
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
    import { initializeApp }           from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
    import { getFirestore, collection, addDoc, serverTimestamp }
                                       from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-firestore.js';
    import { getStorage, ref, uploadBytes, getDownloadURL }
                                       from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-storage.js';

    const app     = initializeApp(firebaseConfig);
    const db      = getFirestore(app);
    const storage = getStorage(app);

    // ── Init Quill editors ─────────────────────────────────────────────
    const BASIC_TOOLBAR = [['bold','italic','underline'],['link'],['clean']];
    const LIST_TOOLBAR  = [['bold','italic','underline'],[{ list: 'bullet' },{ list: 'ordered' }],['link'],['clean']];

    const quillArtsArea    = new Quill('#artsArea-editor',           { theme: 'snow', modules: { toolbar: BASIC_TOOLBAR } });
    const quillProjectDesc = new Quill('#projectDescription-editor', { theme: 'snow', modules: { toolbar: BASIC_TOOLBAR } });
    const quillMaterials   = new Quill('#materials-editor',          { theme: 'snow', modules: { toolbar: LIST_TOOLBAR  } });

    // Focus ring via CSS class
    [
      [quillArtsArea,    'artsArea-editor'],
      [quillProjectDesc, 'projectDescription-editor'],
      [quillMaterials,   'materials-editor'],
    ].forEach(([quill, wrId]) => {
      const wrap = document.getElementById(wrId);
      quill.on('selection-change', range => wrap.classList.toggle('quill-focused', !!range));
    });

    // ── upload zone drag-and-drop (presenter photo) ──────────────────
    const presenterZone = document.getElementById('presenter-photo-zone');
    presenterZone.addEventListener('dragover', e => { e.preventDefault(); presenterZone.classList.add('drag-over'); });
    presenterZone.addEventListener('dragleave', () => presenterZone.classList.remove('drag-over'));
    presenterZone.addEventListener('drop', e => {
      e.preventDefault(); presenterZone.classList.remove('drag-over');
      const input = presenterZone.querySelector('.upload-input');
      if (input && e.dataTransfer?.files.length) {
        const dt = new DataTransfer(); dt.items.add(e.dataTransfer.files[0]);
        input.files = dt.files; input.dispatchEvent(new Event('change'));
      }
    });
    const presenterPhotoInput   = document.getElementById('presenterPhoto');
    const presenterPhotoPreview = document.getElementById('presenter-photo-preview');
    presenterPhotoInput.addEventListener('change', () => {
      const file = presenterPhotoInput.files?.[0];
      if (!file) { presenterPhotoPreview.hidden = true; return; }
      presenterPhotoPreview.hidden = false;
      const reader = new FileReader();
      reader.onload = ev => {
        presenterPhotoPreview.innerHTML = `<img src="${ev.target.result}" alt="Preview" /><span>${file.name} (${(file.size/1024/1024).toFixed(1)} MB)</span>`;
      };
      reader.readAsDataURL(file);
    });

    // ── upload zone drag-and-drop (project image) ──────────────────────
    const zone = document.getElementById('project-image-zone');
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
      e.preventDefault(); zone.classList.remove('drag-over');
      const input = zone.querySelector('.upload-input');
      if (input && e.dataTransfer?.files.length) {
        const dt = new DataTransfer(); dt.items.add(e.dataTransfer.files[0]);
        input.files = dt.files; input.dispatchEvent(new Event('change'));
      }
    });

    // ── image preview ─────────────────────────────────────────────────
    const imgInput   = document.getElementById('projectImage');
    const imgPreview = document.getElementById('project-image-preview');
    imgInput.addEventListener('change', () => {
      const file = imgInput.files?.[0];
      if (!file) { imgPreview.hidden = true; return; }
      imgPreview.hidden = false;
      const reader = new FileReader();
      reader.onload = ev => {
        imgPreview.innerHTML = `<img src="${ev.target.result}" alt="Preview" /><span>${file.name} (${(file.size/1024/1024).toFixed(1)} MB)</span>`;
      };
      reader.readAsDataURL(file);
    });

    const form         = document.getElementById('teach-form');
    const submitBtn    = document.getElementById('submit-btn');
    const btnText      = document.getElementById('btn-text');
    const btnLoading   = document.getElementById('btn-loading');
    const successState = document.getElementById('success-state');
    const errorBanner  = document.getElementById('error-banner');
    const errorMsg     = document.getElementById('error-message');

    // ── Validation helpers ────────────────────────────────────────────
    function setError(id, msg) {
      const errEl     = document.getElementById('err-' + id);
      const quillWrap = document.getElementById(id + '-editor');
      const inputEl   = document.getElementById(id);
      if (errEl)     errEl.textContent = msg;
      if (quillWrap) quillWrap.classList.toggle('quill-error', !!msg);
      if (inputEl)   inputEl.classList.toggle('input-error', !!msg);
    }

    function validate() {
      let ok = true;
      const fullName     = document.getElementById('fullName').value.trim();
      const email        = document.getElementById('email').value.trim();
      const phone        = document.getElementById('phone').value.trim();
      const artsAreaText = quillArtsArea.getText().trim();
      const projDescText = quillProjectDesc.getText().trim();

      setError('fullName', fullName ? '' : 'Full name is required.');
      if (!fullName) ok = false;

      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      setError('email', emailOk ? '' : 'Please enter a valid email address.');
      if (!emailOk) ok = false;

      setError('phone', phone ? '' : 'Phone number is required.');
      if (!phone) ok = false;

      setError('artsArea', artsAreaText ? '' : 'Please describe your arts area and experience.');
      if (!artsAreaText) ok = false;

      setError('projectDescription', projDescText ? '' : 'Please describe the project or activity you plan to lead.');
      if (!projDescText) ok = false;

      return ok;
    }

    // Clear errors on Quill text-change
    quillArtsArea.on('text-change',    () => setError('artsArea', ''));
    quillProjectDesc.on('text-change', () => setError('projectDescription', ''));

    // Clear errors on plain inputs
    ['fullName','email','phone'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', () => setError(id, ''));
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.hidden = true;

      if (!validate()) return;

      submitBtn.disabled = true;
      btnText.hidden     = true;
      btnLoading.hidden  = false;

      try {
        // Upload presenter photo if provided
        let presenterPhotoUrl = null;
        const presenterFile = document.getElementById('presenterPhoto').files?.[0];
        if (presenterFile) {
          btnLoading.textContent = 'Uploading presenter photo…';
          const ext  = presenterFile.name.split('.').pop();
          const slug = document.getElementById('fullName').value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');
          const storageRef = ref(storage, `art-class-images/${slug}-${Date.now()}/presenter.${ext}`);
          await uploadBytes(storageRef, presenterFile);
          presenterPhotoUrl = await getDownloadURL(storageRef);
        }

        // Upload project image if provided
        let projectImageUrl = null;
        const imgFile = document.getElementById('projectImage').files?.[0];
        if (imgFile) {
          btnLoading.textContent = 'Uploading project image…';
          const ext  = imgFile.name.split('.').pop();
          const slug = document.getElementById('fullName').value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');
          const storageRef = ref(storage, `art-class-images/${slug}-${Date.now()}/project.${ext}`);
          await uploadBytes(storageRef, imgFile);
          projectImageUrl = await getDownloadURL(storageRef);
          btnLoading.textContent = 'Submitting…';
        }

        // Read Quill HTML; treat empty-editor placeholder as empty string
        const materialsHtml = quillMaterials.getText().trim()
          ? quillMaterials.root.innerHTML
          : '';

        await addDoc(collection(db, 'art_class_submissions'), {
          fullName:           document.getElementById('fullName').value.trim(),
          email:              document.getElementById('email').value.trim(),
          phone:              document.getElementById('phone').value.trim(),
          artsArea:           quillArtsArea.root.innerHTML,
          projectDescription: quillProjectDesc.root.innerHTML,
          presenterPhotoUrl,
          projectImageUrl,
          materials:          materialsHtml,
          status:             'pending',
          submittedAt:        serverTimestamp(),
        });

        form.hidden         = true;
        successState.hidden = false;
        window.scrollTo({ top: 0, behavior: 'smooth' });

      } catch (err) {
        console.error('Submission error:', err);
        errorMsg.textContent = err.message || 'Please try again or contact us directly.';
        errorBanner.hidden   = false;
        submitBtn.disabled   = false;
        btnText.hidden       = false;
        btnLoading.hidden    = true;
      }
    });
  </script>

</BaseLayout>

<style>
  /* ── QUILL ── */
  .ql-toolbar { border-radius: 8px 8px 0 0 !important; border-color: var(--border, #e5e5e5) !important; background: var(--cream, #f7f5f0); }
  .ql-container { border-radius: 0 0 8px 8px !important; border-color: var(--border, #e5e5e5) !important; font-family: inherit; font-size: 15px; min-height: 120px; }
  .ql-editor { min-height: 120px; }
  .quill-focused .ql-toolbar { border-color: var(--green, #2d7a3a) !important; box-shadow: 0 0 0 3px rgba(45,122,58,0.12); }
  .quill-focused .ql-container { border-color: var(--green, #2d7a3a) !important; box-shadow: 0 0 0 3px rgba(45,122,58,0.12); }
  .quill-error .ql-toolbar { border-color: var(--red, #b52626) !important; }
  .quill-error .ql-container { border-color: var(--red, #b52626) !important; }

  /* ── HERO ── */
  .page-hero {
    background: var(--green, #2d7a3a);
    color: var(--white, #fff);
    padding: 72px 0 64px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.35);
    color: rgba(255,255,255,0.9);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 17px;
    font-weight: 300;
    color: rgba(255,255,255,0.85);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── LAYOUT ── */
  .form-container {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .info-card {
    background: var(--white, #fff);
    border: 1.5px solid var(--border, #e5e5e5);
    border-top: 3px solid var(--green, #2d7a3a);
    border-radius: 10px;
    padding: 24px;
  }

  .info-card h3 {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--navy, #1a2456);
    margin: 0 0 12px;
  }

  .info-card p {
    font-size: 14px;
    color: var(--muted, #5a5a7a);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .quick-facts {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 14px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border, #e5e5e5);
  }

  .quick-facts dt {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted, #5a5a7a);
    align-self: start;
    padding-top: 1px;
    white-space: nowrap;
  }

  .quick-facts dd {
    font-size: 13px;
    color: var(--navy, #1a2456);
    line-height: 1.5;
  }

  /* ── FORM ── */
  .form-heading {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--navy, #1a2456);
    margin: 24px 0 16px;
    padding-top: 20px;
    border-top: 1px solid var(--border, #e5e5e5);
  }

  .form-heading:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .teach-form { display: flex; flex-direction: column; gap: 16px; }

  .form-row { display: flex; flex-direction: column; gap: 16px; }
  .form-row.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-field label {
    font-size: 12px; font-weight: 700;
    color: var(--navy, #1a2456); text-transform: uppercase; letter-spacing: 0.05em;
  }
  .field-hint {
    font-size: 11px; font-weight: 400;
    color: var(--muted, #5a5a7a); text-transform: none; letter-spacing: 0; margin-left: 6px;
    display: block; margin-top: 2px;
  }
  .req { color: var(--red, #b52626); }

  .form-field input,
  .form-field textarea {
    font-family: inherit; font-size: 15px; color: var(--text, #1a1a1a);
    border: 1.5px solid var(--border, #e5e5e5); border-radius: 8px;
    padding: 10px 14px; outline: none; transition: border-color 0.2s;
    width: 100%; box-sizing: border-box;
  }
  .form-field input:focus,
  .form-field textarea:focus { border-color: var(--green, #2d7a3a); box-shadow: 0 0 0 3px rgba(45,122,58,0.12); }
  .form-field textarea { resize: vertical; min-height: 80px; }
  .form-field input.input-error,
  .form-field textarea.input-error { border-color: var(--red, #b52626); }

  .field-error { font-size: 12px; color: var(--red, #b52626); min-height: 16px; }

  .form-actions { padding-top: 8px; }

  /* ── SUCCESS / ERROR STATES ── */
  .success-state {
    text-align: center;
    padding: 48px 32px;
    background: #f0fdf4;
    border: 1.5px solid #bbf7d0;
    border-radius: 12px;
  }

  .success-icon {
    width: 56px; height: 56px;
    background: var(--green, #2d7a3a);
    color: #fff; font-size: 24px; font-weight: 700;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
  }

  .success-state h2 {
    font-family: var(--font-display);
    font-size: 26px; font-weight: 700;
    color: var(--navy, #1a2456);
    margin-bottom: 12px;
  }

  .success-state p {
    font-size: 15px; color: var(--muted, #5a5a7a);
    max-width: 440px; margin: 0 auto 24px;
    line-height: 1.65;
  }

  .error-banner {
    padding: 14px 18px;
    background: #fee2e2; border: 1.5px solid #fca5a5;
    border-radius: 8px; font-size: 14px; color: #991b1b;
    margin-bottom: 16px;
    display: flex; gap: 8px; align-items: flex-start;
  }

  /* Ensure the HTML `hidden` attribute wins over display:flex above */
  .error-banner[hidden] { display: none; }

  /* ── UPLOAD ZONE ── */
  .upload-zone {
    position: relative;
    border: 2px dashed var(--border, #e5e5e5);
    border-radius: 8px;
    background: var(--cream, #f7f5f0);
    transition: border-color 0.2s, background 0.2s;
    overflow: hidden;
  }
  .upload-zone.drag-over { border-color: var(--green, #2d7a3a); background: #f0fdf4; }
  .upload-input {
    position: absolute; inset: 0; opacity: 0; cursor: pointer;
    width: 100% !important; height: 100%; padding: 0 !important; border: none !important;
  }
  .upload-label {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 6px; padding: 28px 24px;
    cursor: pointer; text-align: center;
  }
  .upload-icon { font-size: 28px; }
  .upload-text { font-size: 15px; color: var(--navy, #1a2456); }
  .upload-text strong { color: var(--green, #2d7a3a); }
  .upload-hint { font-size: 12px; color: var(--muted, #5a5a7a); }
  .upload-preview {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px;
    background: var(--white, #fff);
