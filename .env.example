# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

# Public — safe to expose in browser (used in client-side Supabase calls)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Private — NEVER expose in browser. Server-side only (API routes, SSR pages).
# Used for admin operations: generating reports, board dashboard auth checks, etc.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Site ──────────────────────────────────────────────────────────────────────
# Used for absolute URL generation (e.g. in OG tags, email links)
# Dev: http://localhost:4321
# Prod: https://magnaarts.org
SITE_URL=http://localhost:4321
