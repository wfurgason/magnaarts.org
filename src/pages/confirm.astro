---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const status = Astro.url.searchParams.get('status');
const error  = Astro.url.searchParams.get('error');
---

<BaseLayout
  title="Email Confirmation — Magna Arts Council"
  description="Confirm your subscription to Magna Arts Council updates."
>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">Mailing List</div>
        {status === 'success' && <h1>You're confirmed! 🎉</h1>}
        {status === 'already'  && <h1>Already confirmed</h1>}
        {error                 && <h1>Something went wrong</h1>}
        {!status && !error     && <h1>Confirmation</h1>}
      </div>
    </section>

    <section class="section">
      <div class="container confirm-wrap">
        {status === 'success' && (
          <div class="confirm-card">
            <div class="confirm-icon">✅</div>
            <p>Thanks for confirming your email. You'll now receive updates on events, programs, and arts news from Magna Arts Council.</p>
            <a href="/" class="btn-primary">Back to Home</a>
          </div>
        )}

        {status === 'already' && (
          <div class="confirm-card">
            <div class="confirm-icon">👍</div>
            <p>Your email is already confirmed. You're all set to receive updates from us.</p>
            <a href="/" class="btn-primary">Back to Home</a>
          </div>
        )}

        {error === 'invalid' && (
          <div class="confirm-card error">
            <div class="confirm-icon">⚠️</div>
            <p>This confirmation link is invalid or has already been used. If you'd like to subscribe, please sign up again.</p>
            <a href="/" class="btn-primary">Back to Home</a>
          </div>
        )}

        {error === 'server' && (
          <div class="confirm-card error">
            <div class="confirm-icon">⚠️</div>
            <p>Something went wrong on our end. Please try clicking the link in your email again, or contact us if the problem persists.</p>
            <a href="/contact" class="btn-primary">Contact Us</a>
          </div>
        )}

        {!status && !error && (
          <div class="confirm-card">
            <div class="confirm-icon">✉️</div>
            <p>Use the confirmation link in your email to verify your subscription.</p>
            <a href="/" class="btn-primary">Back to Home</a>
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0 48px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.18);
    color: var(--gold-lt);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 999px;
    margin-bottom: 16px;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--white);
    margin: 0;
  }

  .confirm-wrap {
    max-width: 560px;
    margin: 0 auto;
    padding: 64px 16px;
    text-align: center;
  }

  .confirm-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .confirm-card.error {
    border-color: #fca5a5;
    background: #fff7f7;
  }

  .confirm-icon {
    font-size: 3rem;
    line-height: 1;
  }

  .confirm-card p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .btn-primary {
    display: inline-block;
    background: var(--navy);
    color: var(--white);
    padding: 12px 28px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s;
    margin-top: 4px;
  }
  .btn-primary:hover { background: var(--navy-dk); }
</style>
