---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Contact — Magna Arts Council"
  description="Get in touch with the Magna Arts Council. Questions, volunteer inquiries, press, or partnership opportunities."
>
  <Header />

  <main>

    <!-- ── PAGE HERO ── -->
    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">Contact Us</div>
        <h1>We'd Love to Hear From You</h1>
        <p class="hero-sub">
          Questions, ideas, volunteer inquiries, or partnership opportunities —
          reach out and we'll get back to you.
        </p>
      </div>
    </section>

    <!-- ── CONTACT BODY ── -->
    <section class="section contact-section">
      <div class="container contact-inner">

        <!-- LEFT: Form -->
        <div class="contact-form-wrap reveal">
          <h2>Send a Message</h2>
          <p class="form-sub">We read every message and respond within a few days.</p>

          <form class="contact-form" id="contact-form" novalidate>

            <div class="field-row">
              <div class="field">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" placeholder="Jane Smith" required />
              </div>
              <div class="field">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="jane@example.com" required />
              </div>
            </div>

            <div class="field">
              <label for="subject">Subject</label>
              <select id="subject" name="subject">
                <option value="">Select a topic…</option>
                <option value="volunteer">Volunteer inquiry</option>
                <option value="proposal">Program proposal</option>
                <option value="partnership">Partnership opportunity</option>
                <option value="press">Press / media</option>
                <option value="general">General question</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us what's on your mind…" required></textarea>
            </div>

            <button type="submit" class="btn btn-gold submit-btn" id="submit-btn">Send Message →</button>
            <p id="form-status" class="form-status" aria-live="polite"></p>
          </form>
        </div>

        <!-- RIGHT: Info -->
        <div class="contact-info reveal">

          <div class="info-card">
            <span class="info-icon">📞</span>
            <div>
              <div class="info-label">Phone</div>
              <a href="tel:+18012011095" class="info-value">(801) 201-1095</a>
            </div>
          </div>

          <div class="info-card">
            <span class="info-icon">✉️</span>
            <div>
              <div class="info-label">Email</div>
              <a href="mailto:wfurgason@gmail.com" class="info-value">wfurgason@gmail.com</a>
            </div>
          </div>

          <div class="info-card">
            <span class="info-icon">📬</span>
            <div>
              <div class="info-label">Mailing Address</div>
              <div class="info-value">P.O. Box 136<br />Magna, UT 84044</div>
            </div>
          </div>

          <div class="info-card">
            <span class="info-icon">📍</span>
            <div>
              <div class="info-label">Events Location</div>
              <div class="info-value">Pleasant Green Park<br />3250 S 8400 W, Magna, UT 84044</div>
            </div>
          </div>

          <div class="social-row">
            <a href="https://www.facebook.com/MagnaArtsCouncil" target="_blank" rel="noopener" class="social-btn">
              Facebook
            </a>
          </div>

          <div class="board-note">
            <strong>Board Meetings</strong>
            <p>Open to the public. Contact us for the current meeting schedule.</p>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<script>
  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const btn      = document.getElementById('submit-btn')  as HTMLButtonElement;
  const status   = document.getElementById('form-status') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled   = true;
    btn.textContent = 'Sending…';
    status.textContent = '';
    status.className   = 'form-status';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });

      const json = await res.json();

      if (res.ok) {
        status.innerHTML = '<strong>✓ Message sent!</strong> Thanks — we\'ll be in touch within a few days.';
        status.className = 'form-status status-ok';
        status.style.display = 'block';
        form.reset();
        status.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        status.innerHTML = '<strong>Error:</strong> ' + (json.error ?? 'Something went wrong. Please try again.');
        status.className = 'form-status status-err';
        status.style.display = 'block';
      }
    } catch {
      status.innerHTML = '<strong>Network error.</strong> Please try again.';
      status.className = 'form-status status-err';
      status.style.display = 'block';
    } finally {
      btn.disabled    = false;
      btn.textContent = 'Send Message →';
    }
  });
</script>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0 64px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.18);
    border: 1px solid rgba(232, 160, 32, 0.45);
    color: var(--gold-lt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 18px;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── CONTACT LAYOUT ── */
  .contact-section { background: var(--white); }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 64px;
    align-items: start;
  }

  /* ── FORM ── */
  .contact-form-wrap h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .form-sub {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 32px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field label {
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text);
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 11px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(37, 99, 176, 0.12);
  }

  .field textarea { resize: vertical; min-height: 120px; }

  .submit-btn {
    align-self: flex-start;
    font-size: 15px;
    padding: 14px 32px;
  }

  .form-status {
    display: none;
    font-size: 15px;
    font-weight: 500;
    margin: 0;
    padding: 14px 18px;
    border-radius: var(--radius-sm);
    line-height: 1.5;
  }
  .status-ok  { background: #dcfce7; color: #15803d; border: 1px solid #86efac; }
  .status-err { background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; }

  /* ── INFO SIDEBAR ── */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 8px;
  }

  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--cream);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .info-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }

  .info-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .info-value {
    font-size: 15px;
    font-weight: 500;
    color: var(--navy);
    line-height: 1.5;
  }

  a.info-value:hover { color: var(--blue); }

  .social-row { display: flex; gap: 12px; }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    font-weight: 700;
    color: var(--blue);
    background: #dbeafe;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
  }

  .social-btn:hover { background: #bfdbfe; }

  .board-note {
    padding: 20px;
    background: #fef3c7;
    border-radius: var(--radius);
    border: 1px solid #fde68a;
  }

  .board-note strong {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: var(--amber);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .board-note p {
    font-size: 14px;
    color: var(--text);
    line-height: 1.55;
    margin: 0;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .contact-inner { grid-template-columns: 1fr; gap: 48px; }
    .field-row     { grid-template-columns: 1fr; }
  }
</style>
