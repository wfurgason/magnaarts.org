---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Lens of Magna 2026: Main Street in Motion — Photography Contest"
  description="Enter the 3rd annual Lens of Magna Main Street Photography Contest. Free to enter. $2,875 in cash prizes. Deadline April 11, 2026."
>
  <Header />

  <main>

    <!-- ── HERO ── -->
    <section class="lmm-hero">
      <div class="lmm-hero-img-wrap">
        <img
          src="/images/lens-of-magna/lmm-postcard-flyer.jpg"
          alt="Lens of Magna 2026: Main Street in Motion Photography Contest"
          class="lmm-hero-img"
        />
    </section>

    <!-- ── WINNERS ── -->
    <section class="section lmm-winners">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-label">2026 Winners</div>
          <h2>Congratulations to Our Photographers!</h2>
          <p class="winners-tagline">
            With 104 submissions this year, our judges had quite the task — and the results are extraordinary.
            Thank you to everyone who entered and brought your vision to Magna Main Street.
          </p>
        </div>

        <div class="winners-categories">

          <!-- Youth -->
          <div class="winner-category reveal">
            <div class="category-header cat-youth">
              <span class="cat-icon">🎒</span>
              <h3>Youth</h3>
            </div>
            <ul class="winners-list">
              <li class="winner-row place-1">
                <span class="place-badge">🥇 1st</span>
                <div class="winner-info">
                  <span class="winner-title">Dramatic Lighting!</span>
                  <span class="winner-name">Sylvia Rickett</span>
                </div>
              </li>
              <li class="winner-row place-2">
                <span class="place-badge">🥈 2nd</span>
                <div class="winner-info">
                  <span class="winner-title">Bird Over Empress</span>
                  <span class="winner-name">Jasmine Walden</span>
                </div>
              </li>
              <li class="winner-row place-3">
                <span class="place-badge">🥉 3rd</span>
                <div class="winner-info">
                  <span class="winner-title">The World Beyond the Walls We Build</span>
                  <span class="winner-name">Alex Marshall</span>
                </div>
              </li>
              <li class="winner-row place-theme">
                <span class="place-badge theme-pill">Theme</span>
                <div class="winner-info">
                  <span class="winner-title">Around the Corner</span>
                  <span class="winner-name">Sylvia Rickett</span>
                </div>
              </li>
              <li class="winner-row place-hm">
                <span class="place-badge hm-pill">HM</span>
                <div class="winner-info">
                  <span class="winner-title">Twinsies</span>
                  <span class="winner-name">Kimber Gates</span>
                </div>
              </li>
              <li class="winner-row place-hm">
                <span class="place-badge hm-pill">HM</span>
                <div class="winner-info">
                  <span class="winner-title">Leader of the Pack</span>
                  <span class="winner-name">Wesley Marshall</span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Amateur -->
          <div class="winner-category reveal">
            <div class="category-header cat-amateur">
              <span class="cat-icon">📷</span>
              <h3>Amateur</h3>
            </div>
            <ul class="winners-list">
              <li class="winner-row place-1">
                <span class="place-badge">🥇 1st</span>
                <div class="winner-info">
                  <span class="winner-title">Wishes on the Wind</span>
                  <span class="winner-name">Ashley Erekson</span>
                </div>
              </li>
              <li class="winner-row place-2">
                <span class="place-badge">🥈 2nd</span>
                <div class="winner-info">
                  <span class="winner-title">Mourning on Main</span>
                  <span class="winner-name">Tyler Kirk</span>
                </div>
              </li>
              <li class="winner-row place-3">
                <span class="place-badge">🥉 3rd</span>
                <div class="winner-info">
                  <span class="winner-title">The Road Ahead</span>
                  <span class="winner-name">Izabelle Wulf</span>
                </div>
              </li>
              <li class="winner-row place-theme">
                <span class="place-badge theme-pill">Theme</span>
                <div class="winner-info">
                  <span class="winner-title">Wishes on the Wind</span>
                  <span class="winner-name">Ashley Erekson</span>
                </div>
              </li>
              <li class="winner-row place-hm">
                <span class="place-badge hm-pill">HM</span>
                <div class="winner-info">
                  <span class="winner-title">Eyes in the Sky</span>
                  <span class="winner-name">Allison Powell</span>
                </div>
              </li>
              <li class="winner-row place-hm">
                <span class="place-badge hm-pill">HM</span>
                <div class="winner-info">
                  <span class="winner-title">Flag Amongst the Blossoms</span>
                  <span class="winner-name">Tammy Rickett</span>
                </div>
              </li>
              <li class="winner-row place-hm">
                <span class="place-badge hm-pill">HM</span>
                <div class="winner-info">
                  <span class="winner-title">Magna Alive with Color</span>
                  <span class="winner-name">Scott Taylor</span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Professional -->
          <div class="winner-category reveal">
            <div class="category-header cat-pro">
              <span class="cat-icon">🏆</span>
              <h3>Professional</h3>
            </div>
            <ul class="winners-list">
              <li class="winner-row place-1">
                <span class="place-badge">🥇 1st</span>
                <div class="winner-info">
                  <span class="winner-title">The Lone Ranger</span>
                  <span class="winner-name">Michael Romero</span>
                </div>
              </li>
              <li class="winner-row place-2">
                <span class="place-badge">🥈 2nd</span>
                <div class="winner-info">
                  <span class="winner-title">Cruising to the Weekend</span>
                  <span class="winner-name">James Gates</span>
                </div>
              </li>
              <li class="winner-row place-3">
                <span class="place-badge">🥉 3rd</span>
                <div class="winner-info">
                  <span class="winner-title">The Destination Beckons</span>
                  <span class="winner-name">James Gates</span>
                </div>
              </li>
              <li class="winner-row place-theme">
                <span class="place-badge theme-pill">Theme</span>
                <div class="winner-info">
                  <span class="winner-title">The Lone Ranger</span>
                  <span class="winner-name">Michael Romero</span>
                </div>
              </li>
            </ul>
          </div>

        </div><!-- /.winners-categories -->
      </div>
    </section>

    <!-- ── PEOPLE'S CHOICE ── -->
    <section class="section section-cream lmm-peoples-choice">
      <div class="container">
        <div class="pc-inner reveal">
          <div class="pc-text">
            <div class="section-label">People's Choice</div>
            <h2>Your Vote Decides!</h2>
            <p>
              Didn't see your favorite photo win a judge's award? You can still make it happen.
              The photographer who gets the most votes in their category wins a <strong>$100 People's Choice award</strong>.
              Voting closes <strong>Thursday, April 23 at 6:00 PM</strong>.
            </p>
            <p class="pc-note">
              Each person may vote for as many pictures as they like, but only once per category.
              The Amateur category has two pages — make sure you browse both!
            </p>
            <div class="pc-vote-links">
              <a href="https://pollunit.com/en/polls/lensofmagna2026professional" target="_blank" rel="noopener noreferrer" class="pc-vote-btn cat-pro-btn">
                Vote: Professional &rarr;
              </a>
              <a href="https://pollunit.com/en/polls/lensofmagna2026amateur" target="_blank" rel="noopener noreferrer" class="pc-vote-btn cat-amateur-btn">
                Vote: Amateur &rarr;
              </a>
              <a href="https://pollunit.com/en/polls/lensofmagna2026youth" target="_blank" rel="noopener noreferrer" class="pc-vote-btn cat-youth-btn">
                Vote: Youth &rarr;
              </a>
            </div>
          </div>
          <div class="pc-prize-card">
            <div class="pc-prize-amount">$100</div>
            <div class="pc-prize-label">per category</div>
            <div class="pc-prize-sub">3 People's Choice Awards</div>
            <div class="pc-deadline">Voting closes<br/><strong>April 23 &middot; 6:00 PM</strong></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── INTRO ── -->
    <section class="section lmm-intro">
      <div class="container lmm-intro-inner">
        <div class="lmm-intro-text reveal">
          <div class="section-label">Photography Contest</div>
          <h2>Capture Magna Through Your Lens</h2>
          <p>
            Magna has a story worth telling — and we're looking for photographers to tell it.
            The Lens of Magna Main Street Photography Contest invites youth, hobbyists, and professionals
            alike to turn their cameras on one of our community's most iconic corridors.
          </p>
          <p>
            This year's theme, <strong>"Main Street in Motion,"</strong> challenges you to capture the energy,
            rhythm, and everyday life of Magna Main Street — the people, the places, and the pulse
            that make our neighborhood home.
          </p>
          <p class="sponsor-line">
            Presented by <strong>Magna City</strong> · <strong>Magna Arts Council</strong> · <strong>Salt Lake County Library – Magna Branch</strong> · <strong>Zoo, Arts &amp; Parks / Salt Lake County</strong>
          </p>
        </div>
        <div class="lmm-prize-callout reveal">
          <div class="prize-amount">$2,875</div>
          <div class="prize-label">in Cash Prizes</div>
          <div class="prize-sub">Awarded across Youth, Amateur &amp; Professional categories</div>
          <a href="https://lensofmagna.com" target="_blank" rel="noopener noreferrer" class="btn btn-navy prize-cta">
            View Prize Details →
          </a>
        </div>
      </div>
    </section>

    <!-- ── RULES ── -->
    <section class="section section-cream lmm-rules">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-label">Contest Rules</div>
          <h2>What You Need to Know</h2>
        </div>
        <div class="rules-grid">
          <div class="rule-card reveal">
            <div class="rule-icon">📍</div>
            <h3>Location</h3>
            <p>All photos must be taken within <strong>300 feet of Magna Main Street</strong>.</p>
          </div>
          <div class="rule-card reveal">
            <div class="rule-icon">🆓</div>
            <h3>Free to Enter</h3>
            <p>There is <strong>no entry fee</strong>. The contest is free and open to the community.</p>
          </div>
          <div class="rule-card reveal">
            <div class="rule-icon">🏆</div>
            <h3>Categories</h3>
            <p><strong>Youth · Amateur · Professional</strong></p>
            <p>Prizes are awarded in each category.</p>
          </div>
          <div class="rule-card reveal">
            <div class="rule-icon">📷</div>
            <h3>Photo Types</h3>
            <p>Any style welcome — <strong>Landscape, Portrait, Street &amp; Documentary, Architecture, Abstract, Nature/Macro</strong>, and more.</p>
          </div>
        </div>
        <p class="rules-footer reveal">
          Full contest rules and submission guidelines are available at
          <a href="https://lensofmagna.com" target="_blank" rel="noopener noreferrer">lensofmagna.com</a>.
        </p>
      </div>
    </section>


    <!-- ── EXHIBITION ── -->
    <section class="section section-cream lmm-exhibit">
      <div class="container lmm-exhibit-inner">
        <div class="exhibit-text reveal">
          <div class="section-label">Photo Exhibition</div>
          <h2>Celebrate Local Talent &amp; Historic Magna Main Street</h2>
          <p>
            Join us for the Lens of Magna Main Photo Exhibition — a public reception showcasing the
            best entries from the contest. Come see Magna through the eyes of our community's photographers.
          </p>
          <div class="exhibit-details">
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Date</span>
              <span>Thursday, April 16, 2026</span>
            </div>
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Time</span>
              <span>6:00 – 8:00 PM</span>
            </div>
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Location</span>
              <a
                href="https://www.google.com/maps/search/?api=1&query=Magna+Branch+Salt+Lake+County+Library+2675+S+8950+W+Magna+UT"
                target="_blank"
                rel="noopener noreferrer"
                class="map-link"
              >
                <svg width="11" height="14" viewBox="0 0 11 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M5.5 0C2.46 0 0 2.46 0 5.5c0 3.85 5.5 8.5 5.5 8.5S11 9.35 11 5.5C11 2.46 8.54 0 5.5 0zm0 7.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4z" fill="currentColor"/>
                </svg>
                Magna Branch — Salt Lake County Library
              </a>
            </div>
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Extras</span>
              <span>Light refreshments served</span>
            </div>
          </div>
        </div>
        <div class="exhibit-flyer-wrap reveal">
          <img
            src="/images/lens-of-magna/lmm-exhibit-flyer.jpg"
            alt="Lens of Magna Main Photo Exhibition — Thursday, April 16th, 6–8 PM, Magna Library"
            class="exhibit-flyer-img"
          />
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="lmm-cta-banner">
      <div class="container lmm-cta-inner reveal">
        <div>
          <h2>Thank You, Magna!</h2>
          <p>
            To every photographer who submitted an entry, attended the reception, and helped make the
            3rd annual Lens of Magna a success — thank you. The talent and community spirit in this
            contest remind us why the arts matter in Magna.
          </p>
          <p class="cta-deadline">People's Choice voting closes <strong>Thursday, April 23 at 6:00 PM</strong></p>
        </div>
        <a href="https://lensofmagna.com" target="_blank" rel="noopener noreferrer" class="btn btn-gold btn-lg">
          lensofmagna.com →
        </a>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  /* ── HERO ── */
  .lmm-hero {
    position: relative;
    width: 100%;
  }

  .lmm-hero-img-wrap {
    position: relative;
    width: 100%;
    max-height: 540px;
    overflow: hidden;
  }

  .lmm-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    max-height: 540px;
  }

  .lmm-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 5, 2, 0.55) 0%,
      rgba(10, 5, 2, 0.15) 35%,
      rgba(10, 5, 2, 0.72) 100%
    );
    display: flex;
    align-items: stretch;
    padding-bottom: 0;
  }

  .lmm-hero-content {
    color: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding-top: 32px;
    padding-bottom: 48px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.22);
    border: 1px solid rgba(232, 160, 32, 0.5);
    color: var(--gold-lt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 13px;
    border-radius: 100px;
    margin-top: 8px;
  }

  .lmm-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 38px);
    font-weight: 900;
    line-height: 1.05;
    text-shadow: 0 2px 12px rgba(0,0,0,0.7);
    margin-bottom: 6px;
    margin-top: 40px;
    padding-left: 20%;
  }

  .lmm-hero-cta-row {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .lmm-deadline-badge {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.04em;
  }

  /* ── BUTTONS ── */
  .btn-gold {
    background: var(--gold);
    color: var(--navy-dk);
    border-color: var(--gold);
  }
  .btn-gold:hover {
    background: var(--gold-lt);
    border-color: var(--gold-lt);
    transform: translateY(-1px);
    box-shadow: var(--shadow-hover);
  }

  .btn-navy {
    background: var(--navy);
    color: var(--white);
    border-color: var(--navy);
  }
  .btn-navy:hover {
    background: var(--navy-dk);
    border-color: var(--navy-dk);
    transform: translateY(-1px);
  }

  .btn-lg {
    font-size: 16px;
    padding: 16px 32px;
  }

  /* ── INTRO ── */
  .lmm-intro-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 56px;
    align-items: center;
  }

  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .lmm-intro-text h2,
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 900;
    color: var(--navy);
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .lmm-intro-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .sponsor-line {
    font-size: 13px !important;
    color: var(--muted);
    border-top: 1px solid var(--border);
    padding-top: 16px;
    margin-top: 8px;
  }

  /* Prize callout */
  .lmm-prize-callout {
    background: var(--navy);
    color: var(--white);
    border-radius: var(--radius);
    padding: 36px 28px;
    text-align: center;
    box-shadow: var(--shadow-card);
  }

  .prize-amount {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
  }

  .prize-label {
    font-size: 16px;
    font-weight: 700;
    color: var(--white);
    margin: 6px 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .prize-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
    margin-bottom: 24px;
  }

  .prize-cta {
    width: 100%;
    justify-content: center;
  }

  /* ── RULES ── */
  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .rules-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .rule-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--gold);
    border-radius: var(--radius);
    padding: 28px 22px;
    text-align: center;
    box-shadow: var(--shadow-card);
  }

  .rule-icon {
    font-size: 32px;
    margin-bottom: 12px;
  }

  .rule-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 10px;
  }

  .rule-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 6px;
  }

  .rules-footer {
    text-align: center;
    font-size: 15px;
    color: var(--muted);
  }

  .rules-footer a {
    color: var(--blue);
    font-weight: 600;
    border-bottom: 1px solid currentColor;
  }

  /* ── DATES ── */
  .dates-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .date-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 32px;
    text-align: center;
    box-shadow: var(--shadow-card);
    min-width: 200px;
    flex: 1;
    max-width: 240px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .date-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }

  .date-card--gold {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--white);
  }

  .date-icon { font-size: 24px; margin-bottom: 10px; }

  .date-month {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .date-card--gold .date-month { color: var(--gold-lt); }

  .date-day {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 900;
    color: var(--navy);
    line-height: 1;
    margin: 4px 0 8px;
  }

  .date-card--gold .date-day { color: var(--white); }

  .date-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 4px;
  }

  .date-card--gold .date-label { color: var(--white); }

  .date-sub {
    font-size: 12px;
    color: var(--muted);
  }

  .date-card--gold .date-sub { color: rgba(255,255,255,0.65); }

  .dates-connector {
    font-size: 24px;
    color: var(--border);
    font-weight: 300;
    flex-shrink: 0;
  }

  /* ── EXHIBITION ── */
  .lmm-exhibit-inner {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 56px;
    align-items: center;
  }

  .exhibit-text h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 900;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .exhibit-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 24px;
  }

  .exhibit-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--gold);
    border-radius: var(--radius);
    padding: 20px 24px;
  }

  .exhibit-detail-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    align-items: center;
    gap: 12px;
    font-size: 14px;
  }

