<script>
  const btn = document.getElementById('attend-btn') as HTMLButtonElement | null;
  const countEl = document.getElementById('attend-count');
  const hintEl  = document.getElementById('attend-hint');
  if (btn && countEl) {
    const eventId = btn.dataset.eventId!;
    const storageKey = `attended_${eventId}`;
    if (localStorage.getItem(storageKey)) {
      btn.textContent = '✓ You\'re Going!';
      btn.disabled = true;
      if (hintEl) hintEl.textContent = 'Thanks for letting us know!';
    }
    btn.addEventListener('click', async () => {
      if (localStorage.getItem(storageKey)) return;
      btn.disabled = true;
      btn.textContent = 'Saving…';
      try {
        const res = await fetch('/api/events/attend', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ eventId }),
        });
        const data = await res.json();
        if (res.ok) {
          countEl.textContent = String(data.count);
          btn.textContent = '✓ You\'re Going!';
          if (hintEl) hintEl.textContent = 'Thanks for letting us know!';
          localStorage.setItem(storageKey, '1');
        } else if (res.status === 409) {
          btn.textContent = '✓ Already Counted';
          if (hintEl) hintEl.textContent = 'Your attendance was already recorded.';
          localStorage.setItem(storageKey, '1');
        } else {
          btn.textContent = 'I\'m Attending';
          btn.disabled = false;
          if (hintEl) hintEl.textContent = 'Something went wrong — try again.';
        }
      } catch {
        btn.textContent = 'I\'m Attending';
        btn.disabled = false;
        if (hintEl) hintEl.textContent = 'Network error — try again.';
      }
    });
  }
</script>
