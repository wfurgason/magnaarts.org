---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';

const user = Astro.locals.user;

const firebaseConfig = {
  apiKey:     import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:  import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
};

// Fetch all collections in parallel
const [
  bandsSnap, programsSnap, eventsSnap, vendorsSnap, volunteersSnap, presentersSnap,
  parkEventsSnap, openMicSnap, artNightSnap, festivalSnap, writingGroupSnap
] = await Promise.all([
  adminDb.collection('band_applications').get(),
  adminDb.collection('program_submissions').get(),
  adminDb.collection('events').get(),
  adminDb.collection('vendor_applications').get(),
  adminDb.collection('volunteer_signups').get(),
  adminDb.collection('art_class_submissions').get(),
  adminDb.collection('park_events').where('status', 'in', ['band_assigned', 'presenter_assigned', 'confirmed']).get(),
  adminDb.collection('open_mic_events').where('status', 'in', ['band_assigned', 'presenter_assigned', 'confirmed']).get(),
  adminDb.collection('art_night_events').where('status', 'in', ['band_assigned', 'presenter_assigned', 'confirmed']).get(),
  adminDb.collection('festival_events').where('status', 'in', ['band_assigned', 'presenter_assigned', 'confirmed']).get(),
  adminDb.collection('writing_group_events').where('status', 'in', ['band_assigned', 'presenter_assigned', 'confirmed']).get(),
]);

const bands      = bandsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const programs   = programsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const vendors    = vendorsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const volunteers = volunteersSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const presenters = presentersSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];

// Events in the planning pipeline (not yet published)
const inProgressShells = [
  ...parkEventsSnap.docs,
  ...openMicSnap.docs,
  ...artNightSnap.docs,
  ...festivalSnap.docs,
  ...writingGroupSnap.docs,
].map(d => d.data() as any);

const pipelineCounts = {
  needsConfirmation: inProgressShells.filter(s => s.status === 'band_assigned' || s.status === 'presenter_assigned').length,
  readyToPublish:    inProgressShells.filter(s => s.status === 'confirmed').length,
};

const counts = {
  bandsPending:      bands.filter(b => !b.status || b.status === 'pending').length,
  bandsApproved:     bands.filter(b => b.status === 'approved').length,
  programsPending:   programs.filter(p => !p.status || p.status === 'pending').length,
  eventsTotal:       eventsSnap.size,
  vendorsPending:    vendors.filter(v => !v.status || v.status === 'pending').length,
  vendorsApproved:   vendors.filter(v => v.status === 'approved').length,
  volunteersNew:     volunteers.filter(v => !v.status || v.status === 'new').length,
  presentersPending: presenters.filter(p => !p.status || p.status === 'pending').length,
};

// 5 most recent of each for activity panels
const recentBands = [...bands]
  .sort((a, b) => (b.submittedAt?.seconds ?? 0) - (a.submittedAt?.seconds ?? 0))
  .slice(0, 5);
const recentVendors = [...vendors]
  .sort((a, b) => new Date(b.submitted_at ?? 0).getTime() - new Date(a.submitted_at ?? 0).getTime())
  .slice(0, 5);
const recentVolunteers = [...volunteers]
  .sort((a, b) => (b.submittedAt?.seconds ?? 0) - (a.submittedAt?.seconds ?? 0))
  .slice(0, 5);
---

<AdminLayout title="Dashboard" user={user}>
  <div class="page-header">
    <h1>Dashboard</h1>
  </div>

  <!-- ── Stat Cards ── -->
  <div class="stat-grid">
    <!-- Applications needing a decision -->
    <div class="stat-card stat-warning">
      <div class="stat-number">{counts.bandsPending}</div>
      <div class="stat-label">Band Applications Pending</div>
      <a href="/admin/bands?filter=pending" class="stat-link">Review →</a>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-number">{counts.vendorsPending}</div>
      <div class="stat-label">Vendor Applications Pending</div>
      <a href="/admin/vendors?filter=pending" class="stat-link">Review →</a>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-number">{counts.presentersPending}</div>
      <div class="stat-label">Art Presenters Pending</div>
      <a href="/admin/art-presenters?filter=pending" class="stat-link">Review →</a>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-number">{counts.programsPending}</div>
      <div class="stat-label">Program Proposals Pending</div>
      <a href="/admin/programs?filter=pending" class="stat-link">Review →</a>
    </div>
    <!-- Things approved that need a next step -->
    <div class="stat-card stat-success">
      <div class="stat-number">{counts.bandsApproved}</div>
      <div class="stat-label">Bands Approved — Ready to Publish</div>
      <a href="/admin/bands?filter=approved" class="stat-link">Publish →</a>
    </div>
    <div class="stat-card stat-success">
      <div class="stat-number">{counts.vendorsApproved}</div>
      <div class="stat-label">Vendors Approved — Awaiting Payment</div>
      <a href="/admin/vendors?filter=approved" class="stat-link">Collect Payment →</a>
    </div>
    <div class="stat-card stat-info">
      <div class="stat-number">{counts.volunteersNew}</div>
      <div class="stat-label">New Volunteer Sign-Ups</div>
      <a href="/admin/volunteers?filter=new" class="stat-link">Contact →</a>
    </div>
    <div class="stat-card stat-primary">
      <div class="stat-number">{counts.eventsTotal}</div>
      <div class="stat-label">Published Events</div>
      <a href="/admin/events" class="stat-link">Manage →</a>
    </div>
    <div class="stat-card stat-warning">
      <div class="stat-number">{pipelineCounts.needsConfirmation + pipelineCounts.readyToPublish}</div>
      <div class="stat-label">Events In Progress</div>
      <div class="stat-sublabel">
        {pipelineCounts.needsConfirmation > 0 && `${pipelineCounts.needsConfirmation} need confirmation`}
        {pipelineCounts.needsConfirmation > 0 && pipelineCounts.readyToPublish > 0 && ' · '}
        {pipelineCounts.readyToPublish > 0 && `${pipelineCounts.readyToPublish} ready to publish`}
        {pipelineCounts.needsConfirmation === 0 && pipelineCounts.readyToPublish === 0 && 'None pending'}
      </div>
      <a href="/admin/planning" class="stat-link">Go to Planning →</a>
    </div>
  </div>

  <!-- ── Recent Activity ── -->
  <div class="recent-grid">
    <section class="recent-section">
      <div class="section-header">
        <h2>Recent Band Applications</h2>
        <a href="/admin/bands" class="link-sm">View all</a>
      </div>
      {recentBands.length === 0 ? (
        <p class="empty-msg">No applications yet.</p>
      ) : (
        <table class="data-table">
          <thead>
            <tr><th>Band</th><th>Genre</th><th>Status</th></tr>
          </thead>
          <tbody>
            {recentBands.map(b => (
              <tr>
                <td><a href={`/admin/bands#${b.id}`}>{b.band_name}</a></td>
                <td>{b.genre}</td>
                <td><span class={`badge badge-${b.status || 'pending'}`}>{b.status || 'pending'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>

    <section class="recent-section">
      <div class="section-header">
        <h2>Recent Vendor Applications</h2>
        <a href="/admin/vendors" class="link-sm">View all</a>
      </div>
      {recentVendors.length === 0 ? (
        <p class="empty-msg">No applications yet.</p>
      ) : (
        <table class="data-table">
          <thead>
            <tr><th>Company</th><th>Type</th><th>Status</th></tr>
          </thead>
          <tbody>
            {recentVendors.map(v => (
              <tr>
                <td><a href={`/admin/vendors#card-${v.id}`}>{v.company_name}</a></td>
                <td style="font-size:12px;color:var(--muted)">{v.vendor_type}</td>
                <td><span class={`badge badge-${v.status || 'pending'}`}>{v.status || 'pending'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>

    <section class="recent-section">
      <div class="section-header">
        <h2>Recent Volunteer Sign-Ups</h2>
        <a href="/admin/volunteers" class="link-sm">View all</a>
      </div>
      {recentVolunteers.length === 0 ? (
        <p class="empty-msg">No sign-ups yet.</p>
      ) : (
        <table class="data-table">
          <thead>
            <tr><th>Name</th><th>Interests</th><th>Status</th></tr>
          </thead>
          <tbody>
            {recentVolunteers.map(v => (
              <tr>
                <td><a href={`/admin/volunteers#${v.id}`}>{v.fullName}</a></td>
                <td style="font-size:12px;color:var(--muted)">
                  {Array.isArray(v.interests) ? v.interests.slice(0,2).join(', ') + (v.interests.length > 2 ? '…' : '') : '—'}
                </td>
                <td><span class={`badge badge-${v.status || 'new'}`}>{v.status || 'new'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  </div>
  <Fragment slot="head">
    <script type="module" define:vars={{ firebaseConfig }}>
      import { initializeApp }          from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
      import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-auth.js';

      const app  = initializeApp(firebaseConfig);
      const auth = getAuth(app);

      onAuthStateChanged(auth, async (user) => {
        if (!user) return; // middleware already guards the route server-side

        // Check custom TOTP enrollment flag in Firestore (not Firebase MFA)
        try {
          const idToken   = await user.getIdToken();
          const statusRes = await fetch('/api/admin/totp-status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idToken }),
          });
          if (statusRes.ok) {
            const { enrolled } = await statusRes.json();
            if (!enrolled) window.location.replace('/admin/enroll-mfa');
          }
        } catch {
          // Non-fatal: middleware session check already confirmed the user is authed.
          // If the status check fails transiently, don't boot them out.
        }
      });
    </script>
  </Fragment>
</AdminLayout>
