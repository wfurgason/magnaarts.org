---
import MailingListBanner from '../components/MailingListBanner.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Magna Arts Council',
  description = "Magna, Utah's Designated Local Arts Agency. Free music, art, film, and culture for the community.",
  image = '/images/ArtsCouncil_logo.png',
} = Astro.props;

const canonicalURL = Astro.url.href;
const ogImageURL = new URL(image, Astro.url).href;

const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Magna Arts Council",
  "url": "https://magnaarts.org",
  "logo": "https://magnaarts.org/images/ArtsCouncil_logo.png",
  "description": "Magna, Utah's Designated Local Arts Agency. Free music, art, film, and culture for the community.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Magna",
    "addressRegion": "UT",
    "addressCountry": "US"
  },
  "sameAs": []
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    <link rel="manifest" href="/images/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Magna Arts Council" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <slot name="head" />
  </head>
  <body>
    <slot />

    <MailingListBanner />

    <!-- Scroll reveal observer — used site-wide -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
