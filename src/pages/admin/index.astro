---
import '../../styles/admin.css';

const sessionCookie = Astro.cookies.get('session')?.value;
if (sessionCookie) {
  try {
    const { adminAuth } = await import('../../lib/firebase-admin');
    await adminAuth.verifySessionCookie(sessionCookie, true);
    return Astro.redirect('/admin/dashboard');
  } catch {
    Astro.cookies.delete('session', { path: '/' });
  }
}

const firebaseConfig = {
  apiKey:     import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:  import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — Magna Arts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
</head>
<body class="admin-login-body">
  <div class="login-card">
    <div class="login-logo">
      <img src="/images/ArtsCouncil_logo.png" alt="Magna Arts Council" />
      <span class="login-logo-text">Magna Arts Council</span>
      <span class="login-logo-sub">Board Portal</span>
    </div>

    <!-- Step 1: Email / password -->
    <form id="login-form" novalidate>
      <div class="field-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>
      <div class="field-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" />
      </div>
      <div id="login-error" class="error-msg" hidden></div>
      <button type="submit" class="btn btn-primary btn-full" id="login-btn">
        Sign In
      </button>
    </form>

    <!-- Step 2: SMS verification (shown after password succeeds for MFA-enrolled accounts) -->
    <div id="mfa-form" hidden>
      <p class="mfa-hint">A verification code was sent to your phone. Enter it below.</p>
      <div class="field-group">
        <label for="sms-code">Verification Code</label>
        <input type="text" id="sms-code" name="sms-code" inputmode="numeric" autocomplete="one-time-code" maxlength="6" />
      </div>
      <div id="mfa-error" class="error-msg" hidden></div>
      <button type="button" class="btn btn-primary btn-full" id="mfa-btn">
        Verify
      </button>
      <button type="button" class="btn btn-ghost btn-full" id="resend-btn" style="margin-top:0.5rem;">
        Resend Code
      </button>
    </div>
  </div>

  <!-- Invisible reCAPTCHA anchor (required by Firebase for SMS) -->
  <div id="recaptcha-container"></div>

  <script type="module" define:vars={{ firebaseConfig }}>
    import { initializeApp }             from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
    import {
      getAuth,
      signInWithEmailAndPassword,
      getMultiFactorResolver,
      PhoneAuthProvider,
      PhoneMultiFactorGenerator,
      RecaptchaVerifier,
      multiFactor,
    } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-auth.js';

    const app  = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    // ── DOM refs ──────────────────────────────────────────────────────────────
    const loginForm  = document.getElementById('login-form');
    const loginError = document.getElementById('login-error');
    const loginBtn   = document.getElementById('login-btn');

    const mfaForm    = document.getElementById('mfa-form');
    const mfaError   = document.getElementById('mfa-error');
    const mfaBtn     = document.getElementById('mfa-btn');
    const resendBtn  = document.getElementById('resend-btn');
    const smsInput   = document.getElementById('sms-code');

    // ── State ─────────────────────────────────────────────────────────────────
    let mfaResolver      = null;   // MultiFactorResolver from the auth error
    let verificationId   = null;   // Returned by verifyPhoneNumber
    let recaptchaVerifier = null;

    // ── Helpers ───────────────────────────────────────────────────────────────
    function showError(el, msg) {
      el.textContent = msg;
      el.hidden = false;
    }

    function setLoading(btn, loading, defaultLabel) {
      btn.disabled = loading;
      btn.textContent = loading ? 'Please wait…' : defaultLabel;
    }

    async function createSessionAndRedirect(user) {
      const idToken = await user.getIdToken();
      const res = await fetch('/api/auth/session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idToken }),
      });
      if (!res.ok) throw new Error('Session creation failed');
      window.location.href = '/admin/dashboard';
    }

    function initRecaptcha() {
      if (recaptchaVerifier) return;
      recaptchaVerifier = new RecaptchaVerifier(auth, 'recaptcha-container', {
        size: 'invisible',
      });
    }

    async function sendSmsCode() {
      initRecaptcha();
      const phoneAuthProvider = new PhoneAuthProvider(auth);
      verificationId = await phoneAuthProvider.verifyPhoneNumber(
        { multiFactorHint: mfaResolver.hints[0], session: mfaResolver.session },
        recaptchaVerifier,
      );
    }

    // ── Step 1: password sign-in ──────────────────────────────────────────────
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      loginError.hidden = true;
      setLoading(loginBtn, true, 'Sign In');

      const email    = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;

      try {
        const cred = await signInWithEmailAndPassword(auth, email, password);

        // Check MFA enrollment status
        const factors = multiFactor(cred.user).enrolledFactors;
        if (factors.length === 0) {
          // Not enrolled — go enroll first; session will be created after
          window.location.href = '/admin/enroll-mfa';
          return;
        }

        // Enrolled but MFA was not required (edge case: should not normally occur
        // once phone factor is enrolled, but handle gracefully)
        await createSessionAndRedirect(cred.user);

      } catch (err) {
        if (err.code === 'auth/multi-factor-auth-required') {
          // Expected path for enrolled users — show SMS panel
          mfaResolver = getMultiFactorResolver(auth, err);
          try {
            await sendSmsCode();
            loginForm.hidden = true;
            mfaForm.hidden   = false;
            smsInput.focus();
          } catch (smsErr) {
            console.error('SMS send failed:', smsErr);
            const smsMsg =
              smsErr.code === 'auth/unverified-email'      ? 'Your email address must be verified before MFA can work. Contact your administrator.' :
              smsErr.code === 'auth/invalid-phone-number'  ? 'The phone number on your account is invalid. Contact your administrator.' :
              smsErr.code === 'auth/too-many-requests'     ? 'Too many attempts. Please wait a few minutes.' :
                                                             `Failed to send code (${smsErr.code || smsErr.message}). Please try again.`;
            showError(loginError, smsMsg);
            setLoading(loginBtn, false, 'Sign In');
          }
          return;
        }

        const msg =
          err.code === 'auth/invalid-credential'   ? 'Invalid email or password.' :
          err.code === 'auth/too-many-requests'    ? 'Too many attempts. Try again later.' :
          err.code === 'auth/user-disabled'        ? 'This account has been disabled.' :
                                                     'Sign-in failed. Please try again.';
        showError(loginError, msg);
        setLoading(loginBtn, false, 'Sign In');
      }
    });

    // ── Step 2: SMS code verification ─────────────────────────────────────────
    mfaBtn.addEventListener('click', async () => {
      mfaError.hidden = true;
      setLoading(mfaBtn, true, 'Verify');

      const code = smsInput.value.trim();
      if (!code || code.length < 6) {
        showError(mfaError, 'Please enter the 6-digit code.');
        setLoading(mfaBtn, false, 'Verify');
        return;
      }

      try {
        const phoneCred = PhoneAuthProvider.credential(verificationId, code);
        const assertion = PhoneMultiFactorGenerator.assertion(phoneCred);
        const mfaCred   = await mfaResolver.resolveSignIn(assertion);
        await createSessionAndRedirect(mfaCred.user);
      } catch (err) {
        const msg =
          err.code === 'auth/invalid-verification-code' ? 'Incorrect code. Please try again.' :
          err.code === 'auth/code-expired'              ? 'Code expired. Use "Resend Code" to get a new one.' :
                                                          'Verification failed. Please try again.';
        showError(mfaError, msg);
        setLoading(mfaBtn, false, 'Verify');
      }
    });

    // ── Resend SMS ─────────────────────────────────────────────────────────────
    resendBtn.addEventListener('click', async () => {
      mfaError.hidden = true;
      resendBtn.disabled = true;
      resendBtn.textContent = 'Sending…';
      smsInput.value = '';

      try {
        // Reset reCAPTCHA so it can fire again
        if (recaptchaVerifier) {
          recaptchaVerifier.clear();
          recaptchaVerifier = null;
        }
        await sendSmsCode();
        resendBtn.textContent = 'Code sent!';
      } catch (err) {
        showError(mfaError, 'Failed to resend code. Please refresh and try again.');
        resendBtn.textContent = 'Resend Code';
      } finally {
        setTimeout(() => {
          resendBtn.disabled = false;
          resendBtn.textContent = 'Resend Code';
        }, 5000);
      }
    });
  </script>
</body>
</html>
