</AdminLayout>

<!-- Inject Firebase config, approved bands, and art class submissions -->
<script define:vars={{ firebaseConfig, approvedBands, artClassSubmissions }}>
  window.__FIREBASE_CONFIG__      = firebaseConfig;
  window.__APPROVED_BANDS__       = approvedBands;
  window.__ART_CLASS_SUBMISSIONS__ = artClassSubmissions;
</script>

<script type="module">
  import { initializeApp, getApps, getApp } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
  import { getStorage, ref, uploadBytes, getDownloadURL } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-storage.js';

  const app     = getApps().length ? getApp() : initializeApp(window.__FIREBASE_CONFIG__);
  const storage = getStorage(app);

  // ── Event type dropdown ─────────────────────────────────────────────────
  const EVENT_PRESETS = {
    music_in_park:   { venue: 'Pleasant Green Park',        address: '3250 S 8400 W, Magna, UT 84044' },
    open_mic:        { venue: 'Magna Library',               address: '2675 S 8950 W, Magna, UT 84044' },
    group_art_night: { venue: 'Magna Library',               address: '2675 S 8950 W, Magna, UT 84044' },
    annual_seminar:  { venue: 'Magna Library',               address: '2675 S 8950 W, Magna, UT 84044' },
    arts_festival:   { venue: 'Historic Magna Main Street',  address: '8900 W to 9180 W Magna Main St, Magna, UT 84044' },
    custom:          { venue: '',                            address: '' },
  };
  const PLACEHOLDER_TYPES = new Set(['annual_seminar', 'custom']);

  const typeSelect    = document.getElementById('event-type-select');
  const mainFormBody  = document.getElementById('main-form-body');
  const placeholderEl = document.getElementById('placeholder-notice');
  const omFields      = document.getElementById('open-mic-fields');
  const anFields      = document.getElementById('art-night-fields');
  const afFields      = document.getElementById('arts-festival-fields');
  const venueInput    = document.getElementById('venue');
  const addrInput     = document.getElementById('address');

  typeSelect.addEventListener('change', () => {
    const val = typeSelect.value;

    if (!val) {
      mainFormBody.hidden  = true;
      placeholderEl.hidden = true;
      return;
    }
    if (PLACEHOLDER_TYPES.has(val)) {
      mainFormBody.hidden  = true;
      placeholderEl.hidden = false;
      return;
    }

    mainFormBody.hidden  = false;
    placeholderEl.hidden = true;

    const preset = EVENT_PRESETS[val];
    if (preset) {
      venueInput.value = preset.venue;
      addrInput.value  = preset.address;
    }

    omFields.style.display = val === 'open_mic'        ? 'flex' : 'none';
    anFields.style.display = val === 'group_art_night' ? 'flex' : 'none';
    afFields.style.display = val === 'arts_festival'   ? 'flex' : 'none';
  });

  // ── Calendar ────────────────────────────────────────────────────────────
  const yearInput   = document.getElementById('year');
  const calGrid     = document.getElementById('cal-grid');
  const datesHidden = document.getElementById('dates-hidden');
  const chipsWrap   = document.getElementById('selected-chips');
  const chipsList   = document.getElementById('chips-list');
  const clearBtn    = document.getElementById('clear-dates-btn');

  const MONTH_NAMES = ['January','February','March','April','May','June',
                       'July','August','September','October','November','December'];
  const DAY_ABBRS   = ['Su','Mo','Tu','We','Th','Fr','Sa'];

  let selectedDates = new Set();

  function pad(n) { return String(n).padStart(2, '0'); }
  function dateKey(y, m, d) { return `${y}-${pad(m+1)}-${pad(d)}`; }

  function buildCalendar(year) {
    calGrid.innerHTML = '';
    for (let m = 0; m < 12; m++) {
      const monthEl = document.createElement('div');
      monthEl.className = 'cal-month';

      const heading = document.createElement('div');
      heading.className = 'cal-month-heading';
      heading.textContent = MONTH_NAMES[m];
      monthEl.appendChild(heading);

      const dowRow = document.createElement('div');
      dowRow.className = 'cal-dow-row';
      dowRow.style.cssText = 'display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:2px;';
      DAY_ABBRS.forEach(ab => {
        const c = document.createElement('div');
        c.className = 'cal-dow';
        c.textContent = ab;
        dowRow.appendChild(c);
      });
      monthEl.appendChild(dowRow);

      const daysEl = document.createElement('div');
      daysEl.className = 'cal-days';
      daysEl.style.cssText = 'display:grid;grid-template-columns:repeat(7,1fr);gap:2px;';

      const firstDow   = new Date(year, m, 1).getDay();
      const daysInMonth = new Date(year, m+1, 0).getDate();

      for (let i = 0; i < firstDow; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-day cal-blank';
        daysEl.appendChild(blank);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const key   = dateKey(year, m, d);
        const dayEl = document.createElement('div');
        dayEl.className = 'cal-day';
        dayEl.textContent = d;
        dayEl.dataset.date = key;
        if (selectedDates.has(key)) dayEl.classList.add('cal-selected');

        dayEl.addEventListener('click', () => {
          if (selectedDates.has(key)) {
            selectedDates.delete(key);
            dayEl.classList.remove('cal-selected');
          } else {
            selectedDates.add(key);
            dayEl.classList.add('cal-selected');
          }
          syncDates();
        });

        daysEl.appendChild(dayEl);
      }

      monthEl.appendChild(daysEl);
      calGrid.appendChild(monthEl);
    }
  }

  function syncDates() {
    const sorted = Array.from(selectedDates).sort();
    datesHidden.value = sorted.join('\n');

    if (sorted.length === 0) {
      chipsWrap.hidden = true;
      chipsList.innerHTML = '';
      return;
    }

    chipsWrap.hidden = false;
    chipsList.innerHTML = '';
    sorted.forEach(key => {
      const [y, mo, d] = key.split('-').map(Number);
      const label = new Date(y, mo-1, d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      const chip = document.createElement('span');
      chip.className = 'date-chip';
      chip.innerHTML = `${label} <button type="button" class="chip-remove" data-date="${key}" aria-label="Remove ${label}">×</button>`;
      chipsList.appendChild(chip);
    });

    chipsList.querySelectorAll('.chip-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.date;
        selectedDates.delete(key);
        const dayEl = calGrid.querySelector(`[data-date="${key}"]`);
        if (dayEl) dayEl.classList.remove('cal-selected');
        syncDates();
      });
    });
  }

  clearBtn.addEventListener('click', () => {
    selectedDates.clear();
    calGrid.querySelectorAll('.cal-selected').forEach(el => el.classList.remove('cal-selected'));
    syncDates();
  });

  buildCalendar(parseInt(yearInput.value) || new Date().getFullYear());
  yearInput.addEventListener('change', () => {
    selectedDates.clear();
    syncDates();
    buildCalendar(parseInt(yearInput.value) || new Date().getFullYear());
  });

  // ── Art Night image upload ─────────────────────────────────────────────
  const anImageZone    = document.getElementById('an-image-zone');
  const anImageInput   = document.getElementById('an-image-input');
  const anImagePreview = document.getElementById('an-image-preview');
  const anImageUrlEl   = document.getElementById('anImageUrl');
  const anUploadStatus = document.getElementById('an-upload-status');

  anImageZone.addEventListener('dragover', e => { e.preventDefault(); anImageZone.classList.add('drag-over'); });
  anImageZone.addEventListener('dragleave', () => anImageZone.classList.remove('drag-over'));
  anImageZone.addEventListener('drop', e => {
    e.preventDefault();
    anImageZone.classList.remove('drag-over');
    if (e.dataTransfer?.files?.length) {
      const dt = new DataTransfer();
      dt.items.add(e.dataTransfer.files[0]);
      anImageInput.files = dt.files;
      anImageInput.dispatchEvent(new Event('change'));
    }
  });

  anImageInput.addEventListener('change', () => {
    const file = anImageInput.files?.[0];
    if (!file) { anImagePreview.hidden = true; return; }
    const reader = new FileReader();
    reader.onload = ev => {
      anImagePreview.hidden = false;
      anImagePreview.innerHTML = `<img src="${ev.target.result}" alt="Preview" /><span>${file.name} (${(file.size/1024/1024).toFixed(1)} MB)</span>`;
    };
    reader.readAsDataURL(file);
    anImageUrlEl.value = '';
  });

  // ── Open Mic image upload ───────────────────────────────────────────────
  const omImageZone    = document.getElementById('om-image-zone');
  const omImageInput   = document.getElementById('om-image-input');
  const omImagePreview = document.getElementById('om-image-preview');
  const omImageUrlEl   = document.getElementById('omImageUrl');
  const omUploadStatus = document.getElementById('om-upload-status');

  omImageZone.addEventListener('dragover', e => { e.preventDefault(); omImageZone.classList.add('drag-over'); });
  omImageZone.addEventListener('dragleave', () => omImageZone.classList.remove('drag-over'));
  omImageZone.addEventListener('drop', e => {
    e.preventDefault();
    omImageZone.classList.remove('drag-over');
    if (e.dataTransfer?.files?.length) {
      const dt = new DataTransfer();
      dt.items.add(e.dataTransfer.files[0]);
      omImageInput.files = dt.files;
      omImageInput.dispatchEvent(new Event('change'));
    }
  });

  omImageInput.addEventListener('change', () => {
    const file = omImageInput.files?.[0];
    if (!file) { omImagePreview.hidden = true; return; }
    const reader = new FileReader();
    reader.onload = ev => {
      omImagePreview.hidden = false;
      omImagePreview.innerHTML = `<img src="${ev.target.result}" alt="Preview" /><span>${file.name} (${(file.size/1024/1024).toFixed(1)} MB)</span>`;
    };
    reader.readAsDataURL(file);
    omImageUrlEl.value = ''; // clear previously uploaded URL when new file chosen
  });

  // ── Form submit — upload image first if needed, then POST ───────────────
  const seasonForm   = document.getElementById('season-form');
  const submitBtn    = document.getElementById('submit-btn');
  const submitStatus = document.getElementById('submit-status');

  seasonForm.addEventListener('submit', async (e) => {
    const isOpenMic = typeSelect.value === 'open_mic';
    const file      = omImageInput.files?.[0];

    // Validate dates for all active event types
    if (mainFormBody && !mainFormBody.hidden && !datesHidden.value.trim()) {
      e.preventDefault();
      alert('Please select at least one date from the calendar.');
      return;
    }

    const isArtNight  = typeSelect.value === 'group_art_night';
    const anFile      = anImageInput.files?.[0];

    // If Art Night with a new file not yet uploaded, intercept and upload first
    if (isArtNight && anFile && !anImageUrlEl.value) {
      e.preventDefault();
      submitBtn.disabled = true;
      submitStatus.hidden = false;
      submitStatus.textContent = 'Uploading image…';
      try {
        const year = yearInput.value || '2026';
        const ext  = anFile.name.split('.').pop();
        const path = `art-night-images/${year}/event-image.${ext}`;
        const storageRef = ref(storage, path);
        await uploadBytes(storageRef, anFile);
        const url = await getDownloadURL(storageRef);
        anImageUrlEl.value = url;
        submitStatus.textContent = 'Saving…';
        seasonForm.submit();
      } catch (err) {
        submitStatus.hidden = true;
        submitBtn.disabled  = false;
        alert('Image upload failed: ' + (err.message || 'Unknown error'));
      }
      return;
    }

    // If Open Mic with a new file not yet uploaded, intercept and upload first
    if (isOpenMic && file && !omImageUrlEl.value) {
      e.preventDefault();

      submitBtn.disabled = true;
      submitStatus.hidden = false;
      submitStatus.textContent = 'Uploading image…';

      try {
        const year = yearInput.value || '2026';
        const ext  = file.name.split('.').pop();
        const path = `open-mic-images/${year}/event-image.${ext}`;
        const storageRef = ref(storage, path);
        await uploadBytes(storageRef, file);
        const url = await getDownloadURL(storageRef);
        omImageUrlEl.value = url;

        submitStatus.textContent = 'Saving…';
        seasonForm.submit();
      } catch (err) {
        submitStatus.hidden = true;
        submitBtn.disabled  = false;
        alert('Image upload failed: ' + (err.message || 'Unknown error'));
      }
    }
  });

  // ── Music & Movies action buttons ───────────────────────────────────────
  document.querySelectorAll('.action-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el       = btn;
      const action   = el.dataset.action;
      const shellId  = el.dataset.shellId;
      const bandName = el.dataset.bandName || 'this band';

      const msgs = {
        confirm:  `Mark ${bandName} as confirmed for this date?`,
        unassign: `Remove ${bandName} from this date? They will return to "approved" status.`,
        publish:  'Publish this event to the public site?',
      };

      if (!confirm(msgs[action] || 'Are you sure?')) return;
      el.disabled    = true;
      el.textContent = 'Working…';

      const res = await fetch('/api/admin/assign-band', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ action, shellId }),
      });

      if (res.ok) {
        action === 'publish'
          ? (window.location.href = '/admin/events')
          : window.location.reload();
      } else {
        const { error } = await res.json();
        alert(error || 'Action failed.');
        el.disabled    = false;
        el.textContent = { confirm: 'Mark Confirmed', unassign: 'Unassign', publish: 'Publish ↗' }[action] ?? el.textContent;
      }
    });
  });

  // ── Open Mic publish buttons ────────────────────────────────────────────
  document.querySelectorAll('.om-publish-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el      = btn;
      const shellId = el.dataset.shellId;

      if (!confirm('Publish this Open Mic Night event to the public site?')) return;
      el.disabled    = true;
      el.textContent = 'Publishing…';

      const res = await fetch('/api/admin/publish-open-mic', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ shellId }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
        alert(error || 'Publish failed.');
        el.disabled    = false;
        el.textContent = 'Publish ↗';
      }
    });
  });

  // ── Arts Festival publish buttons ────────────────────────────────────────
  document.querySelectorAll('.festival-publish-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el      = btn;
      const shellId = el.dataset.shellId;

      if (!confirm('Publish this Arts Festival event to the public site?')) return;
      el.disabled    = true;
      el.textContent = 'Publishing…';

      try {
        const res = await fetch('/api/admin/publish-festival', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ shellId }),
        });

        if (res.ok) {
          window.location.href = '/admin/events';
        } else {
          const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
          alert(error || 'Publish failed.');
          el.disabled    = false;
          el.textContent = 'Publish ↗';
        }
      } catch (err) {
        alert('Publish failed: ' + (err.message || 'Unknown error'));
        el.disabled    = false;
        el.textContent = 'Publish ↗';
      }
    });
  });

  // ── Art Night publish buttons ────────────────────────────────────────────
  document.querySelectorAll('.an-publish-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const shellId = btn.dataset.shellId;
      if (!confirm('Publish this Group Art Night event to the public site?')) return;
      btn.disabled    = true;
      btn.textContent = 'Publishing…';
      try {
        const res = await fetch('/api/admin/publish-art-night', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ shellId }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const { error } = await res.json().catch(() => ({ error: 'Unknown error' }));
          alert(error || 'Publish failed.');
          btn.disabled    = false;
          btn.textContent = 'Publish ↗';
        }
      } catch (err) {
        alert('Publish failed: ' + (err.message || 'Unknown error'));
        btn.disabled    = false;
        btn.textContent = 'Publish ↗';
      }
    });
  });

  // ── Presenter assign modal ───────────────────────────────────────────────
  const presenterModal      = document.getElementById('presenter-modal');
  const presenterShellIdEl  = document.getElementById('presenter-modal-shell-id');
  const presenterIdEl       = document.getElementById('presenter-modal-presenter-id');
  const presenterNameEl     = document.getElementById('presenter-modal-presenter-name');
  const presenterList       = document.getElementById('presenter-list');
  const presenterSubmitBtn  = document.getElementById('presenter-modal-submit');
  const submissions         = window.__ART_CLASS_SUBMISSIONS__ || [];

  document.querySelectorAll('.btn-assign-presenter').forEach(btn => {
    btn.addEventListener('click', () => {
      presenterShellIdEl.value    = btn.dataset.shellId;
      presenterIdEl.value         = '';
      presenterNameEl.value       = '';
      presenterSubmitBtn.disabled = true;

      if (submissions.length === 0) {
        presenterList.innerHTML = '<p class="dim" style="font-size:13px;padding:12px">No pending Art Class submissions found. Applicants submit via the Teach an Art Class page.</p>';
      } else {
        presenterList.innerHTML = submissions.map(s => `
          <label class="fest-band-option">
            <input type="radio" name="presenter-pick" value="${s.id}" data-name="${s.fullName}" />
            <span class="fest-band-option-name">${s.fullName}</span>
            <span class="fest-band-option-genre">${s.artsArea ? s.artsArea.substring(0, 40) : ''}</span>
          </label>
        `).join('');

        presenterList.querySelectorAll('input[type=radio]').forEach(radio => {
          radio.addEventListener('change', () => {
            presenterIdEl.value         = radio.value;
            presenterNameEl.value       = radio.dataset.name;
            presenterSubmitBtn.disabled = false;
          });
        });
      }

      presenterModal.hidden = false;
    });
  });

  document.getElementById('presenter-modal-cancel')?.addEventListener('click', () => { presenterModal.hidden = true; });
  presenterModal.addEventListener('click', e => { if (e.target === presenterModal) presenterModal.hidden = true; });

  // ── Festival band assign modal ─────────────────────────────────────
  const festModal       = document.getElementById('fest-band-modal');
  const festSlotLabel   = document.getElementById('fest-modal-slot-label');
  const festShellIdEl   = document.getElementById('fest-modal-shell-id');
  const festSlotEl      = document.getElementById('fest-modal-slot');
  const festBandIdEl    = document.getElementById('fest-modal-band-id');
  const festBandNameEl  = document.getElementById('fest-modal-band-name');
  const festBandList    = document.getElementById('fest-band-list');
  const festSubmitBtn   = document.getElementById('fest-modal-submit');
  const bands           = window.__APPROVED_BANDS__ || [];

  document.querySelectorAll('.btn-assign-fest').forEach(btn => {
    btn.addEventListener('click', () => {
      const shellId = btn.dataset.shellId;
      const slot    = btn.dataset.slot;

      festShellIdEl.value  = shellId;
      festSlotEl.value     = slot;
      festSlotLabel.textContent = slot;
      festBandIdEl.value   = '';
      festBandNameEl.value = '';
      festSubmitBtn.disabled = true;
      document.getElementById('fest-modal-time').value = '';

      // Populate band list
      if (bands.length === 0) {
        festBandList.innerHTML = '<p class="dim" style="font-size:13px">No approved bands found. Approve bands on the Bands page first.</p>';
      } else {
        festBandList.innerHTML = bands.map(b => `
          <label class="fest-band-option">
            <input type="radio" name="fest-band-pick" value="${b.id}" data-name="${b.band_name || b.contact_name}" />
            <span class="fest-band-option-name">${b.band_name || b.contact_name}</span>
            ${b.genre ? `<span class="fest-band-option-genre">${b.genre}</span>` : ''}
          </label>
        `).join('');

        festBandList.querySelectorAll('input[type=radio]').forEach(radio => {
          radio.addEventListener('change', () => {
            festBandIdEl.value   = radio.value;
            festBandNameEl.value = radio.dataset.name;
            festSubmitBtn.disabled = false;
          });
        });
      }

      festModal.hidden = false;
    });
  });

  document.getElementById('fest-modal-cancel')?.addEventListener('click', () => { festModal.hidden = true; });
  festModal.addEventListener('click', e => { if (e.target === festModal) festModal.hidden = true; });

  // ── Edit modal ──────────────────────────────────────────────────────────
  const editModal = document.getElementById('edit-modal');

  window.openEditModal = function(id, venue, address, startTime, collection) {
    document.getElementById('edit-shell-id').value   = id;
    document.getElementById('edit-venue').value      = venue;
    document.getElementById('edit-address').value    = address;
    document.getElementById('edit-startTime').value  = startTime;
    document.getElementById('edit-collection').value = collection;
    editModal.hidden = false;
  };

  window.closeEditModal = function() { editModal.hidden = true; };

  document.getElementById('modal-cancel-btn')?.addEventListener('click', () => { editModal.hidden = true; });
  editModal.addEventListener('click', function(e) { if (e.target === this) editModal.hidden = true; });
</script>

<style>
  .page-header { margin-bottom: 32px; }
  .page-header h1 { font-family: var(--font-display, serif); font-size: 28px; font-weight: 700; color: var(--navy, #1a2456); margin: 0 0 6px; }
  .page-sub { color: var(--muted, #5a5a7a); font-size: 15px; margin: 0; }

  .flash { padding: 14px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; margin-bottom: 24px; }
  .flash-success { background: #d1fae5; border: 1.5px solid #6ee7b7; color: #065f46; }
  .flash-error   { background: #fee2e2; border: 1.5px solid #fca5a5; color: #991b1b; }

  .card { background: var(--white, #fff); border: 1.5px solid var(--border, #e5e5e5); border-radius: 12px; padding: 28px 32px; margin-bottom: 32px; }
  .card-title { font-family: var(--font-display, serif); font-size: 20px; font-weight: 700; color: var(--navy, #1a2456); margin: 0 0 6px; }
  .card-sub { color: var(--muted, #5a5a7a); font-size: 14px; margin: 0 0 24px; line-height: 1.55; }
  .season-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }

  .count-badge {
    display: inline-block; font-family: var(--font-body, sans-serif); font-size: 12px; font-weight: 600;
    color: var(--muted, #5a5a7a); background: #f1f5f9; border-radius: 100px;
    padding: 2px 10px; margin-left: 8px; vertical-align: middle;
  }

  .season-form { display: flex; flex-direction: column; gap: 16px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-field label { font-size: 12px; font-weight: 700; color: var(--navy, #1a2456); text-transform: uppercase; letter-spacing: 0.05em; }
  .field-hint { font-size: 11px; font-weight: 400; color: var(--muted, #5a5a7a); text-transform: none; letter-spacing: 0; margin-left: 6px; }
  .req { color: var(--red, #b52626); }
  .form-field input,
  .form-field textarea,
  .form-field select {
    font-family: inherit; font-size: 14px; color: var(--text, #1a1a1a);
    border: 1.5px solid var(--border, #e5e5e5); border-radius: 6px;
    padding: 9px 12px; outline: none; transition: border-color 0.2s;
    width: 100%; box-sizing: border-box; background: #fff;
  }
  .form-field input:focus,
  .form-field textarea:focus,
  .form-field select:focus { border-color: var(--blue, #2563b0); box-shadow: 0 0 0 3px rgba(37,99,176,0.1); }
  .form-field textarea { resize: vertical; font-family: monospace; font-size: 13px; }
  .form-actions { padding-top: 4px; display: flex; align-items: center; gap: 16px; }
  .submit-status { font-size: 13px; color: var(--muted, #5a5a7a); font-style: italic; }

  .event-extra-fields { flex-direction: column; gap: 16px; padding: 20px; background: #f8faff; border: 1.5px solid #dbeafe; border-radius: 8px; }

  .placeholder-notice {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    padding: 36px 24px; background: #f8f9fa; border: 1.5px dashed var(--border, #e5e5e5);
    border-radius: 8px; text-align: center; color: var(--muted, #5a5a7a); font-size: 14px; line-height: 1.6;
  }
  .placeholder-notice strong { color: var(--navy, #1a2456); font-size: 15px; }
  .placeholder-notice p { margin: 0; }
  .placeholder-icon { font-size: 32px; }

  .info-callout {
    display: flex; align-items: flex-start; gap: 10px; padding: 12px 16px;
    background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px;
    font-size: 13px; color: #1e40af; line-height: 1.55;
  }

  /* ── Upload zone ── */
  .upload-zone {
    position: relative; border: 2px dashed var(--border, #e5e5e5);
    border-radius: 8px; background: #f8faff;
    transition: border-color 0.2s, background 0.2s; overflow: hidden;
  }
  .upload-zone.drag-over { border-color: var(--blue, #2563b0); background: #eff6ff; }
  .upload-input {
    position: absolute; inset: 0; opacity: 0; cursor: pointer;
    width: 100% !important; height: 100%; padding: 0 !important; border: none !important;
  }
  .upload-label {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 6px; padding: 28px 24px; cursor: pointer; text-align: center;
  }
  .upload-icon { font-size: 28px; }
  .upload-text { font-size: 14px; color: var(--navy, #1a2456); }
  .upload-text strong { color: var(--blue, #2563b0); }
  .upload-hint { font-size: 12px; color: var(--muted, #5a5a7a); }
  .upload-preview {
    display: flex; align-items: center; gap: 12px; padding: 10px 14px;
    background: #fff; border-top: 1.5px solid var(--border, #e5e5e5);
    font-size: 13px; color: var(--muted, #5a5a7a);
  }
  .upload-status { font-size: 12px; color: var(--blue, #2563b0); font-style: italic; margin-top: 4px; }

  /* ── Shells table ── */
  .shells-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .shells-table th {
    text-align: left; font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--muted, #5a5a7a);
    padding: 8px 12px; border-bottom: 2px solid var(--border, #e5e5e5);
  }
  .shells-table td { padding: 12px 12px; border-bottom: 1px solid var(--border, #e5e5e5); vertical-align: middle; }
  .shells-table tr:last-child td { border-bottom: none; }
  .date-cell  { font-weight: 600; color: var(--navy, #1a2456); white-space: nowrap; }
  .venue-cell { color: var(--muted, #5a5a7a); }
  .dim { color: var(--muted, #5a5a7a); opacity: 0.5; }
  .check-yes { color: #059669; font-weight: 600; }
  .check-no  { color: var(--red, #b52626); font-weight: 600; font-size: 12px; }
  .desc-preview-cell { max-width: 220px; }
  .desc-preview { font-size: 12px; color: var(--muted, #5a5a7a); line-height: 1.4; }
  .link-sm { font-size: 12px; font-weight: 600; color: var(--blue, #2563b0); text-decoration: none; }
  .link-sm:hover { text-decoration: underline; }

  /* ── Festival card ── */
  .fest-card { border-top: 3px solid var(--amber, #c87e0a); }
  .fest-meta { font-size: 13px; color: var(--muted, #5a5a7a); margin: 4px 0 0; }
  .fest-header-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .fest-description { font-size: 14px; color: var(--muted, #5a5a7a); line-height: 1.65; margin: 0 0 24px; padding-bottom: 20px; border-bottom: 1px solid var(--border, #e5e5e5); }
  .fest-body { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
  @media (max-width: 900px) { .fest-body { grid-template-columns: 1fr; } }
  .fest-section { display: flex; flex-direction: column; gap: 12px; }
  .fest-section-heading { font-family: var(--font-display, serif); font-size: 16px; font-weight: 700; color: var(--navy, #1a2456); margin: 0 0 4px; padding-bottom: 8px; border-bottom: 2px solid var(--amber, #c87e0a); }
  .slot-cell { font-weight: 700; color: var(--amber, #c87e0a); white-space: nowrap; }
  .time-cell { color: var(--muted, #5a5a7a); font-size: 13px; white-space: nowrap; }
  .band-cell { font-weight: 600; }
  .btn-assign-fest { background: #fef3c7; border-color: #fde68a; color: #92400e; font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 6px; cursor: pointer; border: 1.5px solid; }
  .btn-assign-fest:hover { background: #fde68a; }
  .btn-disabled { opacity: 0.45; cursor: not-allowed; }

  /* Vendor summary */
  .vendor-summary-card { display: flex; align-items: center; justify-content: space-between; gap: 16px; background: var(--cream, #f7f5f0); border: 1.5px solid var(--border, #e5e5e5); border-radius: 8px; padding: 16px 20px; flex-wrap: wrap; }
  .vendor-summary-stat { display: flex; flex-direction: column; align-items: flex-start; }
  .vendor-stat-number { font-family: var(--font-display, serif); font-size: 36px; font-weight: 900; color: var(--navy, #1a2456); line-height: 1; }
  .vendor-stat-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted, #5a5a7a); margin-top: 4px; }
  .vendor-summary-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .vendor-hint { font-size: 12px; color: var(--muted, #5a5a7a); line-height: 1.55; margin: 0; }

  .badge { display: inline-block; padding: 3px 10px; border-radius: 100px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .badge-shell              { background: #f1f5f9; color: #64748b; }
  .badge-band_assigned      { background: #fef3c7; color: #92400e; }
  .badge-presenter_assigned { background: #fef3c7; color: #92400e; }
  .badge-planning           { background: #fef3c7; color: #92400e; }
  .badge-confirmed          { background: #d1fae5; color: #065f46; }
  .badge-published          { background: #dbeafe; color: #1e40af; }

  .actions-cell { white-space: nowrap; display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .btn-sm { font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 6px; cursor: pointer; border: 1.5px solid transparent; transition: opacity 0.15s; }
  .btn-sm:hover:not(:disabled) { opacity: 0.8; }
  .btn-sm:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-outline         { background: transparent; border-color: var(--border, #e5e5e5); color: var(--navy, #1a2456); }
  .btn-danger          { background: #fee2e2; border-color: #fca5a5; color: #991b1b; }
  .btn-confirm         { background: #d1fae5; border-color: #6ee7b7; color: #065f46; }
