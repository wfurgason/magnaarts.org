---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { events } from '../../data/events';

const concerts  = events.filter((e) => e.type === 'concert' || e.type === 'film');
const yearRound = events.filter((e) => e.type === 'festival' || e.type === 'class' || e.type === 'openmic');
---

<BaseLayout
  title="Events — Magna Arts Council"
  description="Upcoming events from the Magna Arts Council — free concerts, movies in the park, open mic nights, and the annual Arts Festival."
>
  <Header />

  <main>

    <!-- ── PAGE HERO ── -->
    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">2025 Season</div>
        <h1>Free Events for Everyone</h1>
        <p class="hero-sub">
          Every event is free and open to all. Bring a blanket, bring the family,
          and enjoy the best of Magna's arts community.
        </p>
      </div>
    </section>

    <!-- ── SUMMER SERIES CALLOUT ── -->
    <section class="series-callout reveal">
      <div class="container series-inner">
        <div class="series-text">
          <h2>Music &amp; Movies in the Park</h2>
          <p>Every Friday night June through August. Live music starts at 8 PM, movie follows at dusk on our 35-ft inflatable screen.</p>
          <div class="series-details">
            <span class="detail-pill">📍 Pleasant Green Park — 3250 S 8400 W, Magna</span>
            <span class="detail-pill">🗓 Every Friday · June – August</span>
            <span class="detail-pill">🎟 Free Admission</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── EVENTS LIST ── -->
    <section class="section events-section">
      <div class="container">
        <h2 class="section-title reveal">Summer 2025 Schedule</h2>
        <div class="events-list">
          {concerts.map((e, i) => (
            <a href={`/events/${e.id}`} class={`event-row event-${e.type} reveal`} style={`transition-delay:${i * 0.04}s`}>
              <div class="event-date">{e.date}</div>
              <div class="event-body">
                <div class="event-title">{e.title}</div>
                {e.subtitle && e.subtitleType === 'film' && (
                  <div class="event-movie">🎬 {e.subtitle}</div>
                )}
                <div class="event-day">{e.day} · {e.time}</div>
              </div>
              <div class={`event-type-badge badge-${e.type}`}>
                {e.type === 'concert' ? 'Concert + Film' : 'Film'}
              </div>
              <div class="event-arrow">→</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── FESTIVAL ── -->
    <section class="section festival-section">
      <div class="container">
        <h2 class="section-title reveal">Annual Events</h2>
        <div class="festival-card reveal">
          <div class="festival-body">
            <div class="festival-badge">Festival</div>
            <h3>Magna Main Street Arts Festival</h3>
            <p>Our flagship annual event. 5,000–7,000 attendees, live music, a fine arts contest, street performers, and arts and food vendors on Historic Magna Main Street.</p>
            <div class="festival-meta">
              <span>📍 Historic Magna Main Street</span>
              <span>🗓 August 2025</span>
              <span>🎟 Free Admission</span>
            </div>
          </div>
          <a href="/events/arts-festival-2025" class="btn btn-gold festival-btn">Event Details →</a>
        </div>
      </div>
    </section>

    <!-- ── OTHER PROGRAMS ── -->
    <section class="section other-section">
      <div class="container">
        <h2 class="section-title reveal">Year-Round Programs</h2>
        <div class="other-grid">
          <div class="other-card reveal">
            <span class="other-icon">🎤</span>
            <h3>Open Mic Night</h3>
            <p>8–10 events per year at the Magna Library. Music, comedy, and poetry — open to all performers.</p>
            <a href="/programs#open-mic" class="other-link">Learn more →</a>
          </div>
          <div class="other-card reveal">
            <span class="other-icon">✦</span>
            <h3>Group Art Night</h3>
            <p>Artist-guided sessions at the Magna Library. Come create with your community.</p>
            <a href="/programs#art-night" class="other-link">Learn more →</a>
          </div>
          <div class="other-card reveal">
            <span class="other-icon">📚</span>
            <h3>Arts Seminar</h3>
            <p>Annual deep-dive into a different art discipline — panels, education, and Q&amp;A.</p>
            <a href="/programs#seminar" class="other-link">Learn more →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-banner">
      <div class="container cta-inner reveal">
        <div>
          <h2>Want to Perform or Present?</h2>
          <p>Have a band, a film, an idea for a class? Submit a program proposal and we'll review it at our next board meeting.</p>
        </div>
        <a href="/propose" class="btn btn-gold">Submit a Proposal →</a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0 64px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.18);
    border: 1px solid rgba(232, 160, 32, 0.45);
    color: var(--gold-lt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 18px;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── SERIES CALLOUT ── */
  .series-callout { background: var(--blue); color: var(--white); padding: 48px 0; }
  .series-inner { max-width: 760px; }

  .series-text h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .series-text p {
    font-size: 16px;
    color: rgba(255,255,255,0.85);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .series-details { display: flex; flex-wrap: wrap; gap: 10px; }

  .detail-pill {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    color: var(--white);
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 100px;
  }

  /* ── EVENTS LIST ── */
  .events-section { background: var(--white); }

  .section-title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 28px;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .event-row {
    display: grid;
    grid-template-columns: 72px 1fr auto auto;
    align-items: center;
    gap: 20px;
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--white);
    transition: background 0.15s;
    cursor: pointer;
    color: inherit;
  }

  .event-row:last-child { border-bottom: none; }
  .event-row:hover { background: var(--cream); }

  .event-date {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    text-align: center;
    line-height: 1.2;
    flex-shrink: 0;
  }

  .event-title { font-weight: 600; font-size: 16px; color: var(--navy); margin-bottom: 2px; }
  .event-movie { font-size: 13px; color: var(--red); font-weight: 500; margin-bottom: 2px; }
  .event-day   { font-size: 12.5px; color: var(--muted); }

  .event-type-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .badge-concert { background: #dbeafe; color: var(--blue); }
  .badge-film    { background: #fee2e2; color: var(--red); }

  .event-arrow {
    font-size: 16px;
    color: var(--muted);
    transition: transform 0.2s, color 0.2s;
  }
  .event-row:hover .event-arrow { transform: translateX(4px); color: var(--navy); }

  /* ── FESTIVAL ── */
  .festival-section { background: var(--cream); }

  .festival-card {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 36px 40px;
    box-shadow: var(--shadow-card);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    border-left: 4px solid var(--amber);
  }

  .festival-badge {
    display: inline-block;
    background: #fef3c7;
    color: var(--amber);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 12px;
  }

  .festival-body h3 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 10px;
  }

  .festival-body p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 560px;
    margin-bottom: 16px;
  }

  .festival-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
  }

  .festival-btn { flex-shrink: 0; }

  /* ── OTHER ── */
  .other-section { background: var(--white); }

  .other-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .other-card {
    background: var(--cream);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: box-shadow 0.22s, transform 0.22s;
  }

  .other-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-4px); }
  .other-icon { font-size: 28px; }

  .other-card h3 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--navy);
  }

  .other-card p { font-size: 14px; color: var(--muted); line-height: 1.65; flex: 1; }

  .other-link {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--blue);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.2s;
  }
  .other-link:hover { gap: 8px; }

  /* ── CTA ── */
  .cta-banner { background: var(--navy-dk); color: var(--white); padding: 56px 0; }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .cta-inner h2 {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .cta-inner p { font-size: 15px; color: rgba(255,255,255,0.72); max-width: 520px; }

  /* ── RESPONSIVE ── */
  @media (max-width: 760px) {
    .event-row { grid-template-columns: 56px 1fr auto; }
    .event-type-badge { display: none; }
    .other-grid { grid-template-columns: 1fr; }
    .festival-card { flex-direction: column; align-items: flex-start; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .series-details { flex-direction: column; }
  }
</style>
