rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public events — anyone can read, only server SDK can write ──
    match /events/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── Band applications — public can create (submit form), only server reads/writes ──
    match /band_applications/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Program submissions — public can create (submit form), only server reads/writes ──
    match /program_submissions/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Vendor applications — public can create (submit form), only server reads/writes ──
    match /vendor_applications/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Volunteer sign-ups — public can create (submit form), only server reads/writes ──
    match /volunteer_signups/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Art class submissions — public can create (submit form), only server reads/writes ──
    match /art_class_submissions/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Mailing list — public can create (subscribe), only server reads/updates/deletes ──
    match /mailingList/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Admin users — no client-side access at all ──
    match /admin_users/{doc} {
      allow read, write: if false;
    }

    // ── Artists — public read; artist owns their doc (matched by uid field) ──
    match /artists/{bandId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;

      match /tracks/{trackId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/artists/$(bandId)).data.uid;
      }
    }
  }
}
