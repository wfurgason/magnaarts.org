---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Magna Writing Conference 2026 — Free Mini Writing Conference"
  description="A free community writing conference at the Magna Library on April 25, 2026, 7–9 PM. Keynote by Jodi L. Milner. Workshops on story structure, character, world-building, and more. All levels welcome."
>
  <Header />

  <main>

    <!-- ── HERO ── -->
    <section class="wc-hero">
      <div class="wc-hero-img-wrap">
        <img
          src="/images/classes/writing-group.jpg"
          alt="Magna Writing Conference 2026"
          class="wc-hero-img"
        />
        <div class="wc-hero-overlay">
          <div class="container wc-hero-content">
            <span class="hero-badge">Free Event · April 25, 2026</span>
            <h1>Magna Writing<br />Conference 2026</h1>
            <p class="wc-hero-sub">The Fundamentals of Writing — A Free Mini Conference for Writers of All Levels</p>
            <div class="wc-hero-cta-row">
              <a href="https://slcls.libnet.info/event/15660911" target="_blank" rel="noopener noreferrer" class="btn btn-gold">
                Register Free (Optional) →
              </a>
              <a href="https://www.facebook.com/events/2226908281470642" target="_blank" rel="noopener noreferrer" class="btn btn-outline-white">
                Facebook Event →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── INTRO ── -->
    <section class="section wc-intro">
      <div class="container wc-intro-inner">
        <div class="wc-intro-text reveal">
          <div class="section-label">About the Conference</div>
          <h2>Every Writer Starts Somewhere</h2>
          <p>
            The Magna Writing Conference is a free, community-powered mini conference hosted by the
            Magna Library Writing Group and the Magna Library. Every writer starts somewhere — and
            every great story begins with the basics.
          </p>
          <p>
            <em>The Fundamentals of Writing</em> invites storytellers of all ages and experience levels
            to reconnect with the core elements that bring words to life. From crafting compelling
            characters to building scenes that breathe, we'll explore the timeless tools that shape
            every genre.
          </p>
          <p>
            Whether you're just beginning your writing journey or looking to sharpen your foundation,
            this conference offers inspiration, guidance, and a welcoming community to grow your voice.
            We even have a workshop just for teens.
          </p>
        </div>
        <div class="wc-details-card reveal">
          <h3>At a Glance</h3>
          <dl>
            <dt>Date</dt>
            <dd>Saturday, April 25, 2026</dd>
            <dt>Time</dt>
            <dd>7:00 – 9:00 PM</dd>
            <dt>Location</dt>
            <dd>
              <a
                href="https://www.google.com/maps/search/?api=1&query=Magna+Branch+Salt+Lake+County+Library+2675+S+8950+W+Magna+UT"
                target="_blank"
                rel="noopener noreferrer"
                class="map-link"
              >
                <svg width="11" height="14" viewBox="0 0 11 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M5.5 0C2.46 0 0 2.46 0 5.5c0 3.85 5.5 8.5 5.5 8.5S11 9.35 11 5.5C11 2.46 8.54 0 5.5 0zm0 7.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4z" fill="currentColor"/>
                </svg>
                Magna Library Meeting Room<br />
                <span style="font-size:13px; color:var(--muted);">2675 S 8950 W, Magna, UT</span>
              </a>
            </dd>
            <dt>Cost</dt>
            <dd><strong>Free</strong> — All levels welcome</dd>
            <dt>Registration</dt>
            <dd>Optional — walk-ins welcome</dd>
            <dt>Hosted by</dt>
            <dd>Magna Library Writing Group &amp; Magna Library</dd>
          </dl>
          <div class="wc-cta-stack">
            <a href="https://slcls.libnet.info/event/15660911" target="_blank" rel="noopener noreferrer" class="btn btn-teal">
              Register Free →
            </a>
            <a href="https://www.facebook.com/events/2226908281470642" target="_blank" rel="noopener noreferrer" class="btn btn-outline-navy">
              View on Facebook →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── KEYNOTE ── -->
    <section class="section section-cream wc-keynote">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-label">Keynote Speaker</div>
          <h2>Jodi L. Milner</h2>
        </div>
        <div class="keynote-inner">
          <div class="keynote-bio reveal">
            <div class="keynote-title-block">
              <span class="keynote-badge">Keynote</span>
              <h3>Rediscovering the Joy of Writing</h3>
            </div>
            <p>
              Rediscovering the Joy of Writing isn't about forcing inspiration or fixing your process.
              It's about learning to read your own joy like a map.
            </p>
            <p>
              In this session, writers will uncover how the books, shows, essays, and stories they
              return to again and again reveal their truest creative instincts. By reverse-engineering
              what you love to consume, you'll reclaim permission, clarity, and freedom at the page —
              and rediscover why writing ever mattered to you in the first place.
            </p>
            <div class="speaker-bio-card">
              <p>
                <strong>Jodi L. Milner</strong> is the author of the award-winning Shadow Barrier Trilogy
                and cohost of <em>Squirrel! The Podcast for Distracted Writers</em>. Alongside publishing
                fantasy novels and short stories, she teaches at writing conferences and mentors fellow
                authors. Her service within the writing community earned her the
                <strong>2025 League Volunteer of the Year Award</strong>, recognizing her dedication to
                helping others thrive in their creative journeys. Jodi lives in the mountains of Utah,
                where she balances writing, family, and the occasional crocheted dragon.
              </p>
              <a href="https://www.jodilmilner.com" target="_blank" rel="noopener noreferrer" class="speaker-link">
                JodiLMilner.com →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PRESENTERS ── -->
    <section class="section wc-presenters">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-label">Workshop Presenters</div>
          <h2>Learn from Local &amp; Regional Writers</h2>
        </div>
        <div class="presenters-grid">

          <div class="presenter-card reveal">
            <div class="presenter-name">Emily Robyn Clark</div>
            <div class="presenter-session">Through the Camera's Eye: Visual Storytelling for Screenwriters</div>
            <p class="presenter-bio">
              Emily Robyn Clark is an award-winning poet and filmmaker and the author of
              <em>Morning Comes Roaring Down the Mountain</em> (2025) and <em>Art Triumphant</em> (2017).
              Her intro workshop bridges visual and written storytelling.
            </p>
          </div>

          <div class="presenter-card reveal">
            <div class="presenter-name">Johnny Worthen</div>
            <div class="presenter-session">Basic Story Structure</div>
            <p class="presenter-bio">
              Johnny Worthen is an award-winning, multiple-genre author trained in literary criticism
              and cultural studies. He writes upmarket fiction, mentors other writers, and teaches at
              the University of Utah.
            </p>
          </div>

          <div class="presenter-card reveal">
            <div class="presenter-name">Craig Kingsman</div>
            <div class="presenter-session">Plotting: The Secret Engine of Great Fiction</div>
            <p class="presenter-bio">
              Magna Library Writing Group member and presenter. Learn how plot drives story and
              keeps readers turning pages.
            </p>
          </div>

          <div class="presenter-card reveal">
            <div class="presenter-name">Alisha Golsan &amp; Heather Goslan</div>
            <div class="presenter-session">World Building</div>
            <p class="presenter-bio">
              Magna Library Writing Group presenters exploring the craft of building believable,
              immersive worlds across all genres.
            </p>
          </div>

          <div class="presenter-card reveal">
            <div class="presenter-name">Brittany Wardle-Ortega &amp; Ray Sostre</div>
            <div class="presenter-session">Character Development</div>
            <p class="presenter-bio">
              Discover how to craft interesting characters with depth and authenticity. A Fundamentals
              of Writing workshop from Magna Library Writing Group members.
            </p>
          </div>

          <div class="presenter-card presenter-card--teen reveal">
            <div class="presenter-teen-badge">For Teens</div>
            <div class="presenter-name">Lilly Jones &amp; Parker Lee</div>
            <div class="presenter-session">Focusing on Finishing a Draft</div>
            <p class="presenter-bio">
              A workshop designed especially for teen writers. Get the tools and encouragement you
              need to take your story from idea to finished draft.
            </p>
          </div>

        </div>
        <p class="presenters-note reveal">More information on individual sessions coming soon.</p>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="wc-cta-banner">
      <div class="container wc-cta-inner reveal">
        <div>
          <h2>Come Write With Us</h2>
          <p>
            The Magna Writing Conference is free, community-powered, and open to everyone — from
            first-time writers to seasoned authors. Bring a notebook, bring a friend, and come ready
            to be inspired.
          </p>
          <p class="wc-cta-detail">📅 Saturday, April 25, 2026 · 7:00–9:00 PM · Magna Library</p>
        </div>
        <div class="wc-cta-buttons">
          <a href="https://slcls.libnet.info/event/15660911" target="_blank" rel="noopener noreferrer" class="btn btn-gold btn-lg">
            Register Free →
          </a>
          <a href="/programs#writing-group" class="btn btn-outline-white">
            About The Writing Group →
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  /* ── HERO ── */
  .wc-hero { position: relative; width: 100%; }

  .wc-hero-img-wrap {
    position: relative;
    width: 100%;
    max-height: 560px;
    overflow: hidden;
  }

  .wc-hero-img {
    width: 100%;
    max-height: 560px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .wc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 15, 40, 0.45) 0%,
      rgba(10, 15, 40, 0.2) 30%,
      rgba(10, 15, 40, 0.82) 100%
    );
    display: flex;
    align-items: flex-end;
  }

  .wc-hero-content {
    color: var(--white);
    padding-bottom: 52px;
    padding-top: 32px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(14, 138, 138, 0.28);
    border: 1px solid rgba(14, 138, 138, 0.6);
    color: #7ef0f0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .wc-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    line-height: 1.05;
    text-shadow: 0 2px 14px rgba(0,0,0,0.6);
    margin-bottom: 12px;
  }

  .wc-hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.82);
    max-width: 540px;
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .wc-hero-cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── BUTTONS ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 24px;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    border: 2px solid transparent;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn-gold {
    background: var(--gold);
    color: var(--navy-dk);
    border-color: var(--gold);
  }
  .btn-gold:hover { background: var(--gold-lt); border-color: var(--gold-lt); transform: translateY(-1px); }

  .btn-teal {
    background: var(--teal);
    color: var(--white);
    border-color: var(--teal);
  }
  .btn-teal:hover { background: #0a7070; border-color: #0a7070; transform: translateY(-1px); }

  .btn-outline-white {
    background: transparent;
    color: var(--white);
    border-color: rgba(255,255,255,0.55);
  }
  .btn-outline-white:hover { border-color: var(--white); background: rgba(255,255,255,0.1); }

  .btn-outline-navy {
    background: transparent;
    color: var(--navy);
    border-color: var(--navy);
  }
  .btn-outline-navy:hover { background: var(--navy); color: var(--white); }

  .btn-lg { font-size: 16px; padding: 14px 32px; }

  /* ── INTRO ── */
  .wc-intro-inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 56px;
    align-items: start;
  }

  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 12px;
  }

  .wc-intro-text h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 900;
    color: var(--navy);
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .wc-intro-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  /* Details card */
  .wc-details-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--teal);
    border-radius: var(--radius);
    padding: 28px 24px;
    box-shadow: var(--shadow-card);
  }

  .wc-details-card h3 {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 18px;
  }

  .wc-details-card dl {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 10px 14px;
    font-size: 14px;
    margin-bottom: 24px;
  }

  .wc-details-card dt {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    align-self: start;
    padding-top: 1px;
  }

  .wc-details-card dd { color: var(--navy); line-height: 1.5; }

  .wc-cta-stack { display: flex; flex-direction: column; gap: 10px; }
  .wc-cta-stack .btn { justify-content: center; }

  /* Map link */
  .map-link {
    display: inline-flex;
    align-items: flex-start;
    gap: 5px;
    color: var(--navy);
    text-decoration: none;
    font-size: 14px;
    border-bottom: 1.5px dashed var(--teal);
    padding-bottom: 1px;
    line-height: 1.5;
    transition: color 0.15s;
  }
  .map-link svg { margin-top: 3px; flex-shrink: 0; color: var(--teal); }
  .map-link:hover { color: var(--teal); }

  /* ── KEYNOTE ── */
  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 900;
    color: var(--navy);
    line-height: 1.15;
  }

  .keynote-inner {
    max-width: 780px;
    margin: 0 auto;
  }

  .keynote-title-block {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .keynote-badge {
    display: inline-block;
    background: var(--teal);
    color: var(--white);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    flex-shrink: 0;
  }

  .keynote-bio h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    color: var(--navy);
    margin: 0;
  }

  .keynote-bio p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .speaker-bio-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-left: 3px solid var(--teal);
    border-radius: var(--radius-sm);
    padding: 20px 24px;
    margin-top: 24px;
  }

  .speaker-bio-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .speaker-link {
    font-size: 13px;
    font-weight: 700;
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .speaker-link:hover { color: #0a7070; }

  /* ── PRESENTERS ── */
  .presenters-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }

  .presenter-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--teal);
    border-radius: var(--radius);
    padding: 24px 20px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }

  .presenter-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }

  .presenter-card--teen { border-top-color: var(--gold); }

  .presenter-teen-badge {
    position: absolute;
    top: -1px;
    right: 16px;
    background: var(--gold);
    color: var(--navy-dk);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 0 0 6px 6px;
  }

  .presenter-name {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.2;
  }

  .presenter-session {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--teal);
    margin-bottom: 4px;
  }

  .presenter-card--teen .presenter-session { color: var(--amber); }

  .presenter-bio {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .presenters-note {
    text-align: center;
    font-size: 14px;
    color: var(--muted);
    font-style: italic;
  }

  /* ── CTA BANNER ── */
  .wc-cta-banner {
    background: var(--navy-dk);
    color: var(--white);
    padding: 72px 0;
  }

  .wc-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .wc-cta-inner h2 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 900;
    margin-bottom: 12px;
  }

  .wc-cta-inner p {
    font-size: 16px;
    color: rgba(255,255,255,0.72);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: 10px;
  }

  .wc-cta-detail {
    font-size: 14px !important;
    color: #7ef0f0 !important;
    letter-spacing: 0.02em;
    font-style: normal;
  }

  .wc-cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-shrink: 0;
  }

  /* ── SECTION CREAM ── */
  .section-cream { background: var(--cream); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .wc-intro-inner { grid-template-columns: 1fr; }
    .wc-details-card { max-width: 480px; }
    .presenters-grid { grid-template-columns: repeat(2, 1fr); }
    .wc-cta-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 600px) {
    .presenters-grid { grid-template-columns: 1fr; }
    .wc-hero-img { max-height: 420px; }
    .wc-hero-content { padding-bottom: 36px; }
    .wc-cta-buttons { width: 100%; }
    .wc-cta-buttons .btn { justify-content: center; }
  }
</style>
