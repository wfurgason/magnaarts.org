---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';

const user = Astro.locals.user;

const statusOptions: Record<string, { value: string; label: string }[]> = {
  approved:      [{ value: 'good_standing', label: '⭐ Good Standing' }, { value: 'rejected', label: 'Reject' }],
  assigned:      [{ value: 'good_standing', label: '⭐ Good Standing' }, { value: 'rejected', label: 'Reject' }],
  published:     [{ value: 'good_standing', label: '⭐ Good Standing' }, { value: 'rejected', label: 'Reject' }],
  good_standing: [{ value: 'approved', label: 'Remove Good Standing' }, { value: 'rejected', label: 'Reject' }],
  rejected:      [{ value: 'approved', label: 'Approve' }],
};
const filterParam = Astro.url.searchParams.get('filter') || 'all';

// Load band applications
const snap = await adminDb.collection('band_applications')
  .orderBy('submitted_at', 'desc')
  .get();

type Band = {
  id: string;
  band_name: string;
  genre: string;
  contact_name: string;
  contact_email: string;
  contact_phone: string;
  bio: string;
  music_link: string;
  website: string;
  promo_photo_url: string;
  tech_rider_url: string;
  set_length: string;
  member_count: string | number;
  available_dates: string[];   // new checkbox array
  availability: string;        // legacy text field (if any old submissions)
  performed_before: boolean | string;
  additional_notes: string;
  status: string;
  assignedShellId?: string;
  assignedDate?: string;
  submittedAt?: any;
};

let bands = snap.docs.map(d => ({ ...d.data(), id: d.id })) as Band[];

// Available filters
const filters = ['all', 'pending', 'approved', 'assigned', 'good_standing', 'rejected', 'published'];

if (filterParam !== 'all') {
  bands = bands.filter(b => (b.status || 'pending') === filterParam);
}

// Load available event shells for the assignment dropdown
// Show 'shell' status (unassigned) so board can pick a date
const shellsSnap = await adminDb.collection('park_events')
  .where('status', '==', 'shell')
  .orderBy('date', 'asc')
  .get();

const availableShells = shellsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
---

<AdminLayout title="Band Applications" user={user}>
  <div class="page-header">
    <h1>Band Applications</h1>
    <div class="filter-tabs">
      {filters.map(f => (
        <a
          href={`/admin/bands${f === 'all' ? '' : `?filter=${f}`}`}
          class:list={['filter-tab', { active: filterParam === f }]}
        >
          {f === 'good_standing' ? '⭐ Good Standing' : f.charAt(0).toUpperCase() + f.slice(1)}
        </a>
      ))}
    </div>
  </div>

  {bands.length === 0 ? (
    <div class="empty-state">
      <p>No applications matching this filter.</p>
    </div>
  ) : (
    <div class="submission-list">
      {bands.map(band => (
        <div class="submission-card" id={band.id}>
          <div class="submission-header">
            <div class="submission-title-group">
              {band.promo_photo_url && (
                <img src={band.promo_photo_url} alt={band.band_name} class="submission-photo" />
              )}
              <div>
                <h2 class="submission-name">{band.band_name}</h2>
                <span class="submission-meta">{band.genre} · {band.member_count} members · {band.set_length} set</span>
              </div>
            </div>
            <span class={`badge badge-${band.status || 'pending'}`}>{band.status || 'pending'}</span>
          </div>

          <div class="submission-body">
            <div class="detail-grid">
              <div>
                <div class="detail-label">Contact</div>
                <div>{band.contact_name}</div>
                <div><a href={`mailto:${band.contact_email}`}>{band.contact_email}</a></div>
                <div>{band.contact_phone}</div>
              </div>
              <div>
                <div class="detail-label">Available Dates</div>
                {band.available_dates && band.available_dates.length > 0 ? (
                  <div class="date-chips">
                    {band.available_dates.map(d => {
                      const dt = new Date(d + 'T12:00:00');
                      const label = dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                      return <span class="date-chip">{label}</span>;
                    })}
                  </div>
                ) : (
                  <div class="muted">{band.availability || '—'}</div>
                )}
              </div>
              <div>
                <div class="detail-label">Performed Before?</div>
                <div>{band.performed_before ? 'Yes' : 'No'}</div>
              </div>
              <div>
                <div class="detail-label">Links</div>
                {band.music_link && <div><a href={band.music_link} target="_blank" rel="noopener">Music ↗</a></div>}
                {band.website && <div><a href={band.website} target="_blank" rel="noopener">Website ↗</a></div>}
                {band.tech_rider_url && <div><a href={band.tech_rider_url} target="_blank" rel="noopener">Tech Rider ↗</a></div>}
              </div>
            </div>

            {band.bio && (
              <div class="detail-bio">
                <div class="detail-label">Bio</div>
                <p>{band.bio}</p>
              </div>
            )}
            {band.additional_notes && (
              <div class="detail-bio">
                <div class="detail-label">Additional Notes</div>
                <p>{band.additional_notes}</p>
              </div>
            )}

            {/* Good Standing notice */}
            {band.status === 'good_standing' && (
              <div class="good-standing-notice">
                <span>⭐</span>
                <span>This band is in <strong>Good Standing</strong> — reliable and welcome back for future seasons.</span>
              </div>
            )}

            {/* Show assigned date if already assigned */}
            {band.assignedDate && (
              <div class="assigned-notice">
                <span class="assigned-icon">📅</span>
                <span>Assigned to <strong>{new Date(band.assignedDate + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</strong></span>
                <button
                  class="btn-link unassign-btn"
                  data-shell-id={band.assignedShellId}
                  data-band-name={band.band_name}
                >
                  Remove assignment
                </button>
              </div>
            )}
          </div>

          <div class="submission-actions">
            {/* Approve / Reject for pending bands */}
            {(band.status === 'pending') && (
              <>
                <button class="btn btn-success" data-action="approve" data-id={band.id} data-collection="band_applications">
                  Approve
                </button>
                <button
                  class="btn btn-primary assign-btn"
                  data-band-id={band.id}
                  data-band-name={band.band_name}
                  data-available={JSON.stringify(band.available_dates || [])}
                  data-auto-approve="true"
                >
                  Approve &amp; Assign Date →
                </button>
                <button class="btn btn-danger" data-action="reject" data-id={band.id} data-collection="band_applications">
                  Reject
                </button>
              </>
            )}

            {/* Approved: can still reject OR assign to a date */}
            {(band.status === 'approved') && (
              <>
                <button
                  class="btn btn-primary assign-btn"
                  data-band-id={band.id}
                  data-band-name={band.band_name}
                  data-available={JSON.stringify(band.available_dates || [])}
                >
                  Assign to Date →
                </button>
                <button class="btn btn-danger" data-action="reject" data-id={band.id} data-collection="band_applications">
                  Reject
                </button>
              </>
            )}

            {/* Assigned: can unassign (reassign) */}
            {(band.status === 'assigned') && (
              <button
                class="btn btn-outline unassign-btn"
                data-shell-id={band.assignedShellId}
                data-band-name={band.band_name}
              >
                Reassign Date
              </button>
            )}

            {/* Good Standing: can reassign for a new season */}
            {(band.status === 'good_standing') && (
              <>
                <button
                  class="btn btn-primary assign-btn"
                  data-band-id={band.id}
                  data-band-name={band.band_name}
                  data-available={JSON.stringify(band.available_dates || [])}
                >
                  Assign to Date →
                </button>
              </>
            )}

            {/* Delete button — always available except published */}
            {(band.status !== 'published') && (
              <button
                class="btn btn-danger delete-btn"
                style="margin-left:auto"
                data-band-id={band.id}
                data-band-name={band.band_name}
                data-assigned-shell={band.assignedShellId || ''}
              >
                Delete
              </button>
            )}

            {/* Status change dropdown — shown for all actionable statuses except pending */}
            {statusOptions[band.status] && (
              <select
                class="status-select"
                data-band-id={band.id}
                data-band-name={band.band_name}
              >
                <option value="" disabled selected>Change status…</option>
                {statusOptions[band.status].map(opt => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
            )}
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- ── ASSIGN TO DATE MODAL ───────────────────────────────────────── -->
  <div id="assign-modal" class="modal-backdrop" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <h2>Assign to Date</h2>
        <button id="assign-close" class="modal-close" aria-label="Close">✕</button>
      </div>

      <p class="modal-sub" id="assign-sub">Select a date for <strong id="assign-band-name"></strong>.</p>

      <div id="assign-shells">
        {availableShells.length === 0 ? (
          <p class="empty-shells">No open event dates available. Generate event shells in <a href="/admin/seasons">Season Setup</a> first.</p>
        ) : (
          <div class="shell-list">
            {availableShells.map(shell => (
              <label class="shell-option" data-date={shell.date}>
                <input type="radio" name="shell" value={shell.id} data-display={shell.displayDate} />
                <div class="shell-option-body">
                  <span class="shell-date">{shell.displayDate}</span>
                  <span class="shell-time">{shell.startTime} · {shell.venue}</span>
                </div>
              </label>
            ))}
          </div>
        )}
      </div>

      <div id="assign-match-warning" class="match-warning" hidden>
        ⚠️ This band did not list this date as available. You can still assign them — just confirm with them first.
      </div>

      <div id="assign-error" class="error-msg" hidden></div>

      <div class="modal-actions">
        <button type="button" id="assign-cancel" class="btn btn-ghost">Cancel</button>
        <button type="button" id="assign-submit" class="btn btn-primary" disabled>
          Assign Date →
        </button>
      </div>
    </div>
  </div>

  <script src="/admin-bands.js" defer></script>

  <style>
    .date-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
    .date-chip {
      display: inline-block;
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      color: #1d4ed8;
      font-size: 12px;
      font-weight: 600;
      padding: 3px 9px;
      border-radius: 100px;
    }
    .muted { color: var(--muted, #5a5a7a); font-size: 14px; }
    .assigned-notice {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      color: #166534;
      margin-top: 12px;
    }
    .assigned-icon { font-size: 16px; }
    .btn-link {
      background: none;
      border: none;
      color: var(--red, #b52626);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      padding: 0;
      margin-left: auto;
      text-decoration: underline;
    }
    .btn-outline {
      background: transparent;
      border: 1.5px solid var(--border, #e5e5e5);
      color: var(--navy, #1a2456);
    }

    /* Assign modal shell list */
    .shell-list { display: flex; flex-direction: column; gap: 8px; margin: 16px 0; }
    .shell-option {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 16px;
      border: 1.5px solid var(--border, #e5e5e5);
      border-radius: 8px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .shell-option:has(input:checked) {
      border-color: var(--blue, #2563b0);
      background: #eff6ff;
    }
    .shell-option input[type="radio"] {
      width: 16px;
      height: 16px;
      accent-color: var(--blue, #2563b0);
      flex-shrink: 0;
      cursor: pointer;
    }
    .shell-option-body { display: flex; flex-direction: column; gap: 2px; }
    .shell-date { font-size: 14px; font-weight: 600; color: var(--navy, #1a2456); }
    .shell-time { font-size: 12px; color: var(--muted, #5a5a7a); }
    .empty-shells { font-size: 14px; color: var(--muted, #5a5a7a); padding: 16px 0; }
    .empty-shells a { color: var(--blue, #2563b0); }

    .match-warning {
      background: #fffbeb;
      border: 1px solid #fde68a;
      color: #92400e;
      font-size: 13px;
      font-weight: 500;
      padding: 10px 14px;
      border-radius: 8px;
      margin-bottom: 8px;
    }
    .modal-sub { font-size: 14px; color: var(--muted, #5a5a7a); margin: 4px 0 0; }

    .good-standing-notice {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      color: #78350f;
      margin-top: 12px;
    }

    .badge-good_standing { background: #fef9c3; color: #713f12; }

    .btn-gold {
      background: var(--gold, #e8a020);
      color: #fff;
      border: none;
    }
    .btn-gold:hover { background: var(--gold-lt, #f5b942); }

    .status-select {
      height: 36px;
      padding: 0 10px;
      border: 1.5px solid var(--border, #e5e5e5);
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      background: #fff;
      color: var(--navy, #1a2456);
      cursor: pointer;
      margin-left: auto;
    }
    .status-select:focus { outline: none; border-color: var(--blue, #2563b0); }
  </style>

</AdminLayout>
