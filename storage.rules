rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Band promo photos & tech riders — public upload (call-for-bands form) ──
    match /band-promos/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    match /band-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Band tech riders — public upload (call-for-bands form) ──
    match /band-tech-riders/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Open Mic event images — public upload (planning page) ──
    match /open-mic-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Group Art Night event images — public upload (planning page) ──
    match /art-night-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Music & Movies in the Park event images — public upload (planning page) ──
    match /mmpark-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Art class presenter images — public upload (teach-an-art-class form) ──
    match /art-class-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Vendor profile images — public upload (vendor-application form) ──
    match /vendor-profiles/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Program proposal images — public upload (propose-a-program form) ──
    match /proposal-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Program proposal images — public upload (propose-a-program form) ──
    match /proposal-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── Writing Group event images — admin upload (planning page) ──
    match /writing-group-images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ── All other paths — deny by default ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
