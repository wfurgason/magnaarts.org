---
import '../../styles/admin.css';

const firebaseConfig = {
  apiKey:     import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:  import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Set Up Two-Factor Authentication — Magna Arts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
  <!-- QR code generation (client-side, no secrets leave the browser) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <style>
    .enroll-steps {
      margin: 1.25rem 0 0;
    }
    .enroll-step {
      margin-bottom: 1.5rem;
    }
    .enroll-step p {
      margin: 0 0 0.5rem;
      font-size: 0.9rem;
      color: #444;
      line-height: 1.5;
    }
    .qr-wrapper {
      display: flex;
      justify-content: center;
      margin: 0.75rem 0;
    }
    .qr-wrapper img {
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 6px;
      background: #fff;
    }
    .manual-key {
      font-family: monospace;
      font-size: 0.8rem;
      background: #f4f4f4;
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 0.4rem 0.6rem;
      word-break: break-all;
      margin-top: 0.25rem;
    }
    .loading-msg {
      text-align: center;
      color: #888;
      font-size: 0.9rem;
      padding: 1.5rem 0;
    }
  </style>
</head>
<body class="admin-login-body">
  <div class="login-card">
    <div class="login-logo">
      <img src="/images/ArtsCouncil_logo.png" alt="Magna Arts Council" />
      <span class="login-logo-text">Magna Arts Council</span>
      <span class="login-logo-sub">Board Portal — 2FA Setup</span>
    </div>

    <!-- Loading state while we fetch the QR from the server -->
    <div id="loading-state">
      <p class="loading-msg">Setting up your authenticator…</p>
    </div>

    <!-- Main enrollment UI (shown after QR is fetched) -->
    <div id="enroll-ui" hidden>
      <div class="enroll-steps">
        <div class="enroll-step">
          <p><strong>Step 1.</strong> Open your authenticator app (Google Authenticator, Authy, 1Password, etc.) and scan this QR code.</p>
          <div class="qr-wrapper">
            <div id="qr-container"></div>
          </div>
          <p style="font-size:0.8rem;color:#888;margin:0;">Can't scan? Enter this key manually:</p>
          <div class="manual-key" id="manual-key"></div>
        </div>
        <div class="enroll-step">
          <p><strong>Step 2.</strong> Enter the 6-digit code from your app to confirm setup.</p>
          <div class="field-group">
            <label for="totp-code">Authenticator Code</label>
            <input
              type="text"
              id="totp-code"
              inputmode="numeric"
              autocomplete="one-time-code"
              maxlength="6"
              placeholder="000000"
            />
          </div>
          <div id="enroll-error" class="error-msg" hidden></div>
          <button type="button" class="btn btn-primary btn-full" id="confirm-btn">
            Confirm &amp; Activate
          </button>
        </div>
      </div>
    </div>

    <!-- Error state if setup fails entirely -->
    <div id="error-state" hidden>
      <p class="mfa-hint" style="text-align:center;color:#c00;">
        Could not start 2FA setup. Please sign in again and try once more.
      </p>
      <a href="/admin" class="btn btn-ghost btn-full">Back to Sign In</a>
    </div>
  </div>

  <script type="module" define:vars={{ firebaseConfig }}>
    import { initializeApp }          from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
    import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-auth.js';

    const auth = getAuth(initializeApp(firebaseConfig));

    const loadingState = document.getElementById('loading-state');
    const enrollUi     = document.getElementById('enroll-ui');
    const errorState   = document.getElementById('error-state');
    // qr-img removed; QR is now rendered into #qr-container by qrcodejs
    const manualKey    = document.getElementById('manual-key');
    const confirmBtn   = document.getElementById('confirm-btn');
    const enrollError  = document.getElementById('enroll-error');
    const totpInput    = document.getElementById('totp-code');

    function showError(msg) {
      enrollError.textContent = msg;
      enrollError.hidden = false;
    }

    function setLoading(loading) {
      confirmBtn.disabled    = loading;
      confirmBtn.textContent = loading ? 'Please wait…' : 'Confirm & Activate';
    }

    // Extract the base32 secret from an otpauth:// URI for manual entry display
    function extractSecret(uri) {
      try {
        const params = new URL(uri).searchParams;
        return params.get('secret') ?? '';
      } catch {
        return '';
      }
    }

    onAuthStateChanged(auth, async (user) => {
      // Not signed in — send back to login
      if (!user) {
        window.location.replace('/admin');
        return;
      }

      // Already enrolled — send to dashboard
      const idToken = await user.getIdToken();
      const statusRes = await fetch('/api/admin/totp-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idToken }),
      });
      if (statusRes.ok) {
        const { enrolled } = await statusRes.json();
        if (enrolled) {
          window.location.replace('/admin/dashboard');
          return;
        }
      }

      // Request a new TOTP secret and QR code from the server
      try {
        const enrollRes = await fetch('/api/admin/totp-enroll', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken }),
        });

        if (!enrollRes.ok) throw new Error('Enroll request failed');

        const { otpauthUri } = await enrollRes.json();

        // Generate QR code into #qr-container using qrcodejs (loaded from CDN)
        new window.QRCode(document.getElementById('qr-container'), {
          text:       otpauthUri,
          width:      240,
          height:     240,
          colorDark:  '#000000',
          colorLight: '#ffffff',
        });

        manualKey.textContent = extractSecret(otpauthUri);

        loadingState.hidden = true;
        enrollUi.hidden     = false;
      } catch {
        loadingState.hidden = true;
        errorState.hidden   = false;
      }

      // Confirm enrollment when the user submits their code
      confirmBtn.addEventListener('click', async () => {
        enrollError.hidden = true;
        const code = totpInput.value.trim();

        if (!/^\d{6}$/.test(code)) {
          showError('Please enter a 6-digit code.');
          return;
        }

        setLoading(true);

        try {
          // Re-fetch the token in case it has rotated
          const freshToken = await user.getIdToken();
          const verifyRes  = await fetch('/api/admin/totp-verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idToken: freshToken, code }),
          });

          if (verifyRes.ok) {
            window.location.href = '/admin/dashboard';
          } else {
            const { error } = await verifyRes.json();
            showError(error ?? 'Incorrect code. Try again.');
            setLoading(false);
          }
        } catch {
          showError('Something went wrong. Please try again.');
          setLoading(false);
        }
      });

      // Allow submitting with Enter key
      totpInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') confirmBtn.click();
      });
    });
  </script>
</body>
</html>
