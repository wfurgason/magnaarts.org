---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const volunteerRoles = [
  { icon: '🔧', title: 'Setup & Teardown', body: 'Help us set up stages, seating, and equipment before events and clean up after.' },
  { icon: '👋', title: 'Greeter / Info Booth', body: 'Welcome attendees, answer questions, and hand out programs at the event entrance.' },
  { icon: '🎬', title: 'Screen & Sound Crew', body: 'Assist with operating the 35-ft inflatable movie screen and sound equipment.' },
  { icon: '🍕', title: 'Vendor Coordination', body: 'Help coordinate food and art vendors at the Arts Festival and other events.' },
  { icon: '📸', title: 'Photography', body: 'Capture photos and video of events for social media and grant documentation.' },
  { icon: '📋', title: 'Event Administration', body: 'Help with sign-in sheets, attendance tracking, and on-site logistics.' },
];
---

<BaseLayout
  title="Get Involved — Magna Arts Council"
  description="Volunteer, present a program, or join the board. There are many ways to be part of the Magna Arts Council."
>
  <Header />

  <main>

    <!-- ── PAGE HERO ── -->
    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">Get Involved</div>
        <h1>There's a Place for You Here</h1>
        <p class="hero-sub">
          The Magna Arts Council runs entirely on community support —
          volunteers, presenters, and board members who care about arts in Magna.
        </p>
      </div>
    </section>

    <!-- ── 4 WAYS ── -->
    <section class="section ways-section">
      <div class="container">
        <h2 class="section-title reveal">Four Ways to Participate</h2>
        <div class="ways-grid">

          <div class="way-card way-attend reveal">
            <div class="way-num">01</div>
            <span class="way-icon">👥</span>
            <h3>Attend</h3>
            <p>Every event is free and open to all. Come enjoy concerts, movies, open mic nights, art classes, and our annual Arts Festival.</p>
            <a href="/events" class="way-link">See upcoming events →</a>
          </div>

          <div class="way-card way-volunteer reveal" id="volunteer">
            <div class="way-num">02</div>
            <span class="way-icon">🙌</span>
            <h3>Volunteer</h3>
            <p>We need crew before, during, and after every event. No experience needed — just a willingness to help your community.</p>
            <a href="https://forms.gle/hE4f35TjrLKfPH479" target="_blank" rel="noopener" class="way-link">Sign up to volunteer →</a>
          </div>

          <div class="way-card way-present reveal">
            <div class="way-num">03</div>
            <span class="way-icon">💡</span>
            <h3>Present</h3>
            <p>Have an idea for a class, concert, or community event? Submit a proposal and we'll review it at our next board meeting.</p>
            <a href="/present" class="way-link">See ways to present →</a>
          </div>

          <div class="way-card way-board reveal" id="board">
            <div class="way-num">04</div>
            <span class="way-icon">⭐</span>
            <h3>Join the Board</h3>
            <p>Help shape the future of arts in Magna. Board members attend monthly meetings, sponsor programs, and guide our mission.</p>
            <a href="/contact" class="way-link">Get in touch →</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ── VOLUNTEER ROLES ── -->
    <section class="section volunteer-section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">Volunteer Opportunities</h2>
          <p class="section-sub">Here are some of the ways volunteers help make our events happen.</p>
        </div>
        <div class="roles-grid">
          {volunteerRoles.map((r, i) => (
            <div class="role-card reveal" style={`transition-delay:${i * 0.07}s`}>
              <span class="role-icon">{r.icon}</span>
              <h3>{r.title}</h3>
              <p>{r.body}</p>
            </div>
          ))}
        </div>
        <div class="volunteer-cta reveal">
          <a href="https://forms.gle/hE4f35TjrLKfPH479" target="_blank" rel="noopener" class="btn btn-gold">
            Sign Up to Volunteer →
          </a>
        </div>
      </div>
    </section>

    <!-- ── PROPOSE ── -->
    <section class="propose-section reveal">
      <div class="container propose-inner">
        <div class="propose-text">
          <div class="hero-badge">Presenters</div>
          <h2>Have an Idea? Propose It.</h2>
          <p>
            The Arts Council is always looking for local performers, teachers, and organizers
            who want to bring something new to Magna. Whether it's a concert, a film screening,
            an art class, or something we've never done before — we want to hear it.
          </p>
          <p>
            All proposals are reviewed by the full board. Accepted programs are assigned a board
            sponsor who works alongside you through planning, promotion, and day-of logistics.
          </p>
          <a href="/propose" class="btn btn-gold" style="margin-top: 8px;">Submit a Proposal →</a>
        </div>
        <div class="propose-steps">
          <div class="step">
            <div class="step-num">1</div>
            <div>
              <strong>Submit</strong>
              <p>Fill out the proposal form with your idea, intended audience, and needs.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div>
              <strong>Review</strong>
              <p>The board reviews your proposal at the next monthly meeting and votes.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div>
              <strong>Plan</strong>
              <p>A board sponsor is assigned to help you plan, promote, and run your event.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num">4</div>
            <div>
              <strong>Present</strong>
              <p>Your event goes live — free and open to the Magna community.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-banner">
      <div class="container cta-inner reveal">
        <div>
          <h2>Questions?</h2>
          <p>Reach out any time — we'd love to talk about how you can be part of what we're building in Magna.</p>
        </div>
        <a href="/contact" class="btn btn-gold">Contact Us →</a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0 64px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.18);
    border: 1px solid rgba(232, 160, 32, 0.45);
    color: var(--gold-lt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 18px;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── WAYS ── */
  .ways-section { background: var(--white); }

  .section-title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 32px;
  }

  .ways-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }

  .way-card {
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 32px 24px 28px;
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: box-shadow 0.22s, transform 0.22s;
  }

  .way-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }

  .way-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
  }

  .way-attend::before   { background: var(--blue); }
  .way-volunteer::before { background: var(--green); }
  .way-present::before  { background: var(--red); }
  .way-board::before    { background: var(--amber); }

  .way-num {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--border);
  }

  .way-icon { font-size: 30px; }

  .way-card h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--navy);
  }

  .way-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .way-link {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--blue);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.2s;
    margin-top: auto;
  }

  .way-volunteer .way-link { color: var(--green); }
  .way-present .way-link   { color: var(--red); }
  .way-board .way-link     { color: var(--amber); }
  .way-link:hover { gap: 8px; }

  /* ── VOLUNTEER ROLES ── */
  .volunteer-section { background: var(--cream); }

  .section-header { margin-bottom: 40px; }
  .section-sub { font-size: 16px; color: var(--muted); margin-top: 8px; }

  .roles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .role-card {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 24px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .role-icon { font-size: 26px; }

  .role-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
  }

  .role-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  .volunteer-cta {
    margin-top: 40px;
    text-align: center;
  }

  /* ── PROPOSE ── */
  .propose-section {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0;
  }

  .propose-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .propose-text .hero-badge {
    background: rgba(232, 160, 32, 0.18);
    border: 1px solid rgba(232, 160, 32, 0.45);
    color: var(--gold-lt);
    margin-bottom: 16px;
  }

  .propose-text h2 {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .propose-text p {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  .propose-steps {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--navy-dk);
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step strong {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }

  .step p {
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTA ── */
  .cta-banner {
    background: var(--navy-dk);
    color: var(--white);
    padding: 56px 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .cta-inner h2 {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .cta-inner p {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    max-width: 520px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 960px) {
    .ways-grid    { grid-template-columns: 1fr 1fr; }
    .propose-inner { grid-template-columns: 1fr; gap: 40px; }
    .cta-inner    { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 640px) {
    .ways-grid  { grid-template-columns: 1fr; }
    .roles-grid { grid-template-columns: 1fr; }
  }
</style>
