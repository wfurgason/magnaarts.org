---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';
import { FieldValue } from 'firebase-admin/firestore';

const user = Astro.locals.user;

const firebaseConfig = {
  apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
  storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
  appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID,
};

// ── Load existing shells ──────────────────────────────────────────────────
const [seasonsSnap, shellsSnap, openMicSnap, artNightSnap, festivalSnap, approvedBandsSnap, vendorSnap, artClassSnap] = await Promise.all([
  adminDb.collection('park_seasons').orderBy('year', 'desc').get(),
  adminDb.collection('park_events').orderBy('date', 'asc').get(),
  adminDb.collection('open_mic_events').orderBy('date', 'asc').get(),
  adminDb.collection('art_night_events').orderBy('date', 'asc').get(),
  adminDb.collection('festival_events').orderBy('date', 'asc').get(),
  adminDb.collection('band_applications').where('status', 'in', ['approved', 'waitlisted']).orderBy('band_name', 'asc').get(),
  adminDb.collection('vendor_applications').where('status', 'in', ['approved', 'paid']).get(),
  adminDb.collection('art_class_submissions').where('status', 'in', ['pending', 'approved', 'contacted']).orderBy('submittedAt', 'desc').get(),
]);

const allShells         = shellsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const allOpenMicShells  = openMicSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const allArtNightShells = artNightSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const allFestivalShells = festivalSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const approvedBands     = approvedBandsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const approvedVendorCount  = vendorSnap.size;
const artClassSubmissions  = artClassSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];

// ── POST handling ─────────────────────────────────────────────────────────
let flashMsg  = '';
let flashType = '';

if (Astro.request.method === 'POST') {
  const form       = await Astro.request.formData();
  const action     = form.get('action')?.toString();

  // ── Create shells ───────────────────────────────────────────────────────
  if (action === 'create_season') {
    const year       = parseInt(form.get('year')?.toString() || '0');
    const venue      = form.get('venue')?.toString() || '';
    const address    = form.get('address')?.toString() || '';
    const start      = form.get('startTime')?.toString() || '7:00 PM';
    const datesRaw   = form.get('dates')?.toString() || '';
    const seriesType = form.get('seriesType')?.toString() || 'music_in_park';

    const dates = datesRaw.split('\n').map(d => d.trim()).filter(d => /^\d{4}-\d{2}-\d{2}$/.test(d));

    if (!year || dates.length === 0) {
      flashMsg  = 'Please enter a valid year and at least one date.';
      flashType = 'error';
    } else if (seriesType === 'open_mic') {
      const omTitle    = form.get('omTitle')?.toString() || 'Open Mic Night';
      const omImageUrl = form.get('omImageUrl')?.toString() || '';
      const omDesc     = form.get('omDescription')?.toString() || '';

      const existing      = await adminDb.collection('open_mic_events').where('season', '==', year).get();
      const existingDates = new Set(existing.docs.map(d => d.data().date));
      const batch = adminDb.batch();
      let created = 0;
      for (const date of dates) {
        if (existingDates.has(date)) continue;
        const ref     = adminDb.collection('open_mic_events').doc();
        const d       = new Date(date + 'T12:00:00');
        const display = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        batch.set(ref, {
          season: year, date, displayDate: display, startTime: start, venue, address,
          title: omTitle, imageUrl: omImageUrl, description: omDesc,
          eventType: 'open_mic', status: 'shell', createdAt: FieldValue.serverTimestamp(),
        });
        created++;
      }
      await batch.commit();
      flashMsg  = `Open Mic Night: ${created} new shell(s) created (${dates.length} dates total).`;
      flashType = 'success';

    } else if (seriesType === 'group_art_night') {
      const anTitle    = form.get('anTitle')?.toString() || 'Group Art Night';
      const anImageUrl = form.get('anImageUrl')?.toString() || '';
      const anDesc     = form.get('anDescription')?.toString() || '';

      const existing      = await adminDb.collection('art_night_events').where('season', '==', year).get();
      const existingDates = new Set(existing.docs.map(d => d.data().date));
      const batch = adminDb.batch();
      let created = 0;
      for (const date of dates) {
        if (existingDates.has(date)) continue;
        const ref     = adminDb.collection('art_night_events').doc();
        const d       = new Date(date + 'T12:00:00');
        const display = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        batch.set(ref, {
          season: year, date, displayDate: display, startTime: start, venue, address,
          title: anTitle, description: anDesc, imageUrl: anImageUrl,
          eventType: 'group_art_night', status: 'shell',
          presenterId: null, presenterName: null, presenterConfirmed: false,
          createdAt: FieldValue.serverTimestamp(),
        });
        created++;
      }
      await batch.commit();
      flashMsg  = `Group Art Night: ${created} new shell(s) created (${dates.length} dates total).`;
      flashType = 'success';

    } else if (seriesType === 'arts_festival') {
      const afTitle = form.get('afTitle')?.toString() || 'Magna Main Street Arts Festival';
      const afDesc  = form.get('afDescription')?.toString() || '';

      if (dates.length !== 1) {
        flashMsg  = 'Please select exactly one date for the Arts Festival.';
        flashType = 'error';
      } else {
        const date    = dates[0];
        const d       = new Date(date + 'T12:00:00');
        const display = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        // Use the year from the selected date
        const festYear = d.getFullYear();
        // Check for existing shell for this year
        const existing = await adminDb.collection('festival_events').where('season', '==', festYear).get();
        if (!existing.empty) {
          flashMsg  = `A festival shell for ${festYear} already exists. Delete it first to recreate.`;
          flashType = 'error';
        } else {
          const ref = adminDb.collection('festival_events').doc(`arts-festival-${festYear}`);
          await ref.set({
            season: festYear, date, displayDate: display, startTime: start,
            venue, address, title: afTitle, description: afDesc,
            eventType: 'arts_festival', status: 'shell',
            image: '/images/festival/mmsaf.png',
            createdAt: FieldValue.serverTimestamp(),
          });
          flashMsg  = `Arts Festival shell created for ${display}.`;
          flashType = 'success';
        }
      }

    } else {
      // Music & Movies in the Park
      await adminDb.collection('park_seasons').doc(String(year)).set({
        year, venue, address, startTime: start, dateCount: dates.length,
        createdAt: FieldValue.serverTimestamp(), createdBy: user?.email || 'admin',
      });
      const existing      = await adminDb.collection('park_events').where('season', '==', year).get();
      const existingDates = new Set(existing.docs.map(d => d.data().date));
      const batch = adminDb.batch();
      let created = 0;
      for (const date of dates) {
        if (existingDates.has(date)) continue;
        const ref     = adminDb.collection('park_events').doc();
        const d       = new Date(date + 'T12:00:00');
        const display = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        batch.set(ref, {
          season: year, date, displayDate: display, startTime: start, venue, address,
          eventType: 'music_movie_in_park', status: 'shell',
          bandId: null, bandName: null, bandConfirmed: false, movie: null, movieToken: null,
          createdAt: FieldValue.serverTimestamp(),
        });
        created++;
      }
      await batch.commit();
      flashMsg  = `Music & Movies in the Park: Season ${year} set up. ${created} new shell(s) created.`;
      flashType = 'success';
    }
  }

  // ── Delete a shell ──────────────────────────────────────────────────────
  if (action === 'delete_shell') {
    const shellId = form.get('shellId')?.toString();
    const col     = form.get('collection')?.toString() || 'park_events';
    if (shellId) {
      await adminDb.collection(col).doc(shellId).delete();
      flashMsg  = 'Event shell deleted.';
      flashType = 'success';
    }
  }

  // ── Assign a band to a festival slot ────────────────────────────────────
  if (action === 'assign_festival_band') {
    const shellId  = form.get('shellId')?.toString();
    const slot     = parseInt(form.get('slot')?.toString() || '0');
    const bandId   = form.get('bandId')?.toString();
    const bandName = form.get('bandName')?.toString();
    const slotTime = form.get('slotTime')?.toString() || '';
    if (shellId && slot && bandId) {
      const shellRef  = adminDb.collection('festival_events').doc(shellId);
      const shellSnap = await shellRef.get();
      const bands: any[] = shellSnap.data()?.bands || [
        { slot: 1, time: '', bandId: null, bandName: null, confirmed: false },
        { slot: 2, time: '', bandId: null, bandName: null, confirmed: false },
        { slot: 3, time: '', bandId: null, bandName: null, confirmed: false },
      ];
      const idx = bands.findIndex((b: any) => b.slot === slot);
      if (idx >= 0) {
        bands[idx] = { slot, time: slotTime, bandId, bandName, confirmed: false };
      } else {
        bands.push({ slot, time: slotTime, bandId, bandName, confirmed: false });
      }
      await shellRef.update({ bands, status: 'planning' });
      flashMsg  = `${bandName} assigned to Stage Slot ${slot}.`;
      flashType = 'success';
    }
  }

  // ── Unassign a band from a festival slot ───────────────────────────────
  if (action === 'unassign_festival_band') {
    const shellId = form.get('shellId')?.toString();
    const slot    = parseInt(form.get('slot')?.toString() || '0');
    if (shellId && slot) {
      const shellRef  = adminDb.collection('festival_events').doc(shellId);
      const shellSnap = await shellRef.get();
      const bands: any[] = (shellSnap.data()?.bands || []).map((b: any) =>
        b.slot === slot ? { slot, time: '', bandId: null, bandName: null, confirmed: false } : b
      );
      const allEmpty = bands.every((b: any) => !b.bandId);
      await shellRef.update({ bands, status: allEmpty ? 'shell' : 'planning' });
      flashMsg  = `Slot ${slot} cleared.`;
      flashType = 'success';
    }
  }

  // ── Confirm a festival band slot ───────────────────────────────────────
  if (action === 'confirm_festival_band') {
    const shellId = form.get('shellId')?.toString();
    const slot    = parseInt(form.get('slot')?.toString() || '0');
    if (shellId && slot) {
      const shellRef  = adminDb.collection('festival_events').doc(shellId);
      const shellSnap = await shellRef.get();
      const bands: any[] = (shellSnap.data()?.bands || []).map((b: any) =>
        b.slot === slot ? { ...b, confirmed: true } : b
      );
      const allConfirmed = bands.filter((b: any) => b.bandId).every((b: any) => b.confirmed);
      await shellRef.update({ bands, status: allConfirmed ? 'confirmed' : 'planning' });
      flashMsg  = `Slot ${slot} confirmed.`;
      flashType = 'success';
    }
  }

  // ── Assign an art-night presenter ────────────────────────────────────────
  if (action === 'assign_presenter') {
    const shellId       = form.get('shellId')?.toString();
    const presenterId   = form.get('presenterId')?.toString();
    const presenterName = form.get('presenterName')?.toString();
    if (shellId && presenterId) {
      await adminDb.collection('art_night_events').doc(shellId).update({
        presenterId,
        presenterName,
        presenterConfirmed: false,
        status: 'presenter_assigned',
      });
      flashMsg  = `${presenterName} assigned as presenter.`;
      flashType = 'success';
    }
  }

  // ── Unassign an art-night presenter ──────────────────────────────────────
  if (action === 'unassign_presenter') {
    const shellId = form.get('shellId')?.toString();
    if (shellId) {
      await adminDb.collection('art_night_events').doc(shellId).update({
        presenterId:        null,
        presenterName:      null,
        presenterConfirmed: false,
        status:             'shell',
      });
      flashMsg  = 'Presenter removed.';
      flashType = 'success';
    }
  }

  // ── Confirm an art-night presenter ───────────────────────────────────────
  if (action === 'confirm_presenter') {
    const shellId = form.get('shellId')?.toString();
    if (shellId) {
      await adminDb.collection('art_night_events').doc(shellId).update({
        presenterConfirmed: true,
        status:             'confirmed',
      });
      flashMsg  = 'Presenter confirmed.';
      flashType = 'success';
    }
  }

  // ── Edit a shell ────────────────────────────────────────────────────────
  if (action === 'update_shell') {
    const shellId   = form.get('shellId')?.toString();
    const venue     = form.get('venue')?.toString();
    const address   = form.get('address')?.toString();
    const startTime = form.get('startTime')?.toString();
    const col       = form.get('collection')?.toString() || 'park_events';
    if (shellId) {
      await adminDb.collection(col).doc(shellId).update({ venue, address, startTime });
      flashMsg  = 'Event shell updated.';
      flashType = 'success';
    }
  }

  return Astro.redirect('/admin/planning');
}

// ── Group shells by season year ───────────────────────────────────────────
const shellsBySeason: Record<number, any[]> = {};
for (const s of allShells) {
  if (!shellsBySeason[s.season]) shellsBySeason[s.season] = [];
  shellsBySeason[s.season].push(s);
}

const openMicBySeason: Record<number, any[]> = {};
for (const s of allOpenMicShells) {
  if (!openMicBySeason[s.season]) openMicBySeason[s.season] = [];
  openMicBySeason[s.season].push(s);
}

const artNightBySeason: Record<number, any[]> = {};
for (const s of allArtNightShells) {
  if (!artNightBySeason[s.season]) artNightBySeason[s.season] = [];
  artNightBySeason[s.season].push(s);
}

const festivalBySeason: Record<number, any[]> = {};
for (const s of allFestivalShells) {
  if (!festivalBySeason[s.season]) festivalBySeason[s.season] = [];
  festivalBySeason[s.season].push(s);
}

const totalShells =
  Object.keys(shellsBySeason).length +
  Object.keys(openMicBySeason).length +
  Object.keys(artNightBySeason).length +
  Object.keys(festivalBySeason).length;
---

<AdminLayout title="Plan Events" user={user}>

  <div class="page-header">
    <h1>Plan Events</h1>
    <p class="page-sub">Select an event to set up a new series and generate event shells.</p>
  </div>

  {flashMsg && <div class={`flash flash-${flashType}`}>{flashMsg}</div>}

  <!-- ── WIZARD ────────────────────────────────────────────────────────── -->
  <section class="card">
    <h2 class="card-title">Set Up a New Event Series</h2>
    <p class="card-sub">Choose an event, fill in the details, and select dates from the calendar. A shell will be created for each selected date.</p>

    <form method="POST" class="season-form" id="season-form">
      <input type="hidden" name="action" value="create_season" />
      <!-- Hidden dates field — written by the calendar JS -->
      <textarea name="dates" id="dates-hidden" style="display:none" readonly></textarea>

      <!-- Event title dropdown -->
      <div class="form-field">
        <label for="event-type-select">Event Title <span class="req">*</span></label>
        <select id="event-type-select" name="seriesType">
          <option value="">— Select an event —</option>
          <option value="music_in_park">Music &amp; Movies in the Park</option>
          <option value="open_mic">Open Mic Night</option>
          <option value="group_art_night">Group Art Night</option>
          <option value="annual_seminar">Annual Arts Seminar</option>
          <option value="arts_festival">Magna Main Street Arts Festival</option>
          <option value="custom">— or something else —</option>
        </select>
      </div>

      <!-- Placeholder notice (seminar, festival, custom) -->
      <div id="placeholder-notice" class="placeholder-notice" hidden>
        <div class="placeholder-icon">🚧</div>
        <strong>Planning workflow coming soon.</strong>
        <p>This event type is on the roadmap. We'll build it out in a future session.</p>
      </div>

      <!-- Main form body (music, open mic, art night) -->
      <div id="main-form-body" hidden>

        <div class="form-row">
          <div class="form-field">
            <label for="year">Season Year <span class="req">*</span></label>
            <input type="number" id="year" name="year" value="2026" min="2024" max="2040" />
          </div>
          <div class="form-field">
            <label for="startTime">Default Start Time <span class="req">*</span></label>
            <input type="text" id="startTime" name="startTime" placeholder="7:00 PM" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="venue">Venue Name <span class="req">*</span></label>
            <input type="text" id="venue" name="venue" placeholder="Venue" />
          </div>
          <div class="form-field">
            <label for="address">Address <span class="req">*</span></label>
            <input type="text" id="address" name="address" placeholder="Address" />
          </div>
        </div>

        <!-- Open Mic–specific fields -->
        <div id="open-mic-fields" class="event-extra-fields" style="display:none;">
          <div class="form-field">
            <label for="omTitle">Event Title</label>
            <input type="text" id="omTitle" name="omTitle" value="Open Mic Night" placeholder="Open Mic Night" />
          </div>

          <!-- Image upload -->
          <div class="form-field">
            <label>
              Event Image
              <span class="field-hint">One image used for all dates in this series</span>
            </label>
            <!-- Populated by JS after upload to Firebase Storage -->
            <input type="hidden" id="omImageUrl" name="omImageUrl" />
            <div class="upload-zone" id="om-image-zone">
              <input
                type="file"
                id="om-image-input"
                accept="image/jpeg,image/png,image/webp"
                class="upload-input"
              />
              <label for="om-image-input" class="upload-label">
                <span class="upload-icon">🖼️</span>
                <span class="upload-text"><strong>Choose an image</strong> or drag and drop</span>
                <span class="upload-hint">JPG, PNG or WebP · max 10 MB</span>
              </label>
              <div class="upload-preview" id="om-image-preview" hidden></div>
            </div>
            <div id="om-upload-status" class="upload-status" hidden></div>
          </div>

          <div class="form-field">
            <label for="omDescription">Description</label>
            <textarea id="omDescription" name="omDescription" rows="3"
              placeholder="Join us for an evening of music, poetry, and performance. All are welcome to perform or just enjoy the show."></textarea>
          </div>
        </div>

        <!-- Arts Festival–specific fields -->
        <div id="arts-festival-fields" class="event-extra-fields" style="display:none;">
          <div class="form-field">
            <label for="afTitle">Event Title</label>
            <input type="text" id="afTitle" name="afTitle" value="Magna Main Street Arts Festival" />
          </div>
          <div class="form-field">
            <label for="afDescription">Description <span class="field-hint">(shown on the public event page)</span></label>
            <textarea id="afDescription" name="afDescription" rows="4"
              placeholder="Our annual flagship event draws 5,000–7,000 people to Historic Magna Main Street for a full day of live music, a fine arts contest, street performers, and arts and food vendors. Free and open to all."></textarea>
          </div>
          <div class="info-callout">
            <span>ℹ️</span>
            <span>A single event shell will be created. After publishing, approved vendor applications will appear on the public festival page automatically.</span>
          </div>
        </div>

        <!-- Group Art Night–specific fields -->
        <div id="art-night-fields" class="event-extra-fields" style="display:none;">
          <div class="form-field">
            <label for="anTitle">Event Title</label>
            <input type="text" id="anTitle" name="anTitle" value="Group Art Night" placeholder="Group Art Night" />
          </div>

          <!-- Image upload -->
          <div class="form-field">
            <label>
              Event Image
              <span class="field-hint">One image used for all dates in this series</span>
            </label>
            <input type="hidden" id="anImageUrl" name="anImageUrl" />
            <div class="upload-zone" id="an-image-zone">
              <input
                type="file"
                id="an-image-input"
                accept="image/jpeg,image/png,image/webp"
                class="upload-input"
              />
              <label for="an-image-input" class="upload-label">
                <span class="upload-icon">🖼️</span>
                <span class="upload-text"><strong>Choose an image</strong> or drag and drop</span>
                <span class="upload-hint">JPG, PNG or WebP · max 10 MB</span>
              </label>
              <div class="upload-preview" id="an-image-preview" hidden></div>
            </div>
            <div id="an-upload-status" class="upload-status" hidden></div>
          </div>

          <div class="form-field">
            <label for="anDescription">Description</label>
            <textarea id="anDescription" name="anDescription" rows="3"
              placeholder="A community art session guided by a local artist. All skill levels welcome."></textarea>
          </div>
          <div class="info-callout">
            <span>ℹ️</span>
            <span>After creating shells, use the table below to assign a presenter. Click <strong>Assign Presenter</strong> on any shell to pick from pending Art Class submissions. Once assigned, use <strong>Mark Confirmed</strong> when you've spoken with the presenter, then <strong>Publish ↗</strong> to push the event live.</span>
          </div>
        </div>

        <!-- ── DATE CALENDAR ─────────────────────────────────────────── -->
        <div class="form-field">
          <label>
            Event Dates <span class="req">*</span>
            <span class="field-hint">Click dates to toggle them on/off</span>
          </label>

          <!-- Selected date chips summary -->
          <div id="selected-chips" class="selected-chips" hidden>
            <span class="chips-label">Selected:</span>
            <div id="chips-list" class="chips-list"></div>
            <button type="button" id="clear-dates-btn" class="clear-dates-btn">Clear all</button>
          </div>

          <!-- 12-month scrollable calendar -->
          <div id="cal-grid" class="cal-grid"></div>
        </div>

        <div class="form-actions">
          <button type="submit" id="submit-btn" class="btn btn-primary">Generate Event Shells →</button>
          <span id="submit-status" class="submit-status" hidden></span>
        </div>
      </div><!-- /main-form-body -->
    </form>
  </section>

  <!-- ── MUSIC & MOVIES IN THE PARK ────────────────────────────────────── -->
  {Object.entries(shellsBySeason).sort(([a],[b]) => Number(b)-Number(a)).map(([yr, shells]) => (
    <section class="card">
      <div class="season-header">
        <h2 class="card-title">🎵 Music &amp; Movies in the Park — {yr} <span class="count-badge">{shells.length} events</span></h2>
      </div>
      <table class="shells-table">
        <thead>
          <tr>
            <th>Date</th><th>Start</th><th>Venue</th><th>Status</th>
            <th>Band</th><th>Confirmed</th><th>Movie</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {shells.map(shell => (
            <tr id={`shell-${shell.id}`}>
              <td class="date-cell">{shell.displayDate}</td>
              <td>{shell.startTime}</td>
              <td class="venue-cell">{shell.venue}</td>
              <td><span class={`badge badge-${shell.status}`}>{shell.status}</span></td>
              <td>{shell.bandName || <span class="dim">—</span>}</td>
              <td>
                {shell.bandName
                  ? (shell.bandConfirmed ? <span class="check-yes">✓ Yes</span> : <span class="check-no">✗ Pending</span>)
                  : <span class="dim">—</span>}
              </td>
              <td>{shell.movie ? <span class="check-yes">✓ {shell.movie}</span> : <span class="dim">—</span>}</td>
              <td class="actions-cell">
                <button class="btn-sm btn-outline"
                  onclick={`openEditModal('${shell.id}','${(shell.venue||'').replace(/'/g,"\\'")}','${(shell.address||'').replace(/'/g,"\\'")}','${shell.startTime}','park_events')`}>
