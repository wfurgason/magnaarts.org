---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';
import { events as staticEvents } from '../../data/events';

const user = Astro.locals.user;

const snap = await adminDb.collection('events')
  .orderBy('eventDate', 'asc')
  .get();

type FirestoreEvent = {
  id: string;
  title: string;
  eventDate: any;
  eventTime: string;
  venueName: string;
  venueAddress: string;
  ticketUrl?: string;
  rsvpUrl?: string;
  posterUrl?: string;
  description: string;
  bandName?: string;
  genre?: string;
  submissionType: string;
  publishedBy: string;
  publishedAt: any;
};

const firestoreEvents = snap.docs.map(d => ({ id: d.id, ...d.data() })) as FirestoreEvent[];

function formatDate(ts: any): string {
  if (!ts) return '—';
  const date = ts.toDate ? ts.toDate() : new Date(ts);
  return date.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'long', day: 'numeric' });
}

const now = new Date();

const upcoming = firestoreEvents.filter(e => {
  const d = e.eventDate?.toDate ? e.eventDate.toDate() : new Date(e.eventDate);
  return d >= now;
});

const firestorePast = firestoreEvents.filter(e => {
  const d = e.eventDate?.toDate ? e.eventDate.toDate() : new Date(e.eventDate);
  return d < now;
});

// Build the unified past-events archive:
// 1. Seed from static events.ts (all 2025 season events — all dates are past)
// 2. Add Firestore past events (de-duped by id)

type ArchiveRow = {
  id: string;
  isoDate: string;       // YYYY-MM-DD for sorting
  displayDate: string;
  title: string;
  band?: string;
  type: string;
  venue: string;
  source: 'season' | 'firestore';
};

const firestorePastIds = new Set(firestorePast.map(e => e.id));

const staticArchive: ArchiveRow[] = staticEvents.map(e => ({
  id: e.id,
  isoDate: e.isoDate,
  displayDate: e.day,
  title: e.title,
  band: e.subtitle && e.subtitleType !== 'film' ? e.subtitle : undefined,
  type: e.type.charAt(0).toUpperCase() + e.type.slice(1),
  venue: e.location,
  source: 'season',
}));

const firestoreArchive: ArchiveRow[] = firestorePast
  .filter(e => !staticEvents.some(s => s.id === e.id))   // don't double-count
  .map(e => {
    const d = e.eventDate?.toDate ? e.eventDate.toDate() : new Date(e.eventDate);
    return {
      id: e.id,
      isoDate: d.toISOString().slice(0, 10),
      displayDate: formatDate(e.eventDate),
      title: e.title,
      band: e.bandName,
      type: e.submissionType === 'band' ? 'Concert' : 'Program',
      venue: e.venueName || '—',
      source: 'firestore',
    };
  });

// Merge and sort by date descending (most recent first)
const archive: ArchiveRow[] = [...staticArchive, ...firestoreArchive]
  .sort((a, b) => b.isoDate.localeCompare(a.isoDate));

// Pass to client as JSON for client-side sort/search
const archiveJson = JSON.stringify(archive);
---

<AdminLayout title="Published Events" user={user}>
  <div class="page-header">
    <h1>Published Events</h1>
    <a href="https://magnaarts.org/events" target="_blank" rel="noopener" class="btn btn-ghost">
      View Public Page ↗
    </a>
  </div>

  <!-- ── UPCOMING (from Firestore) ── -->
  {firestoreEvents.length === 0 ? (
    <div class="empty-state">
      <p>No events published yet. Approve a band or program submission, then click "Publish as Event."</p>
    </div>
  ) : (
    <>
      {upcoming.length > 0 && (
        <section class="events-section">
          <h2 class="section-title">Upcoming ({upcoming.length})</h2>
          <div class="event-list">
            {upcoming.map(event => (
              <div class="event-card" id={event.id}>
                <div class="event-card-inner">
                  {event.posterUrl && (
                    <img src={event.posterUrl} alt={event.title} class="event-poster" />
                  )}
                  <div class="event-info">
                    <div class="event-date-badge">{formatDate(event.eventDate)} · {event.eventTime}</div>
                    <h3 class="event-title">{event.title}</h3>
                    {event.bandName && <div class="event-sub">{event.bandName} · {event.genre}</div>}
                    <div class="event-venue">{event.venueName}, {event.venueAddress}</div>
                    <p class="event-desc">{event.description}</p>
                    <div class="event-links">
                      {event.ticketUrl && <a href={event.ticketUrl} target="_blank" rel="noopener" class="link-sm">Tickets ↗</a>}
                      {event.rsvpUrl && <a href={event.rsvpUrl} target="_blank" rel="noopener" class="link-sm">RSVP ↗</a>}
                    </div>
                    <div class="event-meta">Published by {event.publishedBy}</div>
                  </div>
                </div>
                <div class="event-actions">
                  <button class="btn btn-danger btn-sm" data-action="unpublish" data-id={event.id}>
                    Unpublish
                  </button>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {upcoming.length === 0 && (
        <div class="empty-state">
          <p>No upcoming events. Use the Season Setup or Bands pages to publish the next event.</p>
        </div>
      )}
    </>
  )}

  <!-- ── PAST EVENTS ARCHIVE ── -->
  <section class="archive-section">
    <div class="archive-header">
      <h2 class="section-title">Past Events Archive ({archive.length})</h2>
      <input
        type="search"
        id="archive-search"
        placeholder="Search title, band, venue…"
        class="archive-search-input"
        autocomplete="off"
      />
    </div>

    <div class="archive-table-wrap">
      <table class="archive-table" id="archive-table">
        <thead>
          <tr>
            <th class="sortable" data-col="isoDate">Date <span class="sort-icon">↕</span></th>
            <th class="sortable" data-col="title">Event / Title <span class="sort-icon">↕</span></th>
            <th class="sortable" data-col="band">Band / Presenter <span class="sort-icon">↕</span></th>
            <th class="sortable" data-col="type">Type <span class="sort-icon">↕</span></th>
            <th class="sortable" data-col="venue">Venue <span class="sort-icon">↕</span></th>
            <th>Source</th>
          </tr>
        </thead>
        <tbody id="archive-tbody">
          <!-- populated by JS -->
        </tbody>
      </table>
      <div id="archive-empty-msg" class="archive-empty" style="display:none">
        No events match your search.
      </div>
    </div>
  </section>

  <script>
    // ── Unpublish buttons ──
    document.querySelectorAll('[data-action="unpublish"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLButtonElement;
        if (!confirm('Unpublish this event? The submission will return to "approved" status.')) return;
        el.disabled = true;
        el.textContent = 'Removing…';
        const res = await fetch('/api/admin/delete-event', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ eventId: el.dataset.id }),
        });
        if (res.ok) window.location.reload();
        else { alert('Failed to unpublish.'); el.disabled = false; el.textContent = 'Unpublish'; }
      });
    });

    // ── Past Events Archive: sort + search ──
    const raw: Array<{
      id: string; isoDate: string; displayDate: string;
      title: string; band?: string; type: string; venue: string; source: string;
    }> = JSON.parse(document.getElementById('archive-data')!.textContent!);

    let sortCol  = 'isoDate';
    let sortDir  = -1;   // -1 = desc (most recent first)
    let filterQ  = '';

    function renderTable() {
      const tbody  = document.getElementById('archive-tbody')!;
      const empty  = document.getElementById('archive-empty-msg')!;
      const q      = filterQ.toLowerCase();

      let rows = raw.filter(r =>
        !q ||
        r.title.toLowerCase().includes(q) ||
        (r.band || '').toLowerCase().includes(q) ||
        r.venue.toLowerCase().includes(q) ||
        r.type.toLowerCase().includes(q) ||
        r.displayDate.toLowerCase().includes(q)
      );

      rows.sort((a, b) => {
        const av = (a as any)[sortCol] ?? '';
        const bv = (b as any)[sortCol] ?? '';
        return av < bv ? sortDir : av > bv ? -sortDir : 0;
      });

      if (rows.length === 0) {
        tbody.innerHTML = '';
        empty.style.display = 'block';
      } else {
        empty.style.display = 'none';
        tbody.innerHTML = rows.map(r => `
          <tr>
            <td class="col-date">${r.displayDate}</td>
            <td class="col-title">${r.title}</td>
            <td class="col-band">${r.band || '<span class="muted">—</span>'}</td>
            <td><span class="type-badge type-${r.type.toLowerCase()}">${r.type}</span></td>
            <td class="col-venue">${r.venue}</td>
            <td><span class="source-badge source-${r.source}">${r.source === 'season' ? 'Season Data' : 'Firestore'}</span></td>
          </tr>
        `).join('');
      }

      // Update sort icons
      document.querySelectorAll<HTMLElement>('.sortable').forEach(th => {
        const icon = th.querySelector('.sort-icon')!;
        if (th.dataset.col === sortCol) {
          icon.textContent = sortDir === -1 ? '↓' : '↑';
          th.classList.add('active');
        } else {
          icon.textContent = '↕';
          th.classList.remove('active');
        }
      });
    }

    // Sortable headers
    document.querySelectorAll<HTMLElement>('.sortable').forEach(th => {
      th.addEventListener('click', () => {
        if (sortCol === th.dataset.col) {
          sortDir *= -1;
        } else {
          sortCol = th.dataset.col!;
          sortDir = -1;
        }
        renderTable();
      });
    });

    // Search input
    document.getElementById('archive-search')!.addEventListener('input', (e) => {
      filterQ = (e.target as HTMLInputElement).value;
      renderTable();
    });

    renderTable();
  </script>

  <!-- Hidden JSON data island for the archive table -->
  <script id="archive-data" type="application/json" set:html={archiveJson}></script>

</AdminLayout>

<style>
  /* ── Archive section ── */
  .archive-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .archive-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 20px;
  }

  .archive-search-input {
    font-family: var(--font-body);
    font-size: 14px;
    padding: 9px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--white);
    color: var(--navy);
    width: 280px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .archive-search-input:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(37, 99, 176, 0.12);
  }

  .archive-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
  }

  .archive-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .archive-table thead tr {
    background: var(--cream);
    border-bottom: 1px solid var(--border);
  }

  .archive-table th {
    padding: 12px 16px;
    text-align: left;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
    user-select: none;
  }

  .archive-table th.sortable {
    cursor: pointer;
    transition: color 0.15s;
  }
  .archive-table th.sortable:hover,
  .archive-table th.sortable.active { color: var(--navy); }

  .sort-icon {
    font-size: 12px;
    margin-left: 4px;
    opacity: 0.5;
  }
  .archive-table th.active .sort-icon { opacity: 1; }

  .archive-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }
  .archive-table tbody tr:last-child { border-bottom: none; }
  .archive-table tbody tr:hover { background: var(--cream); }

  .archive-table td {
    padding: 12px 16px;
    color: var(--navy);
    vertical-align: middle;
  }

  .col-date  { white-space: nowrap; color: var(--muted); font-size: 13px; }
  .col-title { font-weight: 600; }
  .col-band  { color: var(--muted); }
  .col-venue { color: var(--muted); font-size: 13px; }

  .muted { color: var(--muted); }

  /* Type badges */
  .type-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
  }
  .type-concert  { background: #dbeafe; color: var(--blue); }
  .type-film     { background: #fee2e2; color: var(--red); }
  .type-festival { background: #fef3c7; color: var(--amber); }
  .type-class    { background: #dcfce7; color: var(--green); }
  .type-program  { background: #ede9fe; color: #6d28d9; }
  .type-openmic  { background: #fce7f3; color: #be185d; }

  /* Source badges */
  .source-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 100px;
  }
  .source-season    { background: #f1f5f9; color: var(--muted); }
  .source-firestore { background: #eff6ff; color: var(--blue); }

  .archive-empty {
    text-align: center;
    padding: 32px;
    color: var(--muted);
    font-size: 14px;
  }
</style>
