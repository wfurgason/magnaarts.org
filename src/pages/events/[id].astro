---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { adminDb } from '../../lib/firebase-admin';

const firebaseConfig = {
  apiKey:    import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain:import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
};

const { id } = Astro.params;

// Load event from Firestore only
const eventDoc = await adminDb.collection('events').doc(id!).get();
if (!eventDoc.exists) {
  return Astro.redirect('/events');
}

const event = { id: eventDoc.id, ...eventDoc.data() } as any;

// For calendar link — normalise date string
const isoDate = event.date || (event.eventDate?.toDate
  ? event.eventDate.toDate().toISOString().slice(0, 10)
  : null);

// Pretty-print date e.g. "August 15th, 2026"
function ordinal(n: number) {
  const s = ['th','st','nd','rd'];
  const v = n % 100;
  return n + (s[(v - 20) % 10] || s[v] || s[0]);
}
const displayDate = isoDate
  ? (() => {
      const [y, m, d] = isoDate.split('-').map(Number);
      const monthName = new Date(y, m - 1, 1).toLocaleString('en-US', { month: 'long' });
      return `${monthName} ${ordinal(d)}, ${y}`;
    })()
  : (event.displayDate || '');

const isFestival  = event.eventType === 'arts_festival';
const isArtNight  = event.eventType === 'group_art_night';

function extractEmbedSrc(val: string | null): string | null {
  if (!val) return null;
  if (val.trim().startsWith('http')) return val.trim();
  const m = val.match(/src=["']([^"']+)["']/);
  return m ? m[1] : null;
}

const vendorTypeIcon: Record<string, string> = {
  'Individual Artist': '🎨',
  'Food Vendor': '🌮',
  'Retail / Franchise / non-profit': '🛒',
  'Political': '📜',
};

// For festival pages, load approved + paid vendors with a booth assigned
let vendors: any[] = [];
if (isFestival) {
  const vendorSnap = await adminDb.collection('vendor_applications')
    .where('status', 'in', ['approved', 'paid'])
    .get();
  vendors = vendorSnap.docs
    .map(d => ({ id: d.id, ...d.data() }))
    .filter((v: any) =>
      (v.payment_status === 'paid' || v.status === 'paid') &&
      (v.space_number || v.booth_number)
    );
}
const eventTime    = event.eventTime    || '';
const endTime      = event.endTime      || null;
const timeDisplay  = isFestival && eventTime && endTime
  ? `${eventTime} – ${endTime}`
  : eventTime;
const venueName    = event.venueName    || '';
const venueAddress = event.venueAddress || '';
---

<BaseLayout
  title={`${event.title} — Magna Arts Council`}
  description={event.description || `${event.title} at ${venueName} on ${displayDate}.`}
>
  <Header />

  <main>

    <!-- ── EVENT HERO ── -->
    <section class={`event-hero ${isFestival ? 'hero-amber' : 'hero-navy'}`}>
      <div class="container hero-inner">
        <div class="hero-left">
          <div class="back-link-wrap">
            <a href="/events" class="back-link">← All Events</a>
          </div>
          <div class="type-badge">
            {isFestival ? 'Arts Festival' : (event.category || 'Event')}
          </div>
          <h1>{event.title}</h1>
          <div class="hero-meta">
            <div class="meta-item">
              <span class="meta-icon">🗓</span>
              <span>{displayDate}</span>
            </div>
            {timeDisplay && (
              <div class="meta-item">
                <span class="meta-icon">🕗</span>
                <span>{timeDisplay}</span>
              </div>
            )}
            <div class="meta-item">
              <span class="meta-icon">📍</span>
              <span>{venueName}</span>
            </div>
            {venueAddress && (
              <div class="meta-item meta-address">
                <span class="meta-icon">↳</span>
                <a
                  href={`https://maps.google.com?q=${encodeURIComponent(venueAddress)}`}
                  target="_blank"
                  rel="noopener"
                  class="map-link"
                >
                  {venueAddress} (map)
                </a>
              </div>
            )}
          </div>
          <div class="hero-actions">
            {isoDate && (
              <a
                href={`https://www.google.com/calendar/event?action=TEMPLATE&text=${encodeURIComponent(event.title)}&dates=${isoDate.replace(/-/g,'')}T020000Z/${isoDate.replace(/-/g,'')}T055900Z&location=${encodeURIComponent(venueAddress || venueName)}`}
                target="_blank"
                rel="noopener"
                class="btn btn-white"
              >
                + Add to Google Calendar
              </a>
            )}
          </div>
        </div>

        {event.image && isFestival && (
          <div class="hero-image-wrap">
            <img src={event.image} alt={event.title} class="hero-image" />
          </div>
        )}
        {event.posterUrl && !isFestival && (
          <div class="hero-image-wrap">
            <img src={event.posterUrl} alt={event.title} class="hero-image" />
          </div>
        )}
      </div>
    </section>

    <!-- ── ART NIGHT PRESENTER SECTION ── -->
    {isArtNight && (
      <section class="section desc-section reveal">
        <div class="container desc-inner">
          <div class="desc-body">
            {event.presenterName && (
              <div class="band-hero">
                {event.presenterPhotoUrl && (
                  <div class="band-hero-photo-wrap">
                    <img src={event.presenterPhotoUrl} alt={event.presenterName} class="band-hero-photo" />
                  </div>
                )}
                <div class="band-hero-info">
                  <h2 class="band-hero-name">
                    {event.presenterName}
                    {event.presenterSocialUrl && (
                      <a href={event.presenterSocialUrl} target="_blank" rel="noopener" class="presenter-social-link">↗</a>
                    )}
                  </h2>
                  {event.presenterArtsArea && (
                    <div class="presenter-project-desc" set:html={event.presenterArtsArea} />
                  )}
                  {event.presenterProjectDescription && (
                    <>
                      <div class="presenter-section-label">This Month's Project</div>
                      {event.presenterImageUrl && (
                        <div class="project-image-wrap">
                          <img src={event.presenterImageUrl} alt="Project image" class="project-image" />
                        </div>
                      )}
                      <div class="presenter-project-desc" set:html={event.presenterProjectDescription} />
                    </>
                  )}
                </div>
              </div>
            )}
            {!event.presenterName && event.description && (
              <p>{event.description}</p>
            )}
          </div>
          <div class="desc-sidebar">
            <div class="sidebar-card">
              <h3>Event Details</h3>
              <dl>
                <dt>Date</dt>
                <dd>{displayDate}</dd>
                {timeDisplay && <><dt>Time</dt><dd>{timeDisplay}</dd></>}
                <dt>Location</dt>
                <dd>{venueName}</dd>
                {venueAddress && <><dt>Address</dt><dd>{venueAddress}</dd></>}
                <dt>Admission</dt>
                <dd>Free — Materials Provided — For Ages 16+</dd>
              </dl>
            </div>
            <div class="sidebar-card attend-card">
              <h3>Attending</h3>
              <div class="attend-count-wrap">
                <span class="attend-count" id="attend-count">{event.attendingCount || 0}</span>
                <span class="attend-label">people are going</span>
              </div>
              <button class="btn btn-gold attend-btn" id="attend-btn" style="width:100%;justify-content:center;" data-event-id={Astro.params.id}>
                I'm Attending
              </button>
              <p class="attend-hint" id="attend-hint"></p>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ── DESCRIPTION ── -->
    {(!isFestival && !isArtNight && (event.bandName || event.description)) && (() => {
      const band = (event.bands || []).find((b: any) => b.bandId) as any;
      return (
        <section class="section desc-section reveal">
          <div class="container desc-inner">
            <div class="desc-body">
              {event.bandName && (
                <div class="band-hero">
                  {band?.photoUrl && (
                    <div class="band-hero-photo-wrap">
                      <img src={band.photoUrl} alt={event.bandName} class="band-hero-photo" />
                    </div>
                  )}
                  <div class="band-hero-info">
                    <h2 class="band-hero-name">{event.bandName}</h2>
                    {(band?.bio || event.description) && <p class="band-hero-bio">{band?.bio || event.description}</p>}
                    {(band?.genre || event.genre) && <div class="band-hero-genre">{band?.genre || event.genre}</div>}
                    <div class="band-hero-links">
                      {(band?.website || event.bandWebsite || event.website) && (
                        <a href={band?.website || event.bandWebsite || event.website} target="_blank" rel="noopener" class="band-hero-link">🌐 Website</a>
                      )}
                      {(band?.musicLink || event.musicLink) && (
                        <a href={band?.musicLink || event.musicLink} target="_blank" rel="noopener" class="band-hero-link band-hero-link-music">🎵 Listen</a>
                      )}
                      {(band?.instagram || event.instagram) && (
                        <a href={band?.instagram || event.instagram} target="_blank" rel="noopener" class="band-hero-link">📸 Instagram</a>
                      )}
                      {(band?.facebook || event.facebook) && (
                        <a href={band?.facebook || event.facebook} target="_blank" rel="noopener" class="band-hero-link">📘 Facebook</a>
                      )}
                    </div>
                  </div>
                </div>
              )}
              {event.description && !event.bandName && (
                <p>{event.description}</p>
              )}

              {event.movieTitle && (
                <div class="inline-movie">
                  <h3 class="inline-movie-heading">🎬 Tonight's Movie</h3>
                  <p class="movie-title-display">{event.movieTitle}</p>
                  {event.moviePreviewEmbed && extractEmbedSrc(event.moviePreviewEmbed) && (
                    <div class="movie-embed-wrapper">
                      <iframe
                        src={extractEmbedSrc(event.moviePreviewEmbed)!}
                        title={`${event.movieTitle} trailer`}
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    </div>
                  )}
                </div>
              )}

              {!isFestival && event.eventType === 'music_movie_in_park' && (
                <div class="inline-park-tips">
                  <span class="park-icon">🌳</span>
                  <div>
                    <strong>Tips for Attending</strong>
                    <p>Bring a blanket or lawn chairs. Parking is free on surrounding streets. All events are free and open to the public.</p>
                  </div>
                </div>
              )}
            </div>
          <div class="desc-sidebar">
            <div class="sidebar-card">
              <h3>Event Details</h3>
              <dl>
                <dt>Date</dt>
                <dd>{displayDate}</dd>
                {timeDisplay && <><dt>Time</dt><dd>{timeDisplay}</dd></>}
                <dt>Location</dt>
                <dd>{venueName}</dd>
                {venueAddress && <><dt>Address</dt><dd>{venueAddress}</dd></>}
                <dt>Admission</dt>
                <dd>Free — all ages welcome</dd>
              </dl>
            </div>
            {!isFestival && (
              <div class="sidebar-card attend-card">
                <h3>Attending</h3>
                <div class="attend-count-wrap">
                  <span class="attend-count" id="attend-count">{event.attendingCount || 0}</span>
                  <span class="attend-label">people are going</span>
                </div>
                <button class="btn btn-gold attend-btn" id="attend-btn" style="width:100%;justify-content:center;" data-event-id={Astro.params.id}>
                  I'm Attending
                </button>
                <p class="attend-hint" id="attend-hint"></p>
              </div>
            )}
          </div>
        </div>
      </section>
      );
    })()}

    {isFestival && event.description && (
      <section class="section desc-section reveal">
        <div class="container desc-inner">
          <div class="desc-body">
            <h2>About This Event</h2>
            <p>{event.description}</p>
          </div>
        </div>
      </section>
    )}

    <!-- ── FESTIVAL: BAND PROFILES + VENDORS ── -->
    {isFestival && (
      <section class="section festival-body">
        <div class="container">

          <!-- Band Profiles -->
          {(event.bands || []).filter((b: any) => b.bandId).length > 0 && (
            <div class="festival-section reveal">
              <h2 class="festival-section-heading">🎸 Main Stage Lineup</h2>
              <div class="band-profiles">
                {(event.bands as any[])
                  .filter(b => b.bandId)
                  .sort((a, b) => a.slot - b.slot)
                  .map((b: any) => (
                    <div class="band-profile-card">
                      <div class="band-photo-col">
                        {b.photoUrl && (
                          <div class="band-photo-wrap">
                            <img src={b.photoUrl} alt={b.bandName} class="band-photo" />
                          </div>
                        )}
                        <h3 class="band-name">{b.bandName}</h3>
                      </div>
                      <div class="band-info">
                        <div class="band-genre-row">
                          {b.time && <span class="slot-time">{b.time}</span>}
                          {b.genre && <div class="band-genre">{b.genre}</div>}
                          {b.website && (
                            <a href={b.website} target="_blank" rel="noopener" class="band-link">
                              Website ↗
                            </a>
                          )}
                          {b.musicLink && (
                            <a href={b.musicLink} target="_blank" rel="noopener" class="band-link band-link-music">
                              🎵 Listen
                            </a>
                          )}
                        </div>
                        {b.bio && <p class="band-bio">{b.bio}</p>}
                      </div>
                    </div>
                  ))}
              </div>
            </div>
          )}

          {(event.bands || []).filter((b: any) => b.bandId).length === 0 && (
            <div class="festival-section reveal">
              <h2 class="festival-section-heading">🎸 Main Stage Lineup</h2>
              <p class="coming-soon">Band lineup being announced soon — check back!</p>
            </div>
          )}

          <!-- Vendor List (server-rendered) -->
          <div class="festival-section reveal">
            <h2 class="festival-section-heading">🛒 Participating Vendors</h2>
            {vendors.length > 0 ? (
              <div class="vendor-list">
                {vendors.map((v: any) => {
                  const icon = vendorTypeIcon[v.vendor_type] || '✓';
                  const space = v.space_number || v.booth_number;
                  const vendorName = v.company_name || v.vendor_name || v.contact_name;
                  return (
                    <div class="vendor-profile-card">
                      <div class="vendor-photo-col">
                        {v.profile_image_url
                          ? <div class="vendor-photo-wrap"><img src={v.profile_image_url} alt={vendorName} class="vendor-photo" /></div>
                          : <div class="vendor-photo-placeholder">{icon}</div>
                        }
                        <h3 class="vendor-name">{vendorName}</h3>
                      </div>
                      <div class="vendor-info">
                        <div class="vendor-meta-row">
                          {space && <span class="vendor-space">Space #{space}</span>}
                          {v.vendor_type && <div class="vendor-genre">{v.vendor_type}</div>}
                          {v.website && (
                            <a href={v.website} target="_blank" rel="noopener" class="band-link">Website ↗</a>
                          )}
                        </div>
                        {v.description && <p class="band-bio">{v.description}</p>}
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="vendor-empty">
                Vendor announcements coming soon! <a href="/vendor-application">Apply to be a vendor →</a>
              </div>
            )}
            <a href="/vendor-application" class="vendor-apply-link">Apply to be a vendor →</a>
          </div>

          <!-- Arts Contest -->
          <div class="festival-section reveal">
            <h2 class="festival-section-heading">🎨 Arts Contest</h2>
            <p class="contest-intro">
              The Magna Arts Festival hosts a juried art contest open to artists of all ages and skill levels.
              Whether you're a seasoned professional or picking up a brush for the first time, we invite you
              to share your work with the community. All submitted artwork is displayed at the festival,
              with entries judged within age groups across five fine arts categories. Every submission is
              also eligible for the <strong>People's Choice Award</strong>, voted on by festival attendees.
            </p>

            <div class="contest-grid">

              <div class="contest-card">
                <h3 class="contest-card-heading">Age Groups</h3>
                <ul class="contest-list">
                  <li>8 – 12</li>
                  <li>13 – 17</li>
                  <li>18+</li>
                  <li>Professional</li>
                </ul>
              </div>

              <div class="contest-card">
                <h3 class="contest-card-heading">Categories</h3>
                <ul class="contest-list">
                  <li>Watercolor</li>
                  <li>Oil / Acrylic</li>
                  <li>Photography <span class="cat-note">(No AI Enhanced)</span></li>
                  <li>Drawing</li>
                  <li>Sculpture / Fiber / Mixed Media <span class="cat-note">(No 3D Printed)</span></li>
                </ul>
              </div>

              <div class="contest-card contest-card-rules">
                <h3 class="contest-card-heading">Entry Rules</h3>
                <p>Artists may enter <strong>more than one piece</strong>, but each entry must be in a <strong>different category</strong>.</p>
                <p>Multiple entries submitted under the same category will be <strong>displayed but not judged</strong>. If submitting more than one piece in a category, please indicate at the time of submission which work you would like to be judged.</p>
                <p>All artwork must be submitted to the <strong>Magna Library</strong> between <strong>June 1st and August 1st</strong>.</p>
              </div>

            </div>
          </div>

        </div>
      </section>
    )}

    <!-- movie and park tips now rendered inside desc-body above -->

  </main>

  <Footer />



</BaseLayout>

<style>
  /* ── HERO ── */
  .event-hero { padding: 64px 0 56px; color: var(--white); }
  .hero-navy  { background: var(--navy, #1a2456); }
  .hero-amber { background: #a86300; }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: center;
  }

  .back-link-wrap { margin-bottom: 20px; }
  .back-link {
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.7); letter-spacing: 0.04em; transition: color 0.2s;
  }
  .back-link:hover { color: var(--white); }

  .type-badge {
    display: inline-block; font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 5px 14px; border-radius: 100px; margin-bottom: 16px;
    background: rgba(255,255,255,0.2); color: var(--white);
    border: 1px solid rgba(255,255,255,0.3);
  }

  .event-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 58px);
    font-weight: 900; line-height: 1.05; margin-bottom: 10px;
  }

  .hero-subtitle {
    font-size: 18px; font-weight: 400;
    color: rgba(255,255,255,0.85); margin-bottom: 28px;
  }

  .hero-meta { display: flex; flex-direction: column; gap: 8px; margin-bottom: 32px; }
  .meta-item { display: flex; align-items: center; gap: 10px; font-size: 15px; color: rgba(255,255,255,0.9); }
  .meta-icon { font-size: 16px; flex-shrink: 0; }
  .meta-address { opacity: 0.75; }
  .map-link { color: rgba(255,255,255,0.85); text-decoration: underline; text-underline-offset: 3px; }
  .map-link:hover { color: var(--white); }

  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-image-wrap { width: 320px; flex-shrink: 0; }
  .hero-image { width: 100%; border-radius: var(--radius); box-shadow: 0 12px 40px rgba(0,0,0,0.3); object-fit: cover; aspect-ratio: 1/1; }

  /* ── DESCRIPTION ── */
  .desc-section { background: var(--white); }
  .desc-section.section,
  .movie-section.section { padding: 24px 0 !important; }
  .band-hero { margin-bottom: 8px !important; padding-bottom: 0 !important; }
  .desc-inner { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  .desc-body h2 {
    font-family: var(--font-display); font-size: 28px; font-weight: 700;
    color: var(--navy); margin-bottom: 16px;
  }
  .desc-body p { font-size: 16px; color: var(--muted); line-height: 1.75; }

  /* ── BAND HERO ── */
  .band-hero {
    display: flex;
    gap: 32px;
    align-items: flex-start;
    margin-bottom: 16px;
    padding-bottom: 0;
  }

  .band-hero-photo-wrap {
    flex-shrink: 0;
    width: 160px;
    height: 160px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(26,36,86,0.15);
  }

  .band-hero-photo { width: 100%; height: 100%; object-fit: cover; }

  .band-hero-info { flex: 1; min-width: 0; }

  .band-hero-name {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 900;
    color: var(--navy);
    margin: 0 0 8px;
    line-height: 1.1;
  }

  .band-hero-bio {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.75;
    margin: 0 0 10px;
  }

  .presenter-project-desc {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.75;
    margin: 0;
  }
  .presenter-project-desc p { margin: 0 0 8px; }
  .presenter-project-desc p:last-child { margin-bottom: 0; }

  .presenter-section-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--navy);
    margin: 12px 0 4px;
  }

  .presenter-social-link {
    font-size: 14px;
    font-weight: 400;
    color: var(--blue);
    text-decoration: none;
    margin-left: 6px;
    vertical-align: middle;
  }
  .presenter-social-link:hover { text-decoration: underline; }

  .project-image-wrap {
    margin: 8px 0 12px;
    border-radius: 8px;
    overflow: hidden;
    max-width: 400px;
  }
  .project-image {
    width: 100%;
    display: block;
    border-radius: 8px;
    border: 1.5px solid var(--border, #e5e5e5);
  }

  .band-hero-genre {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gold);
    background: rgba(212,163,38,0.12);
    border-radius: 20px;
    padding: 3px 12px;
    margin-bottom: 10px;
  }

  .band-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 0;
  }

  .band-hero-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
    background: var(--cream);
    border: 1.5px solid var(--border);
    border-radius: 20px;
    padding: 5px 14px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }

  .band-hero-link:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
  .band-hero-link-music { background: #fdf6e3; border-color: var(--gold); color: #7a4f00; }
  .band-hero-link-music:hover { background: var(--gold); color: var(--white); border-color: var(--gold); }

  @media (max-width: 600px) {
    .band-hero { flex-direction: column; }
    .band-hero-photo-wrap { width: 120px; height: 120px; }
    .band-hero-name { font-size: 28px; }
  }

  .sidebar-card {
