---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';

const user = Astro.locals.user;
const filterParam = Astro.url.searchParams.get('filter') || 'all';

const snap = await adminDb.collection('volunteer_signups')
  .orderBy('submittedAt', 'desc')
  .get();

type Volunteer = {
  id: string;
  fullName: string;
  email: string;
  phone?: string;
  canLift?: string;
  interests?: string[];
  status: string;
  submittedAt?: any;
  notes?: string;
};

const filters = ['all', 'new', 'contacted', 'active', 'inactive'];

let volunteers = snap.docs.map(d => ({ ...d.data(), id: d.id })) as Volunteer[];
if (filterParam !== 'all') {
  volunteers = volunteers.filter(v => (v.status || 'new') === filterParam);
}

function fmt(ts: any) {
  if (!ts) return '—';
  const d = ts.toDate ? ts.toDate() : new Date(ts);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<AdminLayout title="Volunteers" user={user}>

  <div class="page-header">
    <h1>Volunteer Sign-Ups</h1>
    <p class="page-sub">{snap.size} total submission{snap.size !== 1 ? 's' : ''}</p>
    <div class="filter-tabs">
      {filters.map(f => (
        <a
          href={`/admin/volunteers${f === 'all' ? '' : `?filter=${f}`}`}
          class:list={['filter-tab', { active: filterParam === f }]}
        >
          {f.charAt(0).toUpperCase() + f.slice(1)}
        </a>
      ))}
    </div>
  </div>

  {volunteers.length === 0 ? (
    <div class="empty-state">
      <p>No volunteer sign-ups matching this filter.</p>
    </div>
  ) : (
    <div class="vol-table-wrap">
      <table class="vol-table" id="vol-table">
        <thead>
          <tr>
            <th>
              <div class="th-label">Name</div>
              <input class="col-filter" data-col="0" placeholder="Filter…" />
            </th>
            <th>
              <div class="th-label">Email</div>
              <input class="col-filter" data-col="1" placeholder="Filter…" />
            </th>
            <th>
              <div class="th-label">Phone</div>
              <input class="col-filter" data-col="2" placeholder="Filter…" />
            </th>
            <th>
              <div class="th-label">Interests</div>
              <input class="col-filter" data-col="3" placeholder="Filter…" />
            </th>
            <th>
              <div class="th-label">Status</div>
              <input class="col-filter" data-col="4" placeholder="Filter…" />
            </th>
            <th><div class="th-label">Actions</div></th>
          </tr>
        </thead>
        <tbody>
          {volunteers.map(v => {
            const status = v.status || 'new';
            const interests = v.interests?.join(', ') || '—';
            return (
              <tr data-id={v.id}>
                <td class="vol-name">{v.fullName}</td>
                <td><a href={`mailto:${v.email}`}>{v.email}</a></td>
                <td>{v.phone || '—'}</td>
                <td>
                  <div class="interest-chips">
                    {v.interests && v.interests.length > 0
                      ? v.interests.map(i => <span class="interest-chip">{i}</span>)
                      : <span class="muted">—</span>}
                  </div>
                </td>
                <td><span class={`badge badge-${status}`}>{status}</span></td>
                <td class="actions-cell">
                  {(status === 'new') && (
                    <>
                      <button class="btn-sm btn-primary" data-action="contacted" data-id={v.id}>Contacted</button>
                      <button class="btn-sm btn-success" data-action="active" data-id={v.id}>Active</button>
                      <button class="btn-sm btn-danger" data-action="inactive" data-id={v.id}>Inactive</button>
                    </>
                  )}
                  {status === 'contacted' && (
                    <>
                      <button class="btn-sm btn-success" data-action="active" data-id={v.id}>Active</button>
                      <button class="btn-sm btn-danger" data-action="inactive" data-id={v.id}>Inactive</button>
                    </>
                  )}
                  {status === 'active' && (
                    <>
                      <button class="btn-sm btn-primary" data-action="contacted" data-id={v.id}>Contacted</button>
                      <button class="btn-sm btn-danger" data-action="inactive" data-id={v.id}>Inactive</button>
                    </>
                  )}
                  {status === 'inactive' && (
                    <button class="btn-sm btn-success" data-action="new" data-id={v.id}>Restore</button>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  <style>
    .page-sub { color: var(--muted, #5a5a7a); font-size: 14px; margin: 4px 0 16px; }

    .vol-table-wrap { overflow-x: auto; }
    .vol-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .vol-table th {
      background: #f8fafc;
      padding: 6px 10px 4px;
      text-align: left;
      border-bottom: 2px solid #e2e8f0;
      white-space: nowrap;
      vertical-align: top;
    }
    .th-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--muted, #5a5a7a);
      margin-bottom: 4px;
    }
    .col-filter {
      width: 100%;
      padding: 4px 6px;
      font-size: 12px;
      border: 1px solid #cbd5e1;
      border-radius: 4px;
      outline: none;
      background: #fff;
    }
    .col-filter:focus { border-color: var(--navy, #1a2456); }

    .vol-table td {
      padding: 8px 10px;
      border-bottom: 1px solid #f1f5f9;
      vertical-align: middle;
    }
    .vol-table tbody tr:hover { background: #f8fafc; }
    .vol-name { font-weight: 600; color: var(--navy, #1a2456); white-space: nowrap; }
    .vol-table a { color: var(--blue, #2563b0); text-decoration: none; }
    .vol-table a:hover { text-decoration: underline; }

    .interest-chips { display: flex; flex-wrap: wrap; gap: 4px; }
    .interest-chip {
      background: #dbeafe;
      color: #1e40af;
      font-size: 11px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 100px;
      white-space: nowrap;
    }
    .muted { color: var(--muted, #5a5a7a); }

    .badge-new       { background: #f1f5f9; color: #64748b; }
    .badge-contacted { background: #e0f2fe; color: #075985; }
    .badge-active    { background: #d1fae5; color: #065f46; }
    .badge-inactive  { background: #fee2e2; color: #991b1b; }

    .actions-cell { white-space: nowrap; }
    .btn-sm {
      display: inline-block;
      padding: 3px 10px;
      font-size: 12px;
      font-weight: 600;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      margin-right: 4px;
    }
    .btn-sm.btn-primary  { background: #dbeafe; color: #1e40af; }
    .btn-sm.btn-success  { background: #d1fae5; color: #065f46; }
    .btn-sm.btn-danger   { background: #fee2e2; color: #991b1b; }
    .btn-sm:hover { filter: brightness(0.93); }
    .btn-sm:disabled { opacity: .5; cursor: default; }
  </style>

  <script>
    // Column filter
    document.querySelectorAll('.col-filter').forEach(function(input) {
      input.addEventListener('input', function() {
        var col = parseInt(input.dataset.col);
        var val = input.value.toLowerCase();
        document.querySelectorAll('#vol-table tbody tr').forEach(function(row) {
          var cell = row.cells[col];
          var text = cell ? cell.innerText.toLowerCase() : '';
          row.style.display = text.includes(val) ? '' : 'none';
        });
      });
    });

    // Status actions
    document.querySelectorAll('[data-action]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var action = btn.dataset.action;
        var id = btn.dataset.id;
        btn.disabled = true;
        var res = await fetch('/api/admin/update-submission', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id, collection: 'volunteer_signups', status: action }),
        });
        if (res.ok) window.location.reload();
        else { alert('Action failed.'); btn.disabled = false; }
      });
    });
  </script>

</AdminLayout>
