---
// Footer.astro
---

<footer>
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src="/images/ArtsCouncil_logo.png" alt="Magna Arts Council logo" class="brand-logo" />
      <div>
        <span class="logo">Magna Arts Council</span>
        <p>Magna, Utah's Designated Local Arts Agency</p>
      </div>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-nav-row">
        <a href="/events">Events</a>
        <a href="/programs">Programs</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-nav-row footer-nav-sub">
        <a href="/call-for-bands">Band Application</a>
        <a href="/vendor-application">Vendor Application</a>
        <a href="/local-artists">Local Artists</a>
        <a href="/artist/login">Artist Portal</a>
      </div>
    </nav>
  </div>
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {new Date().getFullYear()} Magna Arts Council &nbsp;·&nbsp;
      <a href="/privacy">Privacy</a></span>
      <img
        src="/images/ZAPLogoHorizontal_PrimaryColor_White.png"
        alt="Funded by ZAP — Zoo, Arts & Parks"
        class="zap-logo"
      />
    </div>
  </div>
</footer>

<style>
  footer {
    background: #0e1327;
    color: rgba(255, 255, 255, 0.55);
    font-size: 14px;
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
    padding-top: 48px;
    padding-bottom: 40px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .brand-logo {
    height: 48px;
    width: 48px;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
    background: #dbeafe;
    border-radius: 10px;
    padding: 6px;
  }

  .logo {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--white);
    display: block;
    margin-bottom: 4px;
  }

  .footer-brand p {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-end;
  }

  .footer-nav-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
  }

  .footer-nav-sub a {
    color: rgba(255, 255, 255, 0.38) !important;
    font-size: 14px !important;
  }

  .footer-nav-sub a:hover { color: var(--gold-lt) !important; }

  .footer-nav a {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.2s;
    letter-spacing: 0.03em;
  }

  .footer-nav a:hover { color: var(--gold-lt); }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 16px 0;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .zap-logo {
    height: 28px;
    width: auto;
    opacity: 0.85;
    display: block;
  }

  .footer-bottom a {
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.2s;
  }
  .footer-bottom a:hover { color: var(--gold-lt); }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: 24px;
    }
    .footer-nav { gap: 16px; }
  }
</style>
