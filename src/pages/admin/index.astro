---
import '../../styles/admin.css';

const sessionCookie = Astro.cookies.get('session')?.value;
if (sessionCookie) {
  try {
    const { adminAuth } = await import('../../lib/firebase-admin');
    await adminAuth.verifySessionCookie(sessionCookie, true);
    return Astro.redirect('/admin/dashboard');
  } catch {
    Astro.cookies.delete('session', { path: '/' });
  }
}

const firebaseConfig = {
  apiKey:     import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:  import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — Magna Arts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
</head>
<body class="admin-login-body">
  <div class="login-card">
    <div class="login-logo">
      <img src="/images/ArtsCouncil_logo.png" alt="Magna Arts Council" />
      <span class="login-logo-text">Magna Arts Council</span>
      <span class="login-logo-sub">Board Portal</span>
    </div>

    <!-- Step 1: Email / password -->
    <form id="login-form" novalidate>
      <div class="field-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>
      <div class="field-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" />
      </div>
      <div id="login-error" class="error-msg" hidden></div>
      <button type="submit" class="btn btn-primary btn-full" id="login-btn">
        Sign In
      </button>
    </form>

    <!-- Step 2: TOTP verification (shown after password succeeds for enrolled accounts) -->
    <div id="totp-panel" hidden>
      <p class="mfa-hint">Enter the 6-digit code from your authenticator app.</p>
      <div class="field-group">
        <label for="totp-code">Authenticator Code</label>
        <input
          type="text"
          id="totp-code"
          inputmode="numeric"
          autocomplete="one-time-code"
          maxlength="6"
          placeholder="000000"
        />
      </div>
      <div id="totp-error" class="error-msg" hidden></div>
      <button type="button" class="btn btn-primary btn-full" id="totp-btn">
        Verify
      </button>
    </div>
  </div>

  <script type="module" define:vars={{ firebaseConfig }}>
    import { initializeApp }                   from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
    import { getAuth, signInWithEmailAndPassword } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-auth.js';

    const app  = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    const loginForm  = document.getElementById('login-form');
    const loginError = document.getElementById('login-error');
    const loginBtn   = document.getElementById('login-btn');
    const totpPanel  = document.getElementById('totp-panel');
    const totpInput  = document.getElementById('totp-code');
    const totpError  = document.getElementById('totp-error');
    const totpBtn    = document.getElementById('totp-btn');

    // Holds the Firebase user across the two-step flow
    let pendingUser = null;

    function showError(el, msg) {
      el.textContent = msg;
      el.hidden = false;
    }

    function setLoading(btn, loading, defaultLabel) {
      btn.disabled    = loading;
      btn.textContent = loading ? 'Please wait…' : defaultLabel;
    }

    // -------------------------------------------------------------------------
    // Step 1: Email / password
    // -------------------------------------------------------------------------
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      loginError.hidden = true;
      setLoading(loginBtn, true, 'Sign In');

      const email    = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;

      try {
        const cred    = await signInWithEmailAndPassword(auth, email, password);
        pendingUser   = cred.user;
        const idToken = await pendingUser.getIdToken();

        // Check whether this user has completed TOTP enrollment
        const statusRes = await fetch('/api/admin/totp-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken }),
        });

        if (!statusRes.ok) throw new Error('Status check failed');

        const { enrolled } = await statusRes.json();

        if (!enrolled) {
          // Send to enrollment flow
          window.location.href = '/admin/enroll-mfa';
          return;
        }

        // Show the TOTP panel
        loginForm.hidden    = true;
        totpPanel.hidden    = false;
        totpInput.focus();
        setLoading(loginBtn, false, 'Sign In');

      } catch (err) {
        const msg =
          err.code === 'auth/invalid-credential'  ? 'Invalid email or password.' :
          err.code === 'auth/too-many-requests'   ? 'Too many attempts. Try again later.' :
          err.code === 'auth/user-disabled'       ? 'This account has been disabled.' :
                                                    'Sign-in failed. Please try again.';
        showError(loginError, msg);
        setLoading(loginBtn, false, 'Sign In');
      }
    });

    // -------------------------------------------------------------------------
    // Step 2: TOTP verification
    // -------------------------------------------------------------------------
    async function submitTotp() {
      totpError.hidden = true;
      const code = totpInput.value.trim();

      if (!/^\d{6}$/.test(code)) {
        showError(totpError, 'Please enter a 6-digit code.');
        return;
      }

      setLoading(totpBtn, true, 'Verify');

      try {
        // Re-fetch token in case it has rotated since Step 1
        const idToken   = await pendingUser.getIdToken();
        const verifyRes = await fetch('/api/admin/totp-verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken, code }),
        });

        if (verifyRes.ok) {
          window.location.href = '/admin/dashboard';
        } else {
          const { error } = await verifyRes.json();
          showError(totpError, error ?? 'Invalid code. Please try again.');
          setLoading(totpBtn, false, 'Verify');
        }
      } catch {
        showError(totpError, 'Something went wrong. Please try again.');
        setLoading(totpBtn, false, 'Verify');
      }
    }

    totpBtn.addEventListener('click', submitTotp);

    totpInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') submitTotp();
    });
  </script>
</body>
</html>
