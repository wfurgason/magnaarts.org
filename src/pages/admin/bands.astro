---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';

const user = Astro.locals.user;

const filterParam = Astro.url.searchParams.get('filter') || 'all';

// Load band applications
const snap = await adminDb.collection('band_applications')
  .orderBy('submitted_at', 'desc')
  .get();

type Band = {
  id: string;
  band_name: string;
  genre: string;
  contact_name: string;
  contact_email: string;
  contact_phone: string;
  bio: string;
  music_link: string;
  website: string;
  promo_photo_url: string;
  tech_rider_url: string;
  set_length: string;
  member_count: string | number;
  available_dates: string[];   // new checkbox array
  availability: string;        // legacy text field (if any old submissions)
  performed_before: boolean | string;
  additional_notes: string;
  status: string;
  assignedShellId?: string;
  assignedDate?: string;
  submittedAt?: any;
  everApproved?: boolean;
  everAssigned?: boolean;
  everPublished?: boolean;
  goodStanding?: boolean;
  rejectionNotes?: string;
};

let bands = snap.docs.map(d => ({ ...d.data(), id: d.id })) as Band[];

// Available filters
const filters = ['all', 'pending', 'approved', 'assigned', 'good_standing', 'rejected', 'published'];

if (filterParam !== 'all') {
  if (filterParam === 'approved') {
    // Backwards-compat: also catch old records that advanced past pending without everApproved flag
    bands = bands.filter(b =>
      (b.everApproved || ['approved','assigned','published','good_standing'].includes(b.status))
      && b.status !== 'rejected'
    );
  } else if (filterParam === 'assigned') {
    bands = bands.filter(b =>
      (b.everAssigned || ['assigned','published','good_standing'].includes(b.status))
      && b.status !== 'rejected'
    );
  } else if (filterParam === 'published') {
    bands = bands.filter(b =>
      (b.everPublished || ['published','good_standing'].includes(b.status))
      && b.status !== 'rejected'
    );
  } else if (filterParam === 'good_standing') {
    bands = bands.filter(b => b.goodStanding || b.status === 'good_standing');
  } else if (filterParam === 'rejected') {
    bands = bands.filter(b => b.status === 'rejected');
  } else {
    bands = bands.filter(b => (b.status || 'pending') === filterParam);
  }
}

// Load available event shells for the assignment dropdown
// Show 'shell' status (unassigned) so board can pick a date
const shellsSnap = await adminDb.collection('park_events')
  .where('status', '==', 'shell')
  .orderBy('date', 'asc')
  .get();

const availableShells = shellsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
---

<AdminLayout title="Band Applications" user={user}>
  <div class="page-header">
    <h1>Band Applications</h1>
    <div class="filter-tabs">
      {filters.map(f => (
        <a
          href={`/admin/bands${f === 'all' ? '' : `?filter=${f}`}`}
          class:list={['filter-tab', { active: filterParam === f }]}
        >
          {f === 'good_standing' ? '⭐ Good Standing' : f.charAt(0).toUpperCase() + f.slice(1)}
        </a>
      ))}
    </div>
  </div>

  {bands.length === 0 ? (
    <div class="empty-state">
      <p>No applications matching this filter.</p>
    </div>
  ) : (
    <div class="submission-list">
      {bands.map(band => (
        <div class="submission-card" id={band.id}>
          <div class="submission-header">
            <div class="submission-title-group">
              {band.promo_photo_url && (
                <img src={band.promo_photo_url} alt={band.band_name} class="submission-photo" />
              )}
              <div>
                <h2 class="submission-name">{band.band_name}</h2>
                <span class="submission-meta">{band.genre} · {band.member_count} members · {band.set_length} set</span>
              </div>
            </div>
            <span class={`badge badge-${band.status || 'pending'}`}>{band.status || 'pending'}</span>
          </div>

          <div class="submission-body">
            <div class="detail-grid">
              <div>
                <div class="detail-label">Contact</div>
                <div>{band.contact_name}</div>
                <div><a href={`mailto:${band.contact_email}`}>{band.contact_email}</a></div>
                <div>{band.contact_phone}</div>
              </div>
              <div>
                <div class="detail-label">Available Dates</div>
                {band.available_dates && band.available_dates.length > 0 ? (
                  <div class="date-chips">
                    {band.available_dates.map(d => {
                      const dt = new Date(d + 'T12:00:00');
                      const label = dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                      return <span class="date-chip">{label}</span>;
                    })}
                  </div>
                ) : (
                  <div class="muted">{band.availability || '—'}</div>
                )}
              </div>
              <div>
                <div class="detail-label">Performed Before?</div>
                <div>{band.performed_before ? 'Yes' : 'No'}</div>
              </div>
              <div>
                <div class="detail-label">Links</div>
                {band.music_link && <div><a href={band.music_link} target="_blank" rel="noopener">Music ↗</a></div>}
                {band.website && <div><a href={band.website} target="_blank" rel="noopener">Website ↗</a></div>}
                {band.tech_rider_url && <div><a href={band.tech_rider_url} target="_blank" rel="noopener">Tech Rider ↗</a></div>}
              </div>
            </div>

            {band.bio && (
              <div class="detail-bio">
                <div class="detail-label">Bio</div>
                <p>{band.bio}</p>
              </div>
            )}
            {band.additional_notes && (
              <div class="detail-bio">
                <div class="detail-label">Additional Notes</div>
                <p>{band.additional_notes}</p>
              </div>
            )}

            {/* Good Standing notice */}
            {(band.goodStanding || band.status === 'good_standing') && (
              <div class="good-standing-notice">
                <span>⭐</span>
                <span>This band is in <strong>Good Standing</strong> — reliable and welcome back for future seasons.</span>
              </div>
            )}

            {/* Rejection notes */}
            {band.status === 'rejected' && band.rejectionNotes && (
              <div class="rejection-notes-display">
                <div class="detail-label">Rejection Notes</div>
                <p class="rejection-notes-text">{band.rejectionNotes}</p>
              </div>
            )}

            {/* Show assigned date if already assigned */}
            {band.assignedDate && (
              <div class="assigned-notice">
                <span class="assigned-icon">📅</span>
                <span>Assigned to <strong>{new Date(band.assignedDate + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</strong></span>
                <button
                  class="btn-link unassign-btn"
                  data-shell-id={band.assignedShellId}
                  data-band-name={band.band_name}
                >
                  Remove assignment
                </button>
              </div>
            )}
          </div>

          <!-- ── INLINE EDIT FORM ── -->
          <div class="band-edit-form" id={`edit-${band.id}`} style="display:none">
            <div class="edit-grid">
              <label class="edit-field">
                <span class="edit-label">Genre</span>
                <input type="text" name="genre" value={band.genre || ''} />
              </label>
              <label class="edit-field">
                <span class="edit-label">Set Length</span>
                <input type="text" name="set_length" value={band.set_length || ''} placeholder="e.g. 45-60 min" />
              </label>
              <label class="edit-field">
                <span class="edit-label">Member Count</span>
                <input type="number" name="member_count" value={band.member_count || ''} min="1" />
              </label>
              <label class="edit-field">
                <span class="edit-label">Contact Name</span>
                <input type="text" name="contact_name" value={band.contact_name || ''} />
              </label>
              <label class="edit-field">
                <span class="edit-label">Contact Email</span>
                <input type="email" name="contact_email" value={band.contact_email || ''} />
              </label>
              <label class="edit-field">
                <span class="edit-label">Contact Phone</span>
                <input type="tel" name="contact_phone" value={band.contact_phone || ''} />
              </label>
              <label class="edit-field">
                <span class="edit-label">Music Link</span>
                <input type="url" name="music_link" value={band.music_link || ''} placeholder="https://" />
              </label>
              <label class="edit-field">
                <span class="edit-label">Website</span>
                <input type="url" name="website" value={band.website || ''} placeholder="https://" />
              </label>
              <label class="edit-field edit-field--full">
                <span class="edit-label">Available Dates <span class="edit-hint">(comma-separated, YYYY-MM-DD)</span></span>
                <input type="text" name="available_dates" value={(band.available_dates || []).join(', ')} />
              </label>
              <label class="edit-field edit-field--full">
                <span class="edit-label">Bio</span>
                <textarea name="bio" rows="4">{band.bio || ''}</textarea>
              </label>
              <label class="edit-field edit-field--full">
                <span class="edit-label">Additional Notes</span>
                <textarea name="additional_notes" rows="3">{band.additional_notes || ''}</textarea>
              </label>
              <label class="edit-field edit-check">
                <input type="checkbox" name="performed_before" checked={!!band.performed_before} />
                <span class="edit-label">Performed with us before?</span>
              </label>
            </div>
            <div class="edit-actions">
              <span class="edit-error" style="display:none"></span>
              <button type="button" class="btn btn-ghost edit-cancel-btn" data-band-id={band.id}>Cancel</button>
              <button type="button" class="btn btn-success edit-save-btn" data-band-id={band.id}>Save Changes</button>
            </div>
          </div>

          <div class="submission-actions">
            {/* Approve / Reject for pending bands */}
            {(band.status === 'pending') && (
              <>
                <button class="btn btn-success" data-action="approve" data-id={band.id} data-collection="band_applications">
                  Approve
                </button>
                <button
                  class="btn btn-primary assign-btn"
                  data-band-id={band.id}
                  data-band-name={band.band_name}
                  data-available={JSON.stringify(band.available_dates || [])}
                  data-auto-approve="true"
                >
                  Approve &amp; Assign Date →
                </button>
                <button class="btn btn-danger" data-action="reject" data-id={band.id} data-band-name={band.band_name} data-collection="band_applications">
                  Reject
                </button>
              </>
            )}

            {/* Approved: assign to a date */}
            {(band.status === 'approved') && (
              <button
                class="btn btn-primary assign-btn"
                data-band-id={band.id}
                data-band-name={band.band_name}
                data-available={JSON.stringify(band.available_dates || [])}
              >
                Assign to Date →
              </button>
            )}

            {/* Assigned: can unassign (reassign) */}
            {(band.status === 'assigned') && (
              <button
                class="btn btn-outline unassign-btn"
                data-shell-id={band.assignedShellId}
                data-band-name={band.band_name}
              >
                Reassign Date
              </button>
            )}

            {/* Good Standing: can reassign for a new season */}
            {(band.status === 'good_standing') && (
              <>
                <button
                  class="btn btn-primary assign-btn"
                  data-band-id={band.id}
                  data-band-name={band.band_name}
                  data-available={JSON.stringify(band.available_dates || [])}
                >
                  Assign to Date →
                </button>
              </>
            )}

            {/* Edit button — always available */}
            <button
              class="btn btn-outline edit-btn"
              data-band-id={band.id}
            >
              ✏️ Edit
            </button>

            {/* Delete button — always available except published */}
            {(band.status !== 'published') && (
              <button
                class="btn btn-danger delete-btn"
                style="margin-left:auto"
                data-band-id={band.id}
                data-band-name={band.band_name}
                data-assigned-shell={band.assignedShellId || ''}
              >
                Delete
              </button>
            )}

            {/* Status change dropdown — shown for all non-pending bands */}
            {band.status !== 'pending' && (
              <select class="status-select" data-band-id={band.id} data-band-name={band.band_name}>
                <option value="" disabled selected>Change status…</option>
                {band.status === 'rejected'
                  ? <option value="approve">Approve</option>
                  : <option value={band.goodStanding ? 'remove-good-standing' : 'add-good-standing'}>
                      {band.goodStanding ? 'Remove Good Standing' : '⭐ Mark Good Standing'}
                    </option>
                }
                {band.status !== 'rejected' && <option value="reject">Reject</option>}
              </select>
            )}
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- ── ASSIGN TO DATE MODAL ───────────────────────────────────────── -->
  <div id="assign-modal" class="modal-backdrop" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <h2>Assign to Date</h2>
        <button id="assign-close" class="modal-close" aria-label="Close">✕</button>
      </div>

      <p class="modal-sub" id="assign-sub">Select a date for <strong id="assign-band-name"></strong>.</p>

      <div id="assign-shells">
        {availableShells.length === 0 ? (
          <p class="empty-shells">No open event dates available. Generate event shells in <a href="/admin/seasons">Season Setup</a> first.</p>
        ) : (
          <div class="shell-list">
            {availableShells.map(shell => (
              <label class="shell-option" data-date={shell.date}>
                <input type="radio" name="shell" value={shell.id} data-display={shell.displayDate} />
                <div class="shell-option-body">
                  <span class="shell-date">{shell.displayDate}</span>
                  <span class="shell-time">{shell.startTime} · {shell.venue}</span>
                </div>
              </label>
            ))}
          </div>
        )}
      </div>

      <div id="assign-match-warning" class="match-warning" hidden>
        ⚠️ This band did not list this date as available. You can still assign them — just confirm with them first.
      </div>

      <div id="assign-error" class="error-msg" hidden></div>

      <div class="modal-actions">
        <button type="button" id="assign-cancel" class="btn btn-ghost">Cancel</button>
        <button type="button" id="assign-submit" class="btn btn-primary" disabled>
          Assign Date →
        </button>
      </div>
    </div>
  </div>

  <!-- ── REJECTION MODAL ─────────────────────────────────────────────────────────── -->
  <div id="reject-modal" class="modal-backdrop" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <h2>Reject Band</h2>
        <button id="reject-close" class="modal-close" aria-label="Close">✕</button>
      </div>
      <p class="modal-sub">Rejecting <strong id="reject-band-name"></strong>. All milestone flags will be cleared.</p>
      <label class="reject-label" for="reject-notes">Reason for rejection <span class="reject-optional">(optional — internal only)</span></label>
      <textarea id="reject-notes" class="reject-textarea" rows="4" placeholder="e.g. No-show, unprofessional conduct, could not confirm availability…"></textarea>
      <div id="reject-error" class="error-msg" hidden></div>
      <div class="modal-actions">
        <button type="button" id="reject-cancel" class="btn btn-ghost">Cancel</button>
        <button type="button" id="reject-submit" class="btn btn-danger">Reject Band</button>
      </div>
    </div>
  </div>

  <script src="/admin-bands.js" defer></script>

  <style>
    .date-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
    .date-chip {
      display: inline-block;
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      color: #1d4ed8;
      font-size: 12px;
      font-weight: 600;
      padding: 3px 9px;
      border-radius: 100px;
    }
    .muted { color: var(--muted, #5a5a7a); font-size: 14px; }
    .assigned-notice {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      color: #166534;
      margin-top: 12px;
    }
    .assigned-icon { font-size: 16px; }
    .btn-link {
      background: none;
      border: none;
      color: var(--red, #b52626);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      padding: 0;
      margin-left: auto;
      text-decoration: underline;
    }
    .btn-outline {
      background: transparent;
      border: 1.5px solid var(--border, #e5e5e5);
      color: var(--navy, #1a2456);
    }

    /* Assign modal shell list */
    .shell-list { display: flex; flex-direction: column; gap: 8px; margin: 16px 0; }
    .shell-option {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 16px;
      border: 1.5px solid var(--border, #e5e5e5);
      border-radius: 8px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .shell-option:has(input:checked) {
      border-color: var(--blue, #2563b0);
      background: #eff6ff;
    }
    .shell-option input[type="radio"] {
      width: 16px;
      height: 16px;
      accent-color: var(--blue, #2563b0);
      flex-shrink: 0;
      cursor: pointer;
    }
    .shell-option-body { display: flex; flex-direction: column; gap: 2px; }
    .shell-date { font-size: 14px; font-weight: 600; color: var(--navy, #1a2456); }
    .shell-time { font-size: 12px; color: var(--muted, #5a5a7a); }
    .empty-shells { font-size: 14px; color: var(--muted, #5a5a7a); padding: 16px 0; }
    .empty-shells a { color: var(--blue, #2563b0); }

    .match-warning {
      background: #fffbeb;
      border: 1px solid #fde68a;
      color: #92400e;
      font-size: 13px;
      font-weight: 500;
      padding: 10px 14px;
      border-radius: 8px;
      margin-bottom: 8px;
    }
    .modal-sub { font-size: 14px; color: var(--muted, #5a5a7a); margin: 4px 0 0; }

    .good-standing-notice {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      color: #78350f;
      margin-top: 12px;
    }

    .badge-good_standing { background: #fef9c3; color: #713f12; }

    .btn-gold {
      background: var(--gold, #e8a020);
      color: #fff;
      border: none;
    }
    .btn-gold:hover { background: var(--gold-lt, #f5b942); }

    .rejection-notes-display {
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-radius: 8px;
      padding: 10px 14px;
      margin-top: 12px;
    }
    .rejection-notes-text { font-size: 13px; color: #7f1d1d; margin: 4px 0 0; }

    .reject-label { display: block; font-size: 13px; font-weight: 600; color: var(--navy, #1a2456); margin: 16px 0 6px; }
    .reject-optional { font-weight: 400; color: var(--muted, #5a5a7a); }
    .reject-textarea {
      width: 100%;
      box-sizing: border-box;
      padding: 10px 12px;
      border: 1.5px solid var(--border, #e5e5e5);
      border-radius: 6px;
      font-size: 13px;
      font-family: inherit;
      resize: vertical;
      min-height: 90px;
    }
    .reject-textarea:focus { outline: none; border-color: var(--blue, #2563b0); }

    .status-select {
      height: 36px;
      padding: 0 10px;
      border: 1.5px solid var(--border, #e5e5e5);
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      background: #fff;
      color: var(--navy, #1a2456);
      cursor: pointer;
      margin-left: auto;
    }
    .status-select:focus { outline: none; border-color: var(--blue, #2563b0); }

    /* ── Inline edit form ── */
    .band-edit-form {
      border-top: 1.5px solid #e5e5e5;
      padding: 20px 0 8px;
      margin-top: 4px;
    }
    .edit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 20px;
    }
    .edit-field { display: flex; flex-direction: column; gap: 4px; }
    .edit-field--full { grid-column: 1 / -1; }
    .edit-check { flex-direction: row; align-items: center; gap: 8px; grid-column: 1 / -1; }
    .edit-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #5a5a7a; }
    .edit-hint  { font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 11px; color: #9ca3af; }
    .edit-field input[type="text"],
    .edit-field input[type="email"],
    .edit-field input[type="tel"],
    .edit-field input[type="url"],
    .edit-field input[type="number"],
    .edit-field textarea {
      padding: 8px 10px;
      border: 1.5px solid #e5e5e5;
      border-radius: 6px;
      font-size: 13px;
      font-family: inherit;
      color: #1a2456;
      background: #fff;
    }
    .edit-field input:focus,
    .edit-field textarea:focus { outline: none; border-color: #2563b0; }
    .edit-field textarea { resize: vertical; min-height: 80px; }
    .edit-actions {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 16px;
      justify-content: flex-end;
    }
    .edit-error { font-size: 13px; color: #b52626; margin-right: auto; }
  </style>

</AdminLayout>
