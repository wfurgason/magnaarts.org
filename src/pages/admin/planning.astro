---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';
import { FieldValue } from 'firebase-admin/firestore';

const user = Astro.locals.user;

// ── Load existing shells ──────────────────────────────────────────────────
const [seasonsSnap, shellsSnap, openMicSnap, artNightSnap] = await Promise.all([
  adminDb.collection('park_seasons').orderBy('year', 'desc').get(),
  adminDb.collection('park_events').orderBy('date', 'asc').get(),
  adminDb.collection('open_mic_events').orderBy('date', 'asc').get(),
  adminDb.collection('art_night_events').orderBy('date', 'asc').get(),
]);

const allShells         = shellsSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const allOpenMicShells  = openMicSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];
const allArtNightShells = artNightSnap.docs.map(d => ({ id: d.id, ...d.data() })) as any[];

// ── POST handling ─────────────────────────────────────────────────────────
let flashMsg  = '';
let flashType = '';

if (Astro.request.method === 'POST') {
  const form       = await Astro.request.formData();
  const action     = form.get('action')?.toString();

  // ── Create shells ───────────────────────────────────────────────────────
  if (action === 'create_season') {
    const year       = parseInt(form.get('year')?.toString() || '0');
    const venue      = form.get('venue')?.toString() || '';
    const address    = form.get('address')?.toString() || '';
    const start      = form.get('startTime')?.toString() || '7:00 PM';
    const datesRaw   = form.get('dates')?.toString() || '';
    const seriesType = form.get('seriesType')?.toString() || 'music_in_park';

    const dates = datesRaw.split('\n').map(d => d.trim()).filter(d => /^\d{4}-\d{2}-\d{2}$/.test(d));

    if (!year || dates.length === 0) {
      flashMsg  = 'Please enter a valid year and at least one date (YYYY-MM-DD format).';
      flashType = 'error';
    } else if (seriesType === 'open_mic') {
      const omTitle    = form.get('omTitle')?.toString() || 'Open Mic Night';
      const omImageUrl = form.get('omImageUrl')?.toString() || '';
      const omDesc     = form.get('omDescription')?.toString() || '';

      const existing      = await adminDb.collection('open_mic_events').where('season', '==', year).get();
      const existingDates = new Set(existing.docs.map(d => d.data().date));
      const batch = adminDb.batch();
      let created = 0;
      for (const date of dates) {
        if (existingDates.has(date)) continue;
        const ref     = adminDb.collection('open_mic_events').doc();
        const d       = new Date(date + 'T12:00:00');
        const display = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        batch.set(ref, {
          season: year, date, displayDate: display, startTime: start, venue, address,
          title: omTitle, imageUrl: omImageUrl, description: omDesc,
          eventType: 'open_mic', status: 'shell', createdAt: FieldValue.serverTimestamp(),
        });
        created++;
      }
      await batch.commit();
      flashMsg  = `Open Mic Night: ${created} new shell(s) created (${dates.length} dates total).`;
      flashType = 'success';

    } else if (seriesType === 'group_art_night') {
      const anTitle = form.get('anTitle')?.toString() || 'Group Art Night';
      const anDesc  = form.get('anDescription')?.toString() || '';

      const existing      = await adminDb.collection('art_night_events').where('season', '==', year).get();
      const existingDates = new Set(existing.docs.map(d => d.data().date));
      const batch = adminDb.batch();
      let created = 0;
      for (const date of dates) {
        if (existingDates.has(date)) continue;
        const ref     = adminDb.collection('art_night_events').doc();
        const d       = new Date(date + 'T12:00:00');
        const display = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        batch.set(ref, {
          season: year, date, displayDate: display, startTime: start, venue, address,
          title: anTitle, description: anDesc,
          eventType: 'group_art_night', status: 'shell',
          presenterId: null, presenterName: null, presenterConfirmed: false,
          createdAt: FieldValue.serverTimestamp(),
        });
        created++;
      }
      await batch.commit();
      flashMsg  = `Group Art Night: ${created} new shell(s) created (${dates.length} dates total).`;
      flashType = 'success';

    } else {
      // Music & Movies in the Park (original flow)
      await adminDb.collection('park_seasons').doc(String(year)).set({
        year, venue, address, startTime: start, dateCount: dates.length,
        createdAt: FieldValue.serverTimestamp(), createdBy: user?.email || 'admin',
      });
      const existing      = await adminDb.collection('park_events').where('season', '==', year).get();
      const existingDates = new Set(existing.docs.map(d => d.data().date));
      const batch = adminDb.batch();
      let created = 0;
      for (const date of dates) {
        if (existingDates.has(date)) continue;
        const ref     = adminDb.collection('park_events').doc();
        const d       = new Date(date + 'T12:00:00');
        const display = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        batch.set(ref, {
          season: year, date, displayDate: display, startTime: start, venue, address,
          eventType: 'music_movie_in_park', status: 'shell',
          bandId: null, bandName: null, bandConfirmed: false, movie: null, movieToken: null,
          createdAt: FieldValue.serverTimestamp(),
        });
        created++;
      }
      await batch.commit();
      flashMsg  = `Music & Movies in the Park: Season ${year} set up. ${created} new shell(s) created.`;
      flashType = 'success';
    }
  }

  // ── Delete a shell ──────────────────────────────────────────────────────
  if (action === 'delete_shell') {
    const shellId = form.get('shellId')?.toString();
    const col     = form.get('collection')?.toString() || 'park_events';
    if (shellId) {
      await adminDb.collection(col).doc(shellId).delete();
      flashMsg  = 'Event shell deleted.';
      flashType = 'success';
    }
  }

  // ── Edit a shell ────────────────────────────────────────────────────────
  if (action === 'update_shell') {
    const shellId   = form.get('shellId')?.toString();
    const venue     = form.get('venue')?.toString();
    const address   = form.get('address')?.toString();
    const startTime = form.get('startTime')?.toString();
    const col       = form.get('collection')?.toString() || 'park_events';
    if (shellId) {
      await adminDb.collection(col).doc(shellId).update({ venue, address, startTime });
      flashMsg  = 'Event shell updated.';
      flashType = 'success';
    }
  }

  return Astro.redirect('/admin/planning');
}

// ── Group shells by season year ───────────────────────────────────────────
const shellsBySeason: Record<number, any[]> = {};
for (const s of allShells) {
  if (!shellsBySeason[s.season]) shellsBySeason[s.season] = [];
  shellsBySeason[s.season].push(s);
}

const openMicBySeason: Record<number, any[]> = {};
for (const s of allOpenMicShells) {
  if (!openMicBySeason[s.season]) openMicBySeason[s.season] = [];
  openMicBySeason[s.season].push(s);
}

const artNightBySeason: Record<number, any[]> = {};
for (const s of allArtNightShells) {
  if (!artNightBySeason[s.season]) artNightBySeason[s.season] = [];
  artNightBySeason[s.season].push(s);
}

const totalShells =
  Object.keys(shellsBySeason).length +
  Object.keys(openMicBySeason).length +
  Object.keys(artNightBySeason).length;
---

<AdminLayout title="Plan Events" user={user}>

  <div class="page-header">
    <h1>Plan Events</h1>
    <p class="page-sub">Select an event to set up a new series and generate event shells.</p>
  </div>

  {flashMsg && <div class={`flash flash-${flashType}`}>{flashMsg}</div>}

  <!-- ── WIZARD ────────────────────────────────────────────────────────── -->
  <section class="card">
    <h2 class="card-title">Set Up a New Event Series</h2>
    <p class="card-sub">Choose an event, fill in the details, and enter one date per line. A shell will be created for each date.</p>

    <form method="POST" class="season-form" id="season-form">
      <input type="hidden" name="action" value="create_season" />

      <!-- Event title dropdown -->
      <div class="form-field">
        <label for="event-type-select">Event Title <span class="req">*</span></label>
        <select id="event-type-select" name="seriesType">
          <option value="">— Select an event —</option>
          <option value="music_in_park">Music &amp; Movies in the Park</option>
          <option value="open_mic">Open Mic Night</option>
          <option value="group_art_night">Group Art Night</option>
          <option value="annual_seminar">Annual Arts Seminar</option>
          <option value="arts_festival">Magna Main Street Arts Festival</option>
          <option value="custom">— or something else —</option>
        </select>
      </div>

      <!-- Placeholder notice (seminar, festival, custom) -->
      <div id="placeholder-notice" class="placeholder-notice" hidden>
        <div class="placeholder-icon">🚧</div>
        <strong>Planning workflow coming soon.</strong>
        <p>This event type is on the roadmap. We'll build it out in a future session.</p>
      </div>

      <!-- Main form body (music, open mic, art night) -->
      <div id="main-form-body" hidden>

        <div class="form-row">
          <div class="form-field">
            <label for="year">Season Year <span class="req">*</span></label>
            <input type="number" id="year" name="year" value="2026" min="2024" max="2040" />
          </div>
          <div class="form-field">
            <label for="startTime">Default Start Time <span class="req">*</span></label>
            <input type="text" id="startTime" name="startTime" placeholder="7:00 PM" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="venue">Venue Name <span class="req">*</span></label>
            <input type="text" id="venue" name="venue" placeholder="Venue" />
          </div>
          <div class="form-field">
            <label for="address">Address <span class="req">*</span></label>
            <input type="text" id="address" name="address" placeholder="Address" />
          </div>
        </div>

        <!-- Open Mic–specific fields -->
        <div id="open-mic-fields" class="event-extra-fields" style="display:none;">
          <div class="form-field">
            <label for="omTitle">Event Title</label>
            <input type="text" id="omTitle" name="omTitle" value="Open Mic Night" placeholder="Open Mic Night" />
          </div>
          <div class="form-field">
            <label for="omImageUrl">
              Image URL
              <span class="field-hint">One image used for all dates in this series</span>
            </label>
            <input type="url" id="omImageUrl" name="omImageUrl" placeholder="https://…" />
          </div>
          <div class="form-field">
            <label for="omDescription">Description</label>
            <textarea id="omDescription" name="omDescription" rows="3"
              placeholder="Join us for an evening of music, poetry, and performance. All are welcome to perform or just enjoy the show."></textarea>
          </div>
        </div>

        <!-- Group Art Night–specific fields -->
        <div id="art-night-fields" class="event-extra-fields" style="display:none;">
          <div class="form-field">
            <label for="anTitle">Event Title</label>
            <input type="text" id="anTitle" name="anTitle" value="Group Art Night" placeholder="Group Art Night" />
          </div>
          <div class="form-field">
            <label for="anDescription">Description</label>
            <textarea id="anDescription" name="anDescription" rows="3"
              placeholder="A community art session guided by a local artist. All skill levels welcome."></textarea>
          </div>
          <div class="info-callout">
            <span>ℹ️</span>
            <span>After creating shells, use the table below to assign a presenter from
              <strong>Art Class submissions</strong>. Presenter assignment is coming in the next build.</span>
          </div>
        </div>

        <div class="form-field">
          <label for="dates">
            Event Dates <span class="req">*</span>
            <span class="field-hint">One date per line — YYYY-MM-DD format</span>
          </label>
          <textarea
            id="dates"
            name="dates"
            rows="8"
            placeholder={"2026-06-12\n2026-06-19\n2026-06-26\n2026-07-10"}
            spellcheck="false"
          ></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Generate Event Shells →</button>
        </div>
      </div>
    </form>
  </section>

  <!-- ── MUSIC & MOVIES IN THE PARK ────────────────────────────────────── -->
  {Object.entries(shellsBySeason).sort(([a],[b]) => Number(b)-Number(a)).map(([yr, shells]) => (
    <section class="card">
      <div class="season-header">
        <h2 class="card-title">🎵 Music &amp; Movies in the Park — {yr} <span class="count-badge">{shells.length} events</span></h2>
      </div>
      <table class="shells-table">
        <thead>
          <tr>
            <th>Date</th><th>Start</th><th>Venue</th><th>Status</th>
            <th>Band</th><th>Confirmed</th><th>Movie</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {shells.map(shell => (
            <tr id={`shell-${shell.id}`}>
              <td class="date-cell">{shell.displayDate}</td>
              <td>{shell.startTime}</td>
              <td class="venue-cell">{shell.venue}</td>
              <td><span class={`badge badge-${shell.status}`}>{shell.status}</span></td>
              <td>{shell.bandName || <span class="dim">—</span>}</td>
              <td>
                {shell.bandName
                  ? (shell.bandConfirmed ? <span class="check-yes">✓ Yes</span> : <span class="check-no">✗ Pending</span>)
                  : <span class="dim">—</span>}
              </td>
              <td>{shell.movie ? <span class="check-yes">✓ {shell.movie}</span> : <span class="dim">—</span>}</td>
              <td class="actions-cell">
                <button class="btn-sm btn-outline"
                  onclick={`openEditModal('${shell.id}','${(shell.venue||'').replace(/'/g,"\\'")}','${(shell.address||'').replace(/'/g,"\\'")}','${shell.startTime}','park_events')`}>
                  Edit
                </button>
                {shell.status === 'band_assigned' && (
                  <button class="btn-sm btn-confirm action-btn"
                    data-action="confirm" data-shell-id={shell.id} data-band-name={shell.bandName}>
                    Mark Confirmed
                  </button>
                )}
                {(shell.status === 'band_assigned' || shell.status === 'confirmed') && (
                  <button class="btn-sm btn-outline action-btn"
                    data-action="unassign" data-shell-id={shell.id} data-band-name={shell.bandName}>
                    Unassign
                  </button>
                )}
                {shell.status === 'confirmed' && (
                  <button class="btn-sm btn-publish action-btn"
                    data-action="publish" data-shell-id={shell.id} data-band-name={shell.bandName}>
                    Publish ↗
                  </button>
                )}
                {shell.status === 'shell' && (
                  <form method="POST" style="display:inline" onsubmit="return confirm('Delete this event shell? This cannot be undone.')">
                    <input type="hidden" name="action" value="delete_shell" />
                    <input type="hidden" name="shellId" value={shell.id} />
                    <input type="hidden" name="collection" value="park_events" />
                    <button type="submit" class="btn-sm btn-danger">Delete</button>
                  </form>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}

  <!-- ── OPEN MIC NIGHT ─────────────────────────────────────────────────── -->
  {Object.entries(openMicBySeason).sort(([a],[b]) => Number(b)-Number(a)).map(([yr, shells]) => (
    <section class="card">
      <div class="season-header">
        <h2 class="card-title">🎤 Open Mic Night — {yr} <span class="count-badge">{shells.length} events</span></h2>
      </div>
      <table class="shells-table">
        <thead>
          <tr>
            <th>Date</th><th>Start</th><th>Venue</th><th>Status</th><th>Image</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {shells.map(shell => (
            <tr>
              <td class="date-cell">{shell.displayDate}</td>
              <td>{shell.startTime}</td>
              <td class="venue-cell">{shell.venue}</td>
              <td><span class={`badge badge-${shell.status}`}>{shell.status}</span></td>
              <td>{shell.imageUrl ? <span class="check-yes">✓ Set</span> : <span class="dim">—</span>}</td>
              <td class="actions-cell">
                <button class="btn-sm btn-outline"
                  onclick={`openEditModal('${shell.id}','${(shell.venue||'').replace(/'/g,"\\'")}','${(shell.address||'').replace(/'/g,"\\'")}','${shell.startTime}','open_mic_events')`}>
                  Edit
                </button>
                {shell.status === 'shell' && (
                  <form method="POST" style="display:inline" onsubmit="return confirm('Delete this event shell?')">
                    <input type="hidden" name="action" value="delete_shell" />
                    <input type="hidden" name="shellId" value={shell.id} />
                    <input type="hidden" name="collection" value="open_mic_events" />
                    <button type="submit" class="btn-sm btn-danger">Delete</button>
                  </form>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}

  <!-- ── GROUP ART NIGHT ────────────────────────────────────────────────── -->
  {Object.entries(artNightBySeason).sort(([a],[b]) => Number(b)-Number(a)).map(([yr, shells]) => (
    <section class="card">
      <div class="season-header">
        <h2 class="card-title">✦ Group Art Night — {yr} <span class="count-badge">{shells.length} events</span></h2>
      </div>
      <table class="shells-table">
        <thead>
          <tr>
            <th>Date</th><th>Start</th><th>Venue</th><th>Status</th><th>Presenter</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {shells.map(shell => (
            <tr>
              <td class="date-cell">{shell.displayDate}</td>
              <td>{shell.startTime}</td>
              <td class="venue-cell">{shell.venue}</td>
              <td><span class={`badge badge-${shell.status}`}>{shell.status}</span></td>
              <td>{shell.presenterName || <span class="dim">—</span>}</td>
              <td class="actions-cell">
                <button class="btn-sm btn-outline"
                  onclick={`openEditModal('${shell.id}','${(shell.venue||'').replace(/'/g,"\\'")}','${(shell.address||'').replace(/'/g,"\\'")}','${shell.startTime}','art_night_events')`}>
                  Edit
                </button>
                <button class="btn-sm btn-assign" disabled title="Presenter assignment coming in next build">
                  Assign Presenter
                </button>
                {shell.status === 'shell' && (
                  <form method="POST" style="display:inline" onsubmit="return confirm('Delete this event shell?')">
                    <input type="hidden" name="action" value="delete_shell" />
                    <input type="hidden" name="shellId" value={shell.id} />
                    <input type="hidden" name="collection" value="art_night_events" />
                    <button type="submit" class="btn-sm btn-danger">Delete</button>
                  </form>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}

  {totalShells === 0 && (
    <div class="empty-state">
      <p>No event shells yet. Select an event type above to get started.</p>
    </div>
  )}

  <!-- ── EDIT MODAL ─────────────────────────────────────────────────────── -->
  <div id="edit-modal" class="modal-overlay" hidden>
    <div class="modal-box">
      <h3>Edit Event Shell</h3>
      <form method="POST" id="edit-form">
        <input type="hidden" name="action" value="update_shell" />
        <input type="hidden" name="shellId" id="edit-shell-id" />
        <input type="hidden" name="collection" id="edit-collection" value="park_events" />
        <div class="form-field">
          <label for="edit-venue">Venue</label>
          <input type="text" id="edit-venue" name="venue" required />
        </div>
        <div class="form-field">
          <label for="edit-address">Address</label>
          <input type="text" id="edit-address" name="address" required />
        </div>
        <div class="form-field">
          <label for="edit-startTime">Start Time</label>
          <input type="text" id="edit-startTime" name="startTime" required />
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-outline" id="modal-cancel-btn">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

</AdminLayout>

<script>
  // ── Event type dropdown ───────────────────────────────────────────────
  const EVENT_PRESETS: Record<string, { venue: string; address: string }> = {
    music_in_park:   { venue: 'Pleasant Green Park',        address: '3250 S 8400 W, Magna, UT 84044' },
    open_mic:        { venue: 'Magna Library',               address: '2675 S 8950 W, Magna, UT 84044' },
    group_art_night: { venue: 'Magna Library',               address: '2675 S 8950 W, Magna, UT 84044' },
    annual_seminar:  { venue: 'Magna Library',               address: '2675 S 8950 W, Magna, UT 84044' },
    arts_festival:   { venue: 'Historic Magna Main Street',  address: '8900 W to 9180 W Magna Main St, Magna, UT 84044' },
    custom:          { venue: '',                            address: '' },
  };
  const PLACEHOLDER_TYPES = new Set(['annual_seminar', 'arts_festival', 'custom']);

  const typeSelect    = document.getElementById('event-type-select') as HTMLSelectElement;
  const mainFormBody  = document.getElementById('main-form-body')    as HTMLElement;
  const placeholderEl = document.getElementById('placeholder-notice') as HTMLElement;
  const omFields      = document.getElementById('open-mic-fields')   as HTMLElement;
  const anFields      = document.getElementById('art-night-fields')  as HTMLElement;
  const venueInput    = document.getElementById('venue')             as HTMLInputElement;
  const addrInput     = document.getElementById('address')           as HTMLInputElement;

  typeSelect.addEventListener('change', () => {
    const val = typeSelect.value;

    // Nothing selected
    if (!val) {
      mainFormBody.hidden  = true;
      placeholderEl.hidden = true;
      return;
    }

    // Placeholder-only event types
    if (PLACEHOLDER_TYPES.has(val)) {
      mainFormBody.hidden  = true;
      placeholderEl.hidden = false;
      return;
    }

    // Active event types — show form
    mainFormBody.hidden  = false;
    placeholderEl.hidden = true;

    // Auto-fill venue / address (still editable)
    const preset = EVENT_PRESETS[val];
    if (preset) {
      venueInput.value = preset.venue;
      addrInput.value  = preset.address;
    }

    // Show/hide event-specific field blocks
    omFields.style.display = val === 'open_mic'        ? 'flex' : 'none';
    anFields.style.display = val === 'group_art_night' ? 'flex' : 'none';
  });

  // ── Music & Movies action buttons ─────────────────────────────────────
  document.querySelectorAll('.action-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el       = btn as HTMLButtonElement;
      const action   = el.dataset.action!;
      const shellId  = el.dataset.shellId!;
      const bandName = el.dataset.bandName || 'this band';

      const msgs: Record<string, string> = {
        confirm:  `Mark ${bandName} as confirmed for this date?`,
        unassign: `Remove ${bandName} from this date? They will return to "approved" status.`,
        publish:  'Publish this event to the public site?',
      };

      if (!confirm(msgs[action] || 'Are you sure?')) return;
      el.disabled    = true;
      el.textContent = 'Working…';

      const res = await fetch('/api/admin/assign-band', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ action, shellId }),
      });

      if (res.ok) {
        action === 'publish'
          ? (window.location.href = '/admin/events')
          : window.location.reload();
      } else {
        const { error } = await res.json();
        alert(error || 'Action failed.');
        el.disabled    = false;
        el.textContent = { confirm: 'Mark Confirmed', unassign: 'Unassign', publish: 'Publish ↗' }[action] ?? el.textContent;
      }
    });
  });

  // ── Edit modal ────────────────────────────────────────────────────────
  const editModal = document.getElementById('edit-modal') as HTMLElement;

  (window as any).openEditModal = function(
    id: string, venue: string, address: string, startTime: string, collection: string
  ) {
    (document.getElementById('edit-shell-id')  as HTMLInputElement).value = id;
    (document.getElementById('edit-venue')     as HTMLInputElement).value = venue;
    (document.getElementById('edit-address')   as HTMLInputElement).value = address;
    (document.getElementById('edit-startTime') as HTMLInputElement).value = startTime;
    (document.getElementById('edit-collection')as HTMLInputElement).value = collection;
    editModal.hidden = false;
  };

  (window as any).closeEditModal = function() {
    editModal.hidden = true;
  };

  document.getElementById('modal-cancel-btn')?.addEventListener('click', () => {
    editModal.hidden = true;
  });

  editModal.addEventListener('click', function(e) {
    if (e.target === this) editModal.hidden = true;
  });
</script>

