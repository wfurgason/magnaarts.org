---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';

const user = Astro.locals.user;
const filterParam = Astro.url.searchParams.get('filter') || 'all';

const snap = await adminDb.collection('volunteer_signups')
  .orderBy('submittedAt', 'desc')
  .get();

type Volunteer = {
  id: string;
  fullName: string;
  email: string;
  phone?: string;
  canLift?: string;
  interests?: string[];
  status: string;
  submittedAt?: any;
  notes?: string;
};

const filters = ['all', 'new', 'contacted', 'active', 'inactive'];

let volunteers = snap.docs.map(d => ({ ...d.data(), id: d.id })) as Volunteer[];
if (filterParam !== 'all') {
  volunteers = volunteers.filter(v => (v.status || 'new') === filterParam);
}

function fmt(ts: any) {
  if (!ts) return '';
  const d = ts.toDate ? ts.toDate() : new Date(ts);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<AdminLayout title="Volunteers" user={user}>

  <div class="page-header">
    <h1>Volunteer Sign-Ups</h1>
    <p class="page-sub">{snap.size} total submission{snap.size !== 1 ? 's' : ''}</p>
    <div class="filter-tabs">
      {filters.map(f => (
        <a
          href={`/admin/volunteers${f === 'all' ? '' : `?filter=${f}`}`}
          class:list={['filter-tab', { active: filterParam === f }]}
        >
          {f.charAt(0).toUpperCase() + f.slice(1)}
        </a>
      ))}
    </div>
  </div>

  {volunteers.length === 0 ? (
    <div class="empty-state">
      <p>No volunteer sign-ups matching this filter.</p>
    </div>
  ) : (
    <div class="vol-table-wrap">
      <table class="vol-table" id="vol-table">
        <thead>
          <tr>
            <th>Name<br/><input class="col-filter" data-col="0" placeholder="Filter..." /></th>
            <th>Email<br/><input class="col-filter" data-col="1" placeholder="Filter..." /></th>
            <th>Phone<br/><input class="col-filter" data-col="2" placeholder="Filter..." /></th>
            <th>Interests<br/><input class="col-filter" data-col="3" placeholder="Filter..." /></th>
            <th>Status<br/><input class="col-filter" data-col="4" placeholder="Filter..." /></th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {volunteers.map(v => (
            <tr id={v.id}>
              <td class="vol-name">{v.fullName}</td>
              <td><a href={`mailto:${v.email}`}>{v.email}</a></td>
              <td>{v.phone || ''}</td>
              <td class="interests-cell">
                {v.interests && v.interests.length > 0
                  ? v.interests.map(i => <span class="interest-chip">{i}</span>)
                  : <span class="muted">&mdash;</span>}
              </td>
              <td><span class={`badge badge-${v.status || 'new'}`}>{v.status || 'new'}</span></td>
              <td class="actions-cell">
                {(v.status === 'new' || !v.status) && (
                  <>
                    <button class="btn-xs btn-primary" data-action="contacted" data-id={v.id}>Contacted</button>
                    <button class="btn-xs btn-success" data-action="active" data-id={v.id}>Active</button>
                    <button class="btn-xs btn-danger" data-action="inactive" data-id={v.id}>Inactive</button>
                  </>
                )}
                {v.status === 'contacted' && (
                  <>
                    <button class="btn-xs btn-success" data-action="active" data-id={v.id}>Active</button>
                    <button class="btn-xs btn-danger" data-action="inactive" data-id={v.id}>Inactive</button>
                  </>
                )}
                {v.status === 'active' && (
                  <>
                    <button class="btn-xs btn-primary" data-action="contacted" data-id={v.id}>Contacted</button>
                    <button class="btn-xs btn-danger" data-action="inactive" data-id={v.id}>Inactive</button>
                  </>
                )}
                {v.status === 'inactive' && (
                  <button class="btn-xs btn-success" data-action="new" data-id={v.id}>Restore</button>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <style>
    .page-sub { color: var(--muted, #5a5a7a); font-size: 14px; margin: 4px 0 16px; }

    .vol-table-wrap { overflow-x: auto; }
    .vol-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .vol-table th {
      background: #f1f5f9;
      color: var(--navy, #1a2456);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .04em;
      padding: 8px 10px 6px;
      text-align: left;
      border-bottom: 2px solid #e2e8f0;
      vertical-align: top;
    }
    .vol-table td {
      padding: 10px 10px;
      border-bottom: 1px solid #e2e8f0;
      vertical-align: middle;
    }
    .vol-table tbody tr:hover { background: #f8fafc; }
    .vol-table tbody tr.hidden { display: none; }

    .col-filter {
      display: block;
      margin-top: 4px;
      width: 100%;
      font-size: 12px;
      font-weight: 400;
      padding: 3px 6px;
      border: 1px solid #cbd5e1;
      border-radius: 4px;
      text-transform: none;
      letter-spacing: 0;
    }

    .vol-name { font-weight: 600; color: var(--navy, #1a2456); white-space: nowrap; }
    .muted { color: #94a3b8; }

    .interests-cell { display: flex; flex-wrap: wrap; gap: 4px; align-items: center; padding: 8px 10px; }
    .interest-chip {
      background: #dbeafe;
      color: #1e40af;
      font-size: 11px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 100px;
      white-space: nowrap;
    }

    .badge-new       { background: #f1f5f9; color: #64748b; }
    .badge-contacted { background: #e0f2fe; color: #075985; }
    .badge-active    { background: #d1fae5; color: #065f46; }
    .badge-inactive  { background: #fee2e2; color: #991b1b; }

    .actions-cell { white-space: nowrap; }
    .btn-xs {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 4px;
      border: none;
      cursor: pointer;
      margin-right: 4px;
    }
    .btn-xs.btn-primary  { background: #2563b0; color: #fff; }
    .btn-xs.btn-success  { background: #2d7a3a; color: #fff; }
    .btn-xs.btn-danger   { background: #b52626; color: #fff; }
    .btn-xs:hover { opacity: .85; }
  </style>

  <script>
    // Column filters
    document.querySelectorAll('.col-filter').forEach(function(input) {
      input.addEventListener('input', function() {
        var filters: {col: number, val: string}[] = [];
        document.querySelectorAll<HTMLInputElement>('.col-filter').forEach(function(f) {
          filters.push({ col: parseInt(f.dataset.col || '0'), val: f.value.trim().toLowerCase() });
        });
        document.querySelectorAll('#vol-table tbody tr').forEach(function(row) {
          var cells = row.querySelectorAll('td');
          var visible = filters.every(function(f) {
            if (!f.val) return true;
            var cell = cells[f.col];
            return cell && cell.textContent!.toLowerCase().includes(f.val);
          });
          row.classList.toggle('hidden', !visible);
        });
      });
    });

    // Status actions
    document.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var action = btn.dataset.action;
        var id = btn.dataset.id;
        btn.disabled = true;
        var res = await fetch('/api/admin/update-submission', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, collection: 'volunteer_signups', status: action }),
        });
        if (res.ok) window.location.reload();
        else { alert('Action failed.'); btn.disabled = false; }
      });
    });
  </script>

</AdminLayout>
