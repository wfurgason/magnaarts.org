---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { adminDb } from '../lib/firebase-admin';

const snapshot = await adminDb
  .collection('artists')
  .where('visible', '==', true)
  .where('status', '==', 'approved')
  .get();

const artists = snapshot.docs
  .map(doc => ({ id: doc.id, ...doc.data() }))
  .sort((a, b) => (a.band_name || '').localeCompare(b.band_name || ''));

function ensureUrl(url: string): string {
  if (!url) return url;
  if (url.startsWith('http://') || url.startsWith('https://')) return url;
  return `https://${url}`;
}

// Fetch gallery images for visual artists server-side
const imagesByArtist: Record<string, { id: string; url: string; title: string }[]> = {};
await Promise.all(
  artists
    .filter((a: any) => a.artistType === 'visual')
    .map(async (a: any) => {
      const snap = await adminDb.collection('artists').doc(a.id).collection('images').get();
      imagesByArtist[a.id] = snap.docs.map(d => ({
        id:    d.id,
        url:   d.data().url || '',
        title: d.data().title || '',
      }));
    })
);

const firebaseConfig = {
  apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
  storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
  appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID,
};
---

<BaseLayout
  title="Local Artists — Magna Arts Council"
  description="Discover local musicians and visual artists from the Magna community."
>
  <Header />

  <main>

    <!-- ── PAGE HERO ── -->
    <section class="la-hero">
      <div class="container">
        <h1>Local Artists</h1>
        <p class="la-hero-sub">Discover the musicians and visual artists of Magna. Stream music, explore artwork, and connect with your community's creative voices.</p>
      </div>
    </section>

    <!-- ── ARTIST GRID ── -->
    <section class="section la-section">
      <div class="container">

        {artists.length === 0 ? (
          <div class="la-empty">
            <div class="la-empty-icon">🎵</div>
            <p>No artists listed yet — check back soon!</p>
          </div>
        ) : (
          <div class="la-grid" id="la-grid">
            {artists.map((a: any) => {
              const isVisual  = a.artistType === 'visual';
              const images    = isVisual ? (imagesByArtist[a.id] || []) : [];
              const firstImg  = images[0];
              const cardPhoto = firstImg?.url || a.photo_url || '';
              const placeholder = isVisual ? '🎨' : '🎵';

              return (
                <article
                  class={`la-card${isVisual ? ' la-card--visual' : ''}`}
                  data-band-id={a.id}
                  data-type={isVisual ? 'visual' : 'music'}
                  data-images={isVisual ? JSON.stringify(images) : ''}
                >
                  <div class="la-card-photo">
                    {cardPhoto
                      ? <img src={cardPhoto} alt={a.band_name} loading="lazy" />
                      : <div class="la-photo-placeholder">{placeholder}</div>
                    }
                    {isVisual && images.length > 1 && (
                      <div class="la-image-badge">{images.length} images</div>
                    )}
                  </div>

                  <div class="la-card-body">
                    <div class="la-card-top">
                      <h2 class="la-band-name">{a.band_name}</h2>
                      {a.genre && !isVisual && <span class="la-genre">{a.genre}</span>}
                      {isVisual && <span class="la-genre la-genre--visual">Visual Artist</span>}
                    </div>
                    {a.bio && (
                      <p class="la-bio" data-full-bio={a.bio.length > 120 ? a.bio : ''}>
                        {a.bio.length > 120 ? a.bio.slice(0, 120).trimEnd() + '…' : a.bio}
                        {a.bio.length > 120 && <span class="la-bio-popout">{a.bio}</span>}
                      </p>
                    )}
                    <div class="la-links">
                      {a.website          && <a href={ensureUrl(a.website)}          target="_blank" rel="noopener" class="la-link">🌐 Website</a>}
                      {a.music_link       && !isVisual && <a href={ensureUrl(a.music_link)} target="_blank" rel="noopener" class="la-link">🎵 Music</a>}
                      {a.music_link       && isVisual  && <a href={ensureUrl(a.music_link)} target="_blank" rel="noopener" class="la-link">🎨 Portfolio</a>}
                      {a.social_instagram && <a href={ensureUrl(a.social_instagram)} target="_blank" rel="noopener" class="la-link">📸 Instagram</a>}
                      {a.social_facebook  && <a href={ensureUrl(a.social_facebook)}  target="_blank" rel="noopener" class="la-link">👍 Facebook</a>}
                    </div>
                  </div>

                  {/* Music: per-card play button */}
                  {!isVisual && (
                    <button class="la-play-btn" data-band-id={a.id} aria-label={`Play tracks from ${a.band_name}`}>
                      ▶
                    </button>
                  )}

                  {/* Visual: gallery open hint */}
                  {isVisual && images.length > 0 && (
                    <div class="la-gallery-hint">View Gallery →</div>
                  )}
                </article>
              );
            })}
          </div>
        )}

      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="la-cta">
      <div class="container la-cta-inner">
        <div>
          <h2>Are You a Local Artist?</h2>
          <p>Magna community musicians and visual artists can apply for a free listing on this page. Contact the Arts Council to learn more.</p>
        </div>
        <a href="/contact" class="btn btn-gold">Get in Touch →</a>
      </div>
    </section>

  </main>

  <Footer />

  <!-- ── LIGHTBOX (visual artists) ── -->
  <div id="la-lightbox" aria-modal="true" role="dialog" aria-label="Image gallery" style="display:none">
    <div id="lb-backdrop" class="lb-backdrop"></div>
    <div class="lb-dialog">
      <div class="lb-top">
        <div id="lb-artist-name" class="lb-artist-name"></div>
        <button id="lb-close" class="lb-close" aria-label="Close gallery">✕</button>
      </div>
      <div class="lb-img-wrap">
        <button id="lb-prev" class="lb-nav lb-prev" aria-label="Previous image">‹</button>
        <img id="lb-img" src="" alt="" class="lb-img" />
        <button id="lb-next" class="lb-nav lb-next" aria-label="Next image">›</button>
      </div>
      <div class="lb-footer">
        <div id="lb-title" class="lb-title"></div>
        <div id="lb-counter" class="lb-counter"></div>
      </div>
    </div>
  </div>

  <!-- ── ROTATING PLAYER (fixed bottom, music only) ── -->
  <div id="la-player" style="display:none" aria-label="Music Player">
    <div class="lp-track-info">
      <div id="lp-artist" class="lp-artist"></div>
      <div id="lp-title"  class="lp-title"></div>
    </div>
    <div class="lp-controls">
      <button id="lp-play-pause" class="lp-btn lp-btn-main" aria-label="Play / Pause">▶</button>
      <button id="lp-stop"       class="lp-btn"             aria-label="Stop">⏹</button>
      <button id="lp-skip"       class="lp-btn"             aria-label="Skip track">⏭</button>
    </div>
    <div class="lp-progress-wrap">
      <span id="lp-current"  class="lp-time">0:00</span>
      <div  id="lp-bar-track" class="lp-bar-track" role="slider" aria-label="Seek">
        <div id="lp-bar-fill" class="lp-bar-fill"></div>
      </div>
      <span id="lp-duration" class="lp-time">0:00</span>
    </div>
    <audio id="la-audio" preload="none"></audio>
  </div>

  <script define:vars={{ firebaseConfig }}>
    window.__FIREBASE_CONFIG__ = firebaseConfig;
  </script>

  <script type="module">
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
    import { getFirestore, collectionGroup, collection, getDocs, orderBy, query }
      from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-firestore.js';

    const app = initializeApp(window.__FIREBASE_CONFIG__);
    const db  = getFirestore(app);

    // ─────────────────────────────────────────────
    // LIGHTBOX
    // ─────────────────────────────────────────────
    const lightbox   = document.getElementById('la-lightbox');
    const lbBackdrop = document.getElementById('lb-backdrop');
    const lbClose    = document.getElementById('lb-close');
    const lbPrev     = document.getElementById('lb-prev');
    const lbNext     = document.getElementById('lb-next');
    const lbImg      = document.getElementById('lb-img');
    const lbTitle    = document.getElementById('lb-title');
    const lbCounter  = document.getElementById('lb-counter');
    const lbArtist   = document.getElementById('lb-artist-name');

    let lbImages = [];
    let lbIdx    = 0;

    function openLightbox(artistName, images, startIdx = 0) {
      lbImages = images;
      lbIdx    = startIdx;
      lbArtist.textContent = artistName;
      lbPrev.style.display = images.length > 1 ? '' : 'none';
      lbNext.style.display = images.length > 1 ? '' : 'none';
      showLbImage(lbIdx);
      lightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.style.display    = 'none';
      document.body.style.overflow = '';
      lbImg.src = '';
    }

    function showLbImage(i) {
      lbIdx = ((i % lbImages.length) + lbImages.length) % lbImages.length;
      const item       = lbImages[lbIdx];
      lbImg.src        = item.url;
      lbImg.alt        = item.title || '';
      lbTitle.textContent   = item.title || '';
      lbCounter.textContent = lbImages.length > 1 ? `${lbIdx + 1} / ${lbImages.length}` : '';
    }

    lbClose.addEventListener('click', closeLightbox);
    lbBackdrop.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => showLbImage(lbIdx - 1));
    lbNext.addEventListener('click', () => showLbImage(lbIdx + 1));

    document.addEventListener('keydown', e => {
      if (lightbox.style.display === 'none') return;
      if (e.key === 'Escape')      closeLightbox();
      if (e.key === 'ArrowLeft')   showLbImage(lbIdx - 1);
      if (e.key === 'ArrowRight')  showLbImage(lbIdx + 1);
    });

    // Wire up visual artist card clicks
    document.querySelectorAll('.la-card--visual').forEach(card => {
      const rawImages = card.dataset.images || '[]';
      let images = [];
      try { images = JSON.parse(rawImages); } catch {}
      if (images.length === 0) return;

      const artistName = card.querySelector('.la-band-name')?.textContent?.trim() || '';
      card.style.cursor = 'pointer';
      card.addEventListener('click', e => {
        // Don't intercept link clicks
        if (e.target.closest('a')) return;
        openLightbox(artistName, images, 0);
      });
    });

    // ─────────────────────────────────────────────
    // MUSIC PLAYER
    // ─────────────────────────────────────────────
    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function fmt(s) {
      if (!isFinite(s)) return '0:00';
      const m = Math.floor(s / 60);
      const sec = String(Math.floor(s % 60)).padStart(2, '0');
      return `${m}:${sec}`;
    }

    async function initPlayer() {
      // Only music artist cards contribute to the playlist
      const artistNames = {};
      document.querySelectorAll('.la-card[data-type="music"]').forEach(card => {
        const id   = card.dataset.bandId;
        const name = card.querySelector('.la-band-name')?.textContent?.trim() || 'Unknown Artist';
        artistNames[id] = name;
      });

      const bandIds = Object.keys(artistNames);
      if (bandIds.length === 0) return;

      let playlist = [];
      let idx      = 0;

      try {
        const tracksSnap = await getDocs(
          query(collectionGroup(db, 'tracks'), orderBy('uploadedAt', 'desc'))
        );
        tracksSnap.docs.forEach(d => {
          const bandId = d.ref.parent.parent?.id;
          if (!bandId || !artistNames[bandId]) return;
          const data = d.data();
          if (!data.url) return;
          playlist.push({ url: data.url, title: data.title || 'Untitled', artistName: artistNames[bandId], bandId });
        });
      } catch (err) {
        console.warn('[local-artists] collectionGroup failed, falling back:', err);
        for (const bandId of bandIds) {
          try {
            const snap = await getDocs(collection(db, 'artists', bandId, 'tracks'));
            snap.docs.forEach(d => {
              const data = d.data();
              if (!data.url) return;
              playlist.push({ url: data.url, title: data.title || 'Untitled', artistName: artistNames[bandId], bandId });
            });
          } catch (e) {
            console.warn('[local-artists] Could not fetch tracks for', bandId, e);
          }
        }
      }

      shuffle(playlist);
      if (playlist.length === 0) return;

      const player       = document.getElementById('la-player');
      const audio        = document.getElementById('la-audio');
      const playPauseBtn = document.getElementById('lp-play-pause');
      const stopBtn      = document.getElementById('lp-stop');
      const skipBtn      = document.getElementById('lp-skip');
      const artistEl     = document.getElementById('lp-artist');
      const titleEl      = document.getElementById('lp-title');
      const currentEl    = document.getElementById('lp-current');
      const durationEl   = document.getElementById('lp-duration');
      const barTrack     = document.getElementById('lp-bar-track');
      const barFill      = document.getElementById('lp-bar-fill');

      player.style.display     = 'flex';
      document.body.style.paddingBottom = '72px';

      function loadTrack(i) {
        const t = playlist[i];
        audio.src              = t.url;
        audio.load();
        artistEl.textContent   = t.artistName;
        titleEl.textContent    = t.title;
        barFill.style.width    = '0%';
        currentEl.textContent  = '0:00';
        durationEl.textContent = '0:00';
      }

      function playTrack(i) {
        idx = ((i % playlist.length) + playlist.length) % playlist.length;
        loadTrack(idx);
        audio.play().catch(() => {});
        playPauseBtn.textContent = '⏸';
      }

      loadTrack(0);

      playPauseBtn.addEventListener('click', () => {
        if (audio.paused) {
          if (!audio.src || audio.src === window.location.href) loadTrack(idx);
          audio.play().catch(() => {});
          playPauseBtn.textContent = '⏸';
        } else {
          audio.pause();
          playPauseBtn.textContent = '▶';
        }
      });

      stopBtn.addEventListener('click', () => {
        audio.pause();
        audio.currentTime      = 0;
        playPauseBtn.textContent = '▶';
        barFill.style.width    = '0%';
        currentEl.textContent  = '0:00';
      });

      skipBtn.addEventListener('click', () => playTrack(idx + 1));
      audio.addEventListener('ended', () => playTrack(idx + 1));

      audio.addEventListener('timeupdate', () => {
        if (!isFinite(audio.duration)) return;
        const pct = (audio.currentTime / audio.duration) * 100;
        barFill.style.width    = pct + '%';
        currentEl.textContent  = fmt(audio.currentTime);
        durationEl.textContent = fmt(audio.duration);
      });

      barTrack.addEventListener('click', e => {
        if (!isFinite(audio.duration)) return;
        const rect = barTrack.getBoundingClientRect();
        const pct  = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        audio.currentTime = pct * audio.duration;
      });

      document.querySelectorAll('.la-play-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const bandId    = btn.dataset.bandId;
          const artistIdx = playlist.findIndex(t => t.bandId === bandId);
          if (artistIdx === -1) return;
          playTrack(artistIdx);
        });
      });
    }

    initPlayer();
  </script>

</BaseLayout>

<style is:global>

  /* ── Hero ── */
  .la-hero {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0 56px;
    text-align: center;
  }
  .la-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 14px;
  }
  .la-hero-sub {
    font-size: 18px;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── Section ── */
  .la-section { background: var(--cream); }

  /* ── Empty ── */
  .la-empty {
    text-align: center;
    padding: 60px 0;
    color: var(--muted);
    font-size: 16px;
  }
  .la-empty-icon { font-size: 48px; margin-bottom: 16px; }

  /* ── Grid ── */
  .la-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }

  /* ── Card ── */
  .la-card {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: box-shadow 0.22s, transform 0.22s;
  }
  .la-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }
  .la-card--visual { cursor: pointer; }

  /* Photo */
  .la-card-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--cream);
    flex-shrink: 0;
    position: relative;
  }
  .la-card-photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .la-photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 52px;
    color: var(--border);
  }

  /* Image count badge */
  .la-image-badge {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(26,36,86,0.75);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 99px;
    pointer-events: none;
  }

  /* Body */
  .la-card-body {
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .la-card-top {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
  }
  .la-band-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.2;
    margin: 0;
  }
  .la-genre {
    display: inline-block;
    background: #dbeafe;
    color: #1e40af;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 9px;
    border-radius: 99px;
    white-space: nowrap;
  }
  .la-genre--visual {
    background: #ede9fe;
    color: #5b21b6;
  }
  .la-bio {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    position: relative;
  }
  .la-bio-popout {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    right: 0;
    background: #1a2456;
    color: #fff;
    font-size: 13px;
    line-height: 1.65;
    padding: 12px 14px;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    z-index: 10;
    white-space: normal;
    pointer-events: none;
  }
  .la-bio-popout::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 20px;
    border: 6px solid transparent;
    border-top-color: #1a2456;
  }
  .la-bio:hover .la-bio-popout { display: block; }
  .la-links {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }
  .la-link {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--navy);
    text-decoration: none;
    transition: background 0.15s;
  }
  .la-link:hover { background: var(--border); }

  /* Per-card play button (music only) */
  .la-play-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(26,36,86,0.82);
    color: #fff;
    border: none;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.18s, background 0.15s;
  }
  .la-card:hover .la-play-btn { opacity: 1; }
  .la-play-btn:hover { background: var(--navy); }

  /* Gallery hint (visual) */
  .la-gallery-hint {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(26,36,86,0.75);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 99px;
    opacity: 0;
    transition: opacity 0.18s;
    pointer-events: none;
  }
  .la-card--visual:hover .la-gallery-hint { opacity: 1; }

  /* ── CTA ── */
  .la-cta { background: var(--navy-dk); color: var(--white); padding: 56px 0; }
  .la-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .la-cta-inner h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .la-cta-inner p {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    max-width: 480px;
  }

  /* ── LIGHTBOX ── */
  #la-lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.82);
    cursor: pointer;
  }
  .lb-dialog {
    position: relative;
    z-index: 1;
    background: #111827;
    border-radius: 14px;
    padding: 20px;
    max-width: min(90vw, 700px);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
  }
  .lb-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .lb-artist-name {
    font-family: 'Playfair Display', 'Georgia', serif;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lb-close {
    background: rgba(255,255,255,0.12);
    border: none;
