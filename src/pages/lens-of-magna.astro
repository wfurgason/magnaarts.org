---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Lens of Magna 2026: Main Street in Motion — Photography Contest"
  description="Enter the 3rd annual Lens of Magna Main Street Photography Contest. Free to enter. $2,875 in cash prizes. Deadline April 11, 2026."
>
  <Header />

  <main>

    <!-- ── HERO ── -->
    <section class="lmm-hero">
      <div class="lmm-hero-img-wrap">
        <img
          src="/images/lens-of-magna/lmm-postcard-flyer.jpg"
          alt="Lens of Magna 2026: Main Street in Motion Photography Contest"
          class="lmm-hero-img"
        />
        <div class="lmm-hero-overlay">
          <div class="container lmm-hero-content">
            <h1>Lens of Magna 2026</h1>
            <div class="lmm-hero-cta-row">
              <a href="https://lensofmagna.com" target="_blank" rel="noopener noreferrer" class="btn btn-gold">
                Enter Free at lensofmagna.com →
              </a>
              <span class="lmm-deadline-badge">Deadline: April 11, 2026</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── INTRO ── -->
    <section class="section lmm-intro">
      <div class="container lmm-intro-inner">
        <div class="lmm-intro-text reveal">
          <div class="section-label">Photography Contest</div>
          <h2>Capture Magna Through Your Lens</h2>
          <p>
            Magna has a story worth telling — and we're looking for photographers to tell it.
            The Lens of Magna Main Street Photography Contest invites youth, hobbyists, and professionals
            alike to turn their cameras on one of our community's most iconic corridors.
          </p>
          <p>
            This year's theme, <strong>"Main Street in Motion,"</strong> challenges you to capture the energy,
            rhythm, and everyday life of Magna Main Street — the people, the places, and the pulse
            that make our neighborhood home.
          </p>
          <p class="sponsor-line">
            Presented by <strong>Magna City</strong> · <strong>Magna Arts Council</strong> · <strong>Salt Lake County Library – Magna Branch</strong> · <strong>Zoo, Arts &amp; Parks / Salt Lake County</strong>
          </p>
        </div>
        <div class="lmm-prize-callout reveal">
          <div class="prize-amount">$2,875</div>
          <div class="prize-label">in Cash Prizes</div>
          <div class="prize-sub">Awarded across Youth, Amateur &amp; Professional categories</div>
          <a href="https://lensofmagna.com" target="_blank" rel="noopener noreferrer" class="btn btn-navy prize-cta">
            View Prize Details →
          </a>
        </div>
      </div>
    </section>

    <!-- ── RULES ── -->
    <section class="section section-cream lmm-rules">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-label">Contest Rules</div>
          <h2>What You Need to Know</h2>
        </div>
        <div class="rules-grid">
          <div class="rule-card reveal">
            <div class="rule-icon">📍</div>
            <h3>Location</h3>
            <p>All photos must be taken within <strong>300 feet of Magna Main Street</strong>.</p>
          </div>
          <div class="rule-card reveal">
            <div class="rule-icon">🆓</div>
            <h3>Free to Enter</h3>
            <p>There is <strong>no entry fee</strong>. The contest is free and open to the community.</p>
          </div>
          <div class="rule-card reveal">
            <div class="rule-icon">🏆</div>
            <h3>Categories</h3>
            <p><strong>Youth · Amateur · Professional</strong></p>
            <p>Prizes are awarded in each category.</p>
          </div>
          <div class="rule-card reveal">
            <div class="rule-icon">📷</div>
            <h3>Photo Types</h3>
            <p>Any style welcome — <strong>Landscape, Portrait, Street &amp; Documentary, Architecture, Abstract, Nature/Macro</strong>, and more.</p>
          </div>
        </div>
        <p class="rules-footer reveal">
          Full contest rules and submission guidelines are available at
          <a href="https://lensofmagna.com" target="_blank" rel="noopener noreferrer">lensofmagna.com</a>.
        </p>
      </div>
    </section>

    <!-- ── KEY DATES ── -->
    <section class="section lmm-dates">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-label">Key Dates</div>
          <h2>Mark Your Calendar</h2>
        </div>
        <div class="dates-row">
          <div class="date-card reveal">
            <div class="date-icon">📅</div>
            <div class="date-month">APR</div>
            <div class="date-day">11</div>
            <div class="date-label">Entry Deadline</div>
            <div class="date-sub">Saturday · Don't miss your shot!</div>
          </div>
          <div class="dates-connector" aria-hidden="true">→</div>
          <div class="date-card reveal">
            <div class="date-icon">🎨</div>
            <div class="date-month">APR</div>
            <div class="date-day">13</div>
            <div class="date-label">Judging</div>
            <div class="date-sub">Monday</div>
          </div>
          <div class="dates-connector" aria-hidden="true">→</div>
          <div class="date-card date-card--gold reveal">
            <div class="date-icon">🖼️</div>
            <div class="date-month">APR</div>
            <div class="date-day">16</div>
            <div class="date-label">Public Reception &amp; Exhibit</div>
            <div class="date-sub">Thursday · 6:00–8:00 PM</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── EXHIBITION ── -->
    <section class="section section-cream lmm-exhibit">
      <div class="container lmm-exhibit-inner">
        <div class="exhibit-text reveal">
          <div class="section-label">Photo Exhibition</div>
          <h2>Celebrate Local Talent &amp; Historic Magna Main Street</h2>
          <p>
            Join us for the Lens of Magna Main Photo Exhibition — a public reception showcasing the
            best entries from the contest. Come see Magna through the eyes of our community's photographers.
          </p>
          <div class="exhibit-details">
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Date</span>
              <span>Thursday, April 16, 2026</span>
            </div>
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Time</span>
              <span>6:00 – 8:00 PM</span>
            </div>
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Location</span>
              <a
                href="https://www.google.com/maps/search/?api=1&query=Magna+Branch+Salt+Lake+County+Library+2675+S+8950+W+Magna+UT"
                target="_blank"
                rel="noopener noreferrer"
                class="map-link"
              >
                <svg width="11" height="14" viewBox="0 0 11 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M5.5 0C2.46 0 0 2.46 0 5.5c0 3.85 5.5 8.5 5.5 8.5S11 9.35 11 5.5C11 2.46 8.54 0 5.5 0zm0 7.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4z" fill="currentColor"/>
                </svg>
                Magna Branch — Salt Lake County Library
              </a>
            </div>
            <div class="exhibit-detail-row">
              <span class="exhibit-detail-label">Extras</span>
              <span>Light refreshments served</span>
            </div>
          </div>
        </div>
        <div class="exhibit-flyer-wrap reveal">
          <img
            src="/images/lens-of-magna/lmm-exhibit-flyer.jpg"
            alt="Lens of Magna Main Photo Exhibition — Thursday, April 16th, 6–8 PM, Magna Library"
            class="exhibit-flyer-img"
          />
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="lmm-cta-banner">
      <div class="container lmm-cta-inner reveal">
        <div>
          <h2>Ready to Shoot?</h2>
          <p>
            Magna Main Street is more than a road — it's a living, breathing part of our community's history and future.
            Whether you're a seasoned photographer or picking up a camera for the first time,
            we want to see Main Street through <em>your</em> lens.
          </p>
          <p class="cta-deadline">Entry Deadline: <strong>Saturday, April 11, 2026</strong></p>
        </div>
        <a href="https://lensofmagna.com" target="_blank" rel="noopener noreferrer" class="btn btn-gold btn-lg">
          Enter Free at lensofmagna.com →
        </a>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  /* ── HERO ── */
  .lmm-hero {
    position: relative;
    width: 100%;
  }

  .lmm-hero-img-wrap {
    position: relative;
    width: 100%;
    max-height: 540px;
    overflow: hidden;
  }

  .lmm-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    max-height: 540px;
  }

  .lmm-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 5, 2, 0.55) 0%,
      rgba(10, 5, 2, 0.15) 35%,
      rgba(10, 5, 2, 0.72) 100%
    );
    display: flex;
    align-items: stretch;
    padding-bottom: 0;
  }

  .lmm-hero-content {
    color: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding-top: 32px;
    padding-bottom: 48px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.22);
    border: 1px solid rgba(232, 160, 32, 0.5);
    color: var(--gold-lt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 13px;
    border-radius: 100px;
    margin-top: 8px;
  }

  .lmm-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 38px);
    font-weight: 900;
    line-height: 1.05;
    text-shadow: 0 2px 12px rgba(0,0,0,0.7);
    margin-bottom: 6px;
    margin-top: 40px;
    padding-left: 15%;
  }

  .lmm-hero-cta-row {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .lmm-deadline-badge {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.04em;
  }

  /* ── BUTTONS ── */
  .btn-gold {
    background: var(--gold);
    color: var(--navy-dk);
    border-color: var(--gold);
  }
  .btn-gold:hover {
    background: var(--gold-lt);
    border-color: var(--gold-lt);
    transform: translateY(-1px);
    box-shadow: var(--shadow-hover);
  }

  .btn-navy {
    background: var(--navy);
    color: var(--white);
    border-color: var(--navy);
  }
  .btn-navy:hover {
    background: var(--navy-dk);
    border-color: var(--navy-dk);
    transform: translateY(-1px);
  }

  .btn-lg {
    font-size: 16px;
    padding: 16px 32px;
  }

  /* ── INTRO ── */
  .lmm-intro-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 56px;
    align-items: center;
  }

  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .lmm-intro-text h2,
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 900;
    color: var(--navy);
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .lmm-intro-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .sponsor-line {
    font-size: 13px !important;
    color: var(--muted);
    border-top: 1px solid var(--border);
    padding-top: 16px;
    margin-top: 8px;
  }

  /* Prize callout */
  .lmm-prize-callout {
    background: var(--navy);
    color: var(--white);
    border-radius: var(--radius);
    padding: 36px 28px;
    text-align: center;
    box-shadow: var(--shadow-card);
  }

  .prize-amount {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
  }

  .prize-label {
    font-size: 16px;
    font-weight: 700;
    color: var(--white);
    margin: 6px 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .prize-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
    margin-bottom: 24px;
  }

  .prize-cta {
    width: 100%;
    justify-content: center;
  }

  /* ── RULES ── */
  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .rules-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .rule-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--gold);
    border-radius: var(--radius);
    padding: 28px 22px;
    text-align: center;
    box-shadow: var(--shadow-card);
  }

  .rule-icon {
    font-size: 32px;
    margin-bottom: 12px;
  }

  .rule-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 10px;
  }

  .rule-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 6px;
  }

  .rules-footer {
    text-align: center;
    font-size: 15px;
    color: var(--muted);
  }

  .rules-footer a {
    color: var(--blue);
    font-weight: 600;
    border-bottom: 1px solid currentColor;
  }

  /* ── DATES ── */
  .dates-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .date-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 32px;
    text-align: center;
    box-shadow: var(--shadow-card);
    min-width: 200px;
    flex: 1;
    max-width: 240px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .date-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }

  .date-card--gold {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--white);
  }

  .date-icon { font-size: 24px; margin-bottom: 10px; }

  .date-month {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .date-card--gold .date-month { color: var(--gold-lt); }

  .date-day {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 900;
    color: var(--navy);
    line-height: 1;
    margin: 4px 0 8px;
  }

  .date-card--gold .date-day { color: var(--white); }

  .date-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 4px;
  }

  .date-card--gold .date-label { color: var(--white); }

  .date-sub {
    font-size: 12px;
    color: var(--muted);
  }

  .date-card--gold .date-sub { color: rgba(255,255,255,0.65); }

  .dates-connector {
    font-size: 24px;
    color: var(--border);
    font-weight: 300;
    flex-shrink: 0;
  }

  /* ── EXHIBITION ── */
  .lmm-exhibit-inner {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 56px;
    align-items: center;
  }

  .exhibit-text h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 900;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .exhibit-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 24px;
  }

  .exhibit-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--gold);
    border-radius: var(--radius);
    padding: 20px 24px;
  }

  .exhibit-detail-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    align-items: center;
    gap: 12px;
    font-size: 14px;
  }

  .exhibit-detail-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .exhibit-flyer-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-hover);
  }

  .exhibit-flyer-img {
    width: 100%;
    display: block;
  }

  /* ── MAP LINK ── */
  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--navy);
    text-decoration: none;
    font-size: 14px;
    border-bottom: 1.5px dashed var(--blue);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .map-link:hover {
    color: var(--blue);
    border-bottom-style: solid;
  }

  /* ── CTA BANNER ── */
  .lmm-cta-banner {
    background: var(--navy-dk);
    color: var(--white);
    padding: 72px 0;
  }

  .lmm-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .lmm-cta-inner h2 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 900;
    margin-bottom: 12px;
  }

  .lmm-cta-inner p {
    font-size: 16px;
    color: rgba(255,255,255,0.72);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: 10px;
  }

  .cta-deadline {
    font-size: 14px !important;
    color: var(--gold-lt) !important;
    letter-spacing: 0.02em;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .lmm-exhibit-inner {
      grid-template-columns: 1fr 380px;
      gap: 36px;
    }
  }

  @media (max-width: 860px) {
    .lmm-intro-inner { grid-template-columns: 1fr; }
    .lmm-prize-callout { max-width: 400px; }
    .rules-grid { grid-template-columns: repeat(2, 1fr); }
    .lmm-exhibit-inner { grid-template-columns: 1fr; }
    .exhibit-flyer-wrap { order: -1; max-width: 480px; }
    .lmm-cta-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 600px) {
    .rules-grid { grid-template-columns: 1fr; }
    .dates-row { flex-direction: column; align-items: stretch; }
    .dates-connector { display: none; }
    .date-card { max-width: 100%; }
    .lmm-hero-img { max-height: 400px; }
    .lmm-hero-overlay { padding-bottom: 28px; }
    .prize-amount { font-size: 44px; }
  }
</style>
