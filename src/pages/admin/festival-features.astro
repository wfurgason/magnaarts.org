---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminDb } from '../../lib/firebase-admin';

const user = Astro.locals.user;

const firebaseConfig = {
  apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
  storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
  appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID,
};

// ── Fetch all festival feature entries + festival event shells for the dropdown ──
const [featuresSnap, festivalSnap] = await Promise.all([
  adminDb.collection('festival_features').orderBy('featureTitle', 'asc').get(),
  adminDb.collection('festival_events').orderBy('date', 'asc').get(),
]);

type FeatureEntry = {
  id: string;
  eventId?: string;
  featureTitle: string;
  name: string;
  bio?: string;
  websiteUrl?: string;
  artistPhotoUrl?: string;
  artworkPhotoUrl?: string;
  order?: number;
  createdAt?: any;
};

const entries: FeatureEntry[] = featuresSnap.docs.map(d => ({ id: d.id, ...d.data() } as FeatureEntry));

// Group entries by featureTitle, preserving alphabetical order from the query
const groups: Record<string, FeatureEntry[]> = {};
for (const entry of entries) {
  const key = entry.featureTitle || 'Untitled';
  if (!groups[key]) groups[key] = [];
  groups[key].push(entry);
}

// Festival event shells for the "which event" dropdown
const festivalEvents = festivalSnap.docs.map(d => {
  const data = d.data() as any;
  return { id: d.id, label: `Magna Main Street Arts Festival — ${data.season || d.id}` };
});

// Existing feature titles, for the datalist suggestion in the form
const existingFeatureTitles = Object.keys(groups);

const entriesJson = JSON.stringify(entries);
---

<AdminLayout title="Festival Features" user={user}>
  <div class="page-header">
    <div>
      <h1>Festival Features</h1>
      <p class="page-subtitle">
        Add roster entries for special festival features — chalk artists, car show entries, and similar —
        grouped by feature title and shown on the public festival page.
      </p>
    </div>
    <button class="btn btn-gold" id="new-entry-btn">+ Add Entry</button>
  </div>

  <!-- ── ENTRY LIST, GROUPED BY FEATURE TITLE ── -->
  {entries.length === 0 ? (
    <div class="empty-state">
      <div class="empty-icon">🎨</div>
      <p>No festival feature entries yet.</p>
      <p class="empty-sub">Click <strong>+ Add Entry</strong> to add a chalk artist, car show entrant, or other festival feature.</p>
    </div>
  ) : (
    Object.entries(groups).map(([title, groupEntries]) => (
      <section class="feature-group">
        <h2 class="feature-group-title">{title} <span class="feature-group-count">{groupEntries.length}</span></h2>
        <div class="feature-card-grid">
          {groupEntries.map(entry => (
            <div class="feature-card" id={`card-${entry.id}`}>
              <div class="feature-card-photos">
                <div class="feature-photo-slot">
                  {entry.artistPhotoUrl
                    ? <img src={entry.artistPhotoUrl} alt={`${entry.name} — artist photo`} />
                    : <span class="feature-photo-placeholder">Artist photo</span>}
                </div>
                <div class="feature-photo-slot">
                  {entry.artworkPhotoUrl
                    ? <img src={entry.artworkPhotoUrl} alt={`${entry.name} — artwork photo`} />
                    : <span class="feature-photo-placeholder">Artwork photo</span>}
                </div>
              </div>
              <div class="feature-card-body">
                <h3 class="feature-card-name">{entry.name}</h3>
                {entry.bio && <p class="feature-card-bio">{entry.bio}</p>}
                <div class="feature-card-footer">
                  {entry.websiteUrl && (
                    <a href={entry.websiteUrl} target="_blank" rel="noopener noreferrer" class="feature-card-link">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                      Website
                    </a>
                  )}
                  <span class="feature-card-spacer"></span>
                  <button class="btn-icon" data-edit={entry.id} aria-label="Edit" title="Edit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
                  </button>
                  <button class="btn-icon btn-icon-danger" data-delete={entry.id} data-name={entry.name} aria-label="Delete" title="Delete">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))
  )}

  <!-- ── SLIDE-IN DRAWER ── -->
  <div id="drawer-backdrop" class="drawer-backdrop" hidden></div>
  <aside id="feature-drawer" class="feature-drawer" hidden aria-label="Festival Feature Entry Form">
    <div class="drawer-header">
      <h2 id="drawer-title">Add Entry</h2>
      <button class="drawer-close" id="drawer-close-btn" aria-label="Close">✕</button>
    </div>

    <div class="drawer-body">
      <form id="feature-form" novalidate>
        <input type="hidden" id="field-id" name="id" />

        <fieldset class="form-section">
          <legend class="form-section-label">Feature</legend>
          <div class="field">
            <label for="field-featureTitle">Feature Title <span class="required">*</span></label>
            <input type="text" id="field-featureTitle" name="featureTitle" required list="feature-title-list" placeholder="Chalk Art" />
            <datalist id="feature-title-list">
              {existingFeatureTitles.map(t => <option value={t} />)}
            </datalist>
            <span class="field-hint">Groups this entry with others under the same title on the public page.</span>
          </div>
          {festivalEvents.length > 0 && (
            <div class="field">
              <label for="field-eventId">Event</label>
              <select id="field-eventId" name="eventId">
                <option value="">— Select an event —</option>
                {festivalEvents.map(fe => <option value={fe.id}>{fe.label}</option>)}
              </select>
            </div>
          )}
        </fieldset>

        <fieldset class="form-section">
          <legend class="form-section-label">Entry Details</legend>
          <div class="field">
            <label for="field-name">Name <span class="required">*</span></label>
            <input type="text" id="field-name" name="name" required placeholder="Jenn D'Haenens" />
          </div>
          <div class="field">
            <label for="field-bio">Bio</label>
            <textarea id="field-bio" name="bio" rows="3" placeholder="Local Magna chalk artist known for vivid florals and wildlife portraits."></textarea>
          </div>
          <div class="field">
            <label for="field-websiteUrl">Website / Portfolio Link</label>
            <input type="text" id="field-websiteUrl" name="websiteUrl" placeholder="instagram.com/skittlesntulips" />
          </div>
        </fieldset>

        <fieldset class="form-section">
          <legend class="form-section-label">Photos</legend>
          <div class="field">
            <label for="artist-photo-input">Artist Photo</label>
            <div class="upload-zone" id="artist-photo-zone">
              <div class="upload-zone-text" id="artist-photo-text">Drag and drop or click to browse</div>
              <img id="artist-photo-preview" class="upload-preview" hidden />
              <input type="file" id="artist-photo-input" accept="image/*" hidden />
            </div>
            <input type="hidden" id="field-artistPhotoUrl" name="artistPhotoUrl" />
          </div>
          <div class="field">
            <label for="artwork-photo-input">Artwork Photo</label>
            <div class="upload-zone" id="artwork-photo-zone">
              <div class="upload-zone-text" id="artwork-photo-text">Drag and drop or click to browse</div>
              <img id="artwork-photo-preview" class="upload-preview" hidden />
              <input type="file" id="artwork-photo-input" accept="image/*" hidden />
            </div>
            <input type="hidden" id="field-artworkPhotoUrl" name="artworkPhotoUrl" />
          </div>
        </fieldset>

        <div class="form-actions">
          <div id="form-error" class="form-error" hidden></div>
          <div class="form-action-btns">
            <button type="button" class="btn btn-outline" id="form-cancel-btn">Cancel</button>
            <button type="submit" class="btn btn-gold" id="form-save-btn">
              <span id="save-btn-text">Save Entry</span>
              <span id="save-btn-loading" hidden>Saving…</span>
            </button>
          </div>
        </div>
      </form>
    </div>
  </aside>

  <script define:vars={{ entriesJson, firebaseConfig }}>
    const ALL_ENTRIES = JSON.parse(entriesJson);
    window.__FIREBASE_CONFIG__ = firebaseConfig;
  </script>

  <script type="module">
    import { initializeApp, getApps, getApp } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js';
    import { getStorage, ref, uploadBytes, getDownloadURL } from 'https://www.gstatic.com/firebasejs/11.6.0/firebase-storage.js';

    const app     = getApps().length ? getApp() : initializeApp(window.__FIREBASE_CONFIG__);
    const storage = getStorage(app);

    // ── Drawer open/close ─────────────────────────────────────────
    const drawer      = document.getElementById('feature-drawer');
    const backdrop     = document.getElementById('drawer-backdrop');
    const drawerTitle  = document.getElementById('drawer-title');

    function openDrawer() {
      drawer.hidden   = false;
      backdrop.hidden = false;
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        drawer.classList.add('drawer-open');
        backdrop.classList.add('backdrop-visible');
      }, 10);
    }

    function closeDrawer() {
      drawer.classList.remove('drawer-open');
      backdrop.classList.remove('backdrop-visible');
      setTimeout(() => {
        drawer.hidden   = true;
        backdrop.hidden = true;
        document.body.style.overflow = '';
        resetForm();
      }, 280);
    }

    document.getElementById('drawer-close-btn').addEventListener('click', closeDrawer);
    document.getElementById('form-cancel-btn').addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !drawer.hidden) closeDrawer(); });

    document.getElementById('new-entry-btn').addEventListener('click', () => {
      resetForm();
      drawerTitle.textContent = 'Add Entry';
      openDrawer();
    });

    function resetForm() {
      const form = document.getElementById('feature-form');
      form.reset();
      document.getElementById('field-id').value = '';
      document.getElementById('field-artistPhotoUrl').value = '';
      document.getElementById('field-artworkPhotoUrl').value = '';
      document.getElementById('artist-photo-preview').hidden = true;
      document.getElementById('artist-photo-preview').src = '';
      document.getElementById('artist-photo-text').hidden = false;
      document.getElementById('artwork-photo-preview').hidden = true;
      document.getElementById('artwork-photo-preview').src = '';
      document.getElementById('artwork-photo-text').hidden = false;
      document.getElementById('form-error').hidden = true;
    }

    // ── Upload zones (artist photo + artwork photo) ─────────────────
    function wireUploadZone(zoneId, inputId, previewId, textId) {
      const zone    = document.getElementById(zoneId);
      const input   = document.getElementById(inputId);
      const preview = document.getElementById(previewId);
      const text    = document.getElementById(textId);

      zone.addEventListener('click', () => input.click());
      zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
      zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
      zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.classList.remove('drag-over');
        if (e.dataTransfer.files?.[0]) {
          input.files = e.dataTransfer.files;
          input.dispatchEvent(new Event('change'));
        }
      });
      input.addEventListener('change', () => {
        const file = input.files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = () => {
          preview.src = reader.result;
          preview.hidden = false;
          text.hidden = true;
        };
        reader.readAsDataURL(file);
      });
    }
    wireUploadZone('artist-photo-zone', 'artist-photo-input', 'artist-photo-preview', 'artist-photo-text');
    wireUploadZone('artwork-photo-zone', 'artwork-photo-input', 'artwork-photo-preview', 'artwork-photo-text');

    async function uploadIfNeeded(inputId, urlFieldId, storageFolder) {
      const input   = document.getElementById(inputId);
      const urlField = document.getElementById(urlFieldId);
      const file = input.files?.[0];
      if (!file) return urlField.value || '';
      const ext  = file.name.split('.').pop();
      const path = `${storageFolder}/${Date.now()}-${Math.random().toString(36).slice(2, 8)}.${ext}`;
      const storageRef = ref(storage, path);
      await uploadBytes(storageRef, file);
      const url = await getDownloadURL(storageRef);
      urlField.value = url;
      return url;
    }

    // ── Edit buttons ──────────────────────────────────────────────
    document.querySelectorAll('[data-edit]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id    = btn.dataset.edit;
        const entry = ALL_ENTRIES.find(e => e.id === id);
        if (!entry) return;

        drawerTitle.textContent = 'Edit Entry';
        document.getElementById('field-id').value            = entry.id;
        document.getElementById('field-featureTitle').value  = entry.featureTitle || '';
        document.getElementById('field-eventId').value       = entry.eventId || '';
        document.getElementById('field-name').value          = entry.name || '';
        document.getElementById('field-bio').value           = entry.bio || '';
        document.getElementById('field-websiteUrl').value    = entry.websiteUrl || '';
        document.getElementById('field-artistPhotoUrl').value  = entry.artistPhotoUrl || '';
        document.getElementById('field-artworkPhotoUrl').value = entry.artworkPhotoUrl || '';

        if (entry.artistPhotoUrl) {
          document.getElementById('artist-photo-preview').src = entry.artistPhotoUrl;
          document.getElementById('artist-photo-preview').hidden = false;
          document.getElementById('artist-photo-text').hidden = true;
        }
        if (entry.artworkPhotoUrl) {
          document.getElementById('artwork-photo-preview').src = entry.artworkPhotoUrl;
          document.getElementById('artwork-photo-preview').hidden = false;
          document.getElementById('artwork-photo-text').hidden = true;
        }

        openDrawer();
      });
    });

    // ── Delete buttons ────────────────────────────────────────────
    document.querySelectorAll('[data-delete]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id   = btn.dataset.delete;
        const name = btn.dataset.name || 'this entry';
        if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;

        btn.disabled = true;

        const res = await fetch('/api/admin/delete-festival-feature', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ id }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          alert('Delete failed. Please try again.');
          btn.disabled = false;
        }
      });
    });

    // ── Form submit ───────────────────────────────────────────────
    document.getElementById('feature-form').addEventListener('submit', async e => {
      e.preventDefault();

      const errEl   = document.getElementById('form-error');
      const saveBtn = document.getElementById('form-save-btn');
      const btnText = document.getElementById('save-btn-text');
      const loading = document.getElementById('save-btn-loading');

      const featureTitle = document.getElementById('field-featureTitle').value.trim();
      const name         = document.getElementById('field-name').value.trim();

      if (!featureTitle || !name) {
        errEl.textContent = 'Feature Title and Name are required.';
        errEl.hidden = false;
        return;
      }

      errEl.hidden     = true;
      saveBtn.disabled = true;
      btnText.hidden   = true;
      loading.hidden   = false;

      try {
        loading.textContent = 'Uploading photos…';
        const artistPhotoUrl  = await uploadIfNeeded('artist-photo-input', 'field-artistPhotoUrl', 'festival-feature-photos');
        const artworkPhotoUrl = await uploadIfNeeded('artwork-photo-input', 'field-artworkPhotoUrl', 'festival-feature-artwork');
        loading.textContent = 'Saving…';

        const payload = {
          id:           document.getElementById('field-id').value.trim() || null,
          eventId:      document.getElementById('field-eventId')?.value || '',
          featureTitle,
          name,
          bio:          document.getElementById('field-bio').value.trim(),
          websiteUrl:   document.getElementById('field-websiteUrl').value.trim(),
          artistPhotoUrl,
          artworkPhotoUrl,
        };

        const res = await fetch('/api/admin/save-festival-feature', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Save failed');
        }

        window.location.reload();
      } catch (err) {
        errEl.textContent = 'Error: ' + (err.message || 'Please try again.');
        errEl.hidden      = false;
        saveBtn.disabled  = false;
        btnText.hidden    = false;
        loading.hidden    = true;
      }
    });
  </script>
</AdminLayout>

<style>
  /* ── Site variable aliases (admin pages only load admin.css) ── */
  :root {
    --white:        #ffffff;
    --navy:         #1a2456;
    --muted:        #5a5a7a;
    --border:       #e2e0d8;
    --cream:        #f7f5f0;
    --red:          #b52626;
    --gold:         #e8a020;
    --font-display: 'Playfair Display', Georgia, serif;
    --radius:       8px;
    --radius-sm:    6px;
    --shadow-card:  0 2px 12px rgba(26, 36, 86, 0.08);
    --shadow-hover: 0 4px 20px rgba(26, 36, 86, 0.14);
  }

  .page-subtitle {
    font-size: 14px;
    color: var(--muted);
    margin-top: 4px;
    max-width: 560px;
  }

  .empty-state { text-align: center; padding: 64px 0; }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }
  .empty-state p { font-size: 16px; color: var(--muted); margin: 0 0 6px; }
  .empty-sub { font-size: 14px !important; }

  /* ── Feature groups ── */
  .feature-group { margin-bottom: 32px; }
  .feature-group-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--navy);
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .feature-group-count {
    font-family: inherit;
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 2px 10px;
  }

  .feature-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }

  .feature-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .feature-card:hover { box-shadow: var(--shadow-hover); }

  .feature-card-photos { display: flex; height: 100px; }
  .feature-photo-slot {
    flex: 1;
    background: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .feature-photo-slot img { width: 100%; height: 100%; object-fit: cover; }
  .feature-photo-placeholder { font-size: 11px; color: var(--muted); text-align: center; padding: 0 8px; }

  .feature-card-body { padding: 14px 16px; }
  .feature-card-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--navy);
    margin: 0 0 6px;
  }
  .feature-card-bio {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.5;
    margin: 0 0 10px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .feature-card-footer { display: flex; align-items: center; gap: 8px; }
  .feature-card-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--navy);
    text-decoration: none;
    font-weight: 600;
  }
  .feature-card-link:hover { text-decoration: underline; }
  .feature-card-spacer { flex: 1; }

  .btn-icon {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--navy);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .btn-icon:hover { border-color: var(--navy); background: var(--cream); }
  .btn-icon-danger { color: var(--red); }
  .btn-icon-danger:hover { border-color: var(--red); background: #fee2e2; }

  /* ── DRAWER (shared with Pinned Content pattern) ── */
  .drawer-backdrop {
    position: fixed; inset: 0; background: rgba(0,0,0,0.42);
    z-index: 200; opacity: 0; transition: opacity 0.28s;
  }
  .drawer-backdrop[hidden] { display: none; }
  .drawer-backdrop.backdrop-visible { opacity: 1; }

  .feature-drawer {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: 480px; max-width: 100vw;
    background: var(--white);
    z-index: 300;
    display: flex; flex-direction: column;
    box-shadow: -8px 0 40px rgba(0,0,0,0.18);
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .feature-drawer[hidden] { display: none; }
  .feature-drawer.drawer-open { transform: translateX(0); }

  .drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px; border-bottom: 1.5px solid var(--border);
    flex-shrink: 0; background: var(--white);
  }
  .drawer-header h2 {
    font-family: var(--font-display); font-size: 20px; font-weight: 700;
    color: var(--navy); margin: 0;
  }
  .drawer-close {
    background: none; border: none; font-size: 18px; cursor: pointer;
    color: var(--muted); padding: 4px 8px; border-radius: 4px; line-height: 1;
    transition: background 0.15s, color 0.15s;
  }
  .drawer-close:hover { background: var(--cream); color: var(--navy); }

  .drawer-body { flex: 1; overflow-y: auto; padding: 24px; }

  #feature-form { display: flex; flex-direction: column; gap: 0; }

  .form-section { border: none; padding: 0; margin: 0 0 24px; }
  .form-section-label {
    font-size: 10.5px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 14px; display: block; padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
  .field label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--navy);
  }
  .required { color: var(--red); }

  .field input, .field select, .field textarea {
    font-family: inherit; font-size: 14px; color: var(--navy);
