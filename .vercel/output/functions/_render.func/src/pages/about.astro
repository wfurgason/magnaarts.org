---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const board = [
  { name: 'Wes Furgason',      role: 'President' },
  { name: 'Tammy Furgason',    role: 'Secretary' },
  { name: 'Todd Richards',     role: 'Treasurer' },
  { name: 'Carolyn Richards',  role: 'Board Member' },
  { name: 'Melissa Wayman',    role: 'Board Member' },
  { name: 'Melissa Gates',     role: 'Board Member' },
];

const programs = [
  {
    icon: '♪',
    color: 'blue',
    title: 'Music & Movies in the Park',
    body: 'Every Friday night June through August at Pleasant Green Park. Live music from 8 PM followed by a movie on our 35-ft inflatable screen. Over 300 people attend each event — 14 musical acts each summer.',
  },
  {
    icon: '★',
    color: 'amber',
    title: 'Magna Main Street Arts Festival',
    body: 'Our flagship annual event each August draws 5,000–7,000 attendees to historic Magna Main Street. Live music, a fine arts contest, street performers, and arts and food vendors.',
  },
  {
    icon: '🎤',
    color: 'green',
    title: 'Open Mic Night',
    body: '8–10 events per year at the Magna Library. Two hours of music, comedy, and poetry by community participants. Sound system by the Arts Council; space and refreshments by the Library.',
  },
  {
    icon: '✦',
    color: 'green',
    title: 'Group Art Night',
    body: 'Artist-guided sessions at the Magna Library where participants create art together. Consistently draws around 20 participants — one of our most popular ongoing programs.',
  },
  {
    icon: '📚',
    color: 'blue',
    title: 'Annual Arts Seminar',
    body: 'Each seminar focuses on a different art discipline and features a panel of experts, educational presentations, community outreach, and an open Q&A session.',
  },
];

const partners = [
  { name: 'Magna Library', detail: 'Host venue for Open Mic, Group Art Night, and Arts Seminars.' },
  { name: 'Salt Lake County Parks & Rec', detail: 'Waives park rental fees for Music & Movies in the Park at Pleasant Green Park.' },
  { name: 'ZAP (Zoo, Arts & Parks)', detail: 'Sales tax funding program supporting Salt Lake County arts organizations.' },
  { name: 'Utah Division of Arts & Museums', detail: 'State-level arts agency partnership and grant support.' },
];
---

<BaseLayout
  title="About — Magna Arts Council"
  description="Learn about the Magna Arts Council — Magna, Utah's Designated Local Arts Agency. Meet our board, explore our programs, and discover our community partners."
>
  <Header />

  <main>

    <!-- ── PAGE HERO ── -->
    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">About Us</div>
        <h1>Community. Culture. Magna.</h1>
        <p class="hero-sub">
          The Magna Arts Council is Magna, Utah's Designated Local Arts Agency —
          bringing free music, art, film, and culture to our community.
        </p>
      </div>
    </section>

    <!-- ── MISSION ── -->
    <section class="section mission-section reveal">
      <div class="container mission-inner">
        <div class="mission-text">
          <h2>Who We Are</h2>
          <p>
            The Magna Arts Council has a well-structured team and a network of partners
            to support its activities and events. We believe a strong community engagement
            strategy — utilizing both institutional partnerships and grassroots volunteer
            efforts — is essential to the success of everything we do.
          </p>
          <p>
            Regular meetings are open to partners, volunteers, and community residents.
            Our goal is to keep everyone aligned with the organization's mission and
            to ensure arts programming continues to enrich Magna's cultural landscape.
          </p>
          <div class="mission-stats">
            <div class="stat">
              <span class="stat-number">300+</span>
              <span class="stat-label">per concert</span>
            </div>
            <div class="stat">
              <span class="stat-number">5–7k</span>
              <span class="stat-label">Arts Festival attendance</span>
            </div>
            <div class="stat">
              <span class="stat-number">14</span>
              <span class="stat-label">live acts each summer</span>
            </div>
          </div>
        </div>
        <div class="mission-pillars">
          <div class="pillar pillar-navy">
            <span class="pillar-icon">👥</span>
            <div>
              <h3>Leadership</h3>
              <p>An elected board committed to transparency, community service, and growing the arts in Magna.</p>
            </div>
          </div>
          <div class="pillar pillar-gold">
            <span class="pillar-icon">🤝</span>
            <div>
              <h3>Partnerships</h3>
              <p>Collaboration with the Library, Salt Lake County, ZAP, and local schools and organizations.</p>
            </div>
          </div>
          <div class="pillar pillar-blue">
            <span class="pillar-icon">🎶</span>
            <div>
              <h3>Events</h3>
              <p>Free, open, and welcoming events for everyone in Magna — year-round programming for all ages.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PROGRAMS ── -->
    <section class="section programs-section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">Our Programs</h2>
        </div>
        <div class="programs-grid">
          {programs.map((p, i) => (
            <div class={`program-card program-${p.color} reveal`} style={`transition-delay:${i * 0.08}s`}>
              <span class="program-icon">{p.icon}</span>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── BOARD ── -->
    <section class="section board-section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">Board of Directors</h2>
        </div>
        <div class="board-grid">
          {board.map((m) => (
            <div class="board-card reveal">
              <div class="board-avatar">{m.name.charAt(0)}</div>
              <div>
                <div class="board-name">{m.name}</div>
                <div class="board-role">{m.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PARTNERS ── -->
    <section class="section partners-section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">Our Partners</h2>
          <p class="section-sub">We couldn't do this without the support of these organizations.</p>
        </div>
        <div class="partners-grid">
          {partners.map((p) => (
            <div class="partner-card reveal">
              <h3>{p.name}</h3>
              <p>{p.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-banner">
      <div class="container cta-inner reveal">
        <div>
          <h2>Get Involved</h2>
          <p>Volunteer, attend, propose a program, or join the board. There's a place for you here.</p>
        </div>
        <a href="/get-involved" class="btn btn-gold">Find Your Place →</a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    background: var(--navy);
    color: var(--white);
    padding: 72px 0 64px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(232, 160, 32, 0.18);
    border: 1px solid rgba(232, 160, 32, 0.45);
    color: var(--gold-lt);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 18px;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── MISSION ── */
  .mission-section { background: var(--white); }

  .mission-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .mission-text h2 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 20px;
  }

  .mission-text p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .mission-stats {
    display: flex;
    gap: 32px;
    margin-top: 36px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .stat { display: flex; flex-direction: column; gap: 4px; }

  .stat-number {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 900;
    color: var(--navy);
    line-height: 1;
  }

  .stat-label {
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .mission-pillars {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pillar {
    padding: 24px 28px;
    border-radius: var(--radius);
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .pillar-navy { background: var(--navy); color: var(--white); }
  .pillar-gold { background: var(--gold); color: var(--navy-dk); }
  .pillar-blue { background: #dbeafe; color: var(--navy); }

  .pillar-icon { font-size: 24px; flex-shrink: 0; margin-top: 2px; }

  .pillar h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .pillar p { font-size: 14px; line-height: 1.6; opacity: 0.85; }

  /* ── PROGRAMS ── */
  .programs-section { background: var(--cream); }

  .section-header { margin-bottom: 40px; }

  .section-title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: var(--navy);
  }

  .section-sub {
    font-size: 16px;
    color: var(--muted);
    margin-top: 8px;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .program-card {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 28px 24px;
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.22s, transform 0.22s;
  }

  .program-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
  }

  .program-blue::before  { background: var(--blue); }
  .program-amber::before { background: var(--amber); }
  .program-green::before { background: var(--green); }

  .program-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }

  .program-icon {
    font-size: 28px;
    display: block;
    margin-bottom: 14px;
  }

  .program-card h3 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .program-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
  }

  /* ── BOARD ── */
  .board-section { background: var(--white); }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .board-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--cream);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .board-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .board-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--navy);
  }

  .board-role {
    font-size: 13px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* ── PARTNERS ── */
  .partners-section { background: var(--cream); }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .partner-card {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 24px 28px;
    box-shadow: var(--shadow-card);
    border-left: 4px solid var(--gold);
  }

  .partner-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .partner-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ── CTA BANNER ── */
  .cta-banner {
    background: var(--navy-dk);
    color: var(--white);
    padding: 56px 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .cta-inner h2 {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .cta-inner p {
    font-size: 15px;
    color: rgba(255,255,255,0.72);
    max-width: 520px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .mission-inner  { grid-template-columns: 1fr; gap: 40px; }
    .programs-grid  { grid-template-columns: 1fr 1fr; }
    .board-grid     { grid-template-columns: 1fr 1fr; }
    .cta-inner      { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 600px) {
    .programs-grid  { grid-template-columns: 1fr; }
    .board-grid     { grid-template-columns: 1fr; }
    .partners-grid  { grid-template-columns: 1fr; }
    .mission-stats  { flex-wrap: wrap; gap: 20px; }
  }
</style>
